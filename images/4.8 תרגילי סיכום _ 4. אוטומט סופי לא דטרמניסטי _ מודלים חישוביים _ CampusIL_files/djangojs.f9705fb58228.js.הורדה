    "Change background": "\u05e9\u05d9\u05e0\u05d5\u05d9 \u05e8\u05e7\u05e2",
    "Change due date for student": "\u05e9\u05e0\u05d4 \u05ea\u05d0\u05e8\u05d9\u05da \u05d9\u05e2\u05d3 \u05e2\u05d1\u05d5\u05e8 \u05e1\u05d8\u05d5\u05d3\u05e0\u05d8",
    "Change image": "\u05e9\u05e0\u05d4 \u05ea\u05de\u05d5\u05e0\u05d4",
    "Change my Password": "\u05d0\u05d9\u05e4\u05d5\u05e1 \u05e1\u05d9\u05e1\u05de\u05d4",
    "Change or Leave Session": "\u05e9\u05e0\u05d5 \u05d0\u05d5 \u05e2\u05d6\u05d1\u05d5 \u05e9\u05d9\u05e2\u05d5\u05e8",
    "Change the status of an enrollment code.": "\u05e9\u05e0\u05d4 \u05d0\u05ea \u05d4\u05e1\u05d8\u05d8\u05d5\u05e1 \u05e9\u05dc \u05e7\u05d5\u05d3 \u05d4\u05d4\u05e8\u05e9\u05de\u05d4",
    "Change to a different session or leave the current session.": "\u05d4\u05d7\u05dc\u05e4\u05d4 \u05dc\u05e9\u05d9\u05e2\u05d5\u05e8 \u05d0\u05d7\u05e8 \u05d0\u05d5 \u05e2\u05d6\u05d9\u05d1\u05ea \u05d4\u05e9\u05d9\u05e2\u05d5\u05e8 \u05d4\u05e0\u05d5\u05db\u05d7\u05d9.",
    "Change your life and start learning today by activating your {platform_name} account. Click on the link below or copy and paste it into your browser's address bar.": "\u05e9\u05e0\u05d4 \u05d0\u05ea \u05d7\u05d9\u05d9\u05da \u05d5\u05d4\u05ea\u05d7\u05dc \u05dc\u05dc\u05de\u05d5\u05d3 \u05d4\u05d9\u05d5\u05dd \u05d1\u05d0\u05de\u05e6\u05e2\u05d5\u05ea \u05d4\u05e4\u05e2\u05dc\u05ea \u05d7\u05e9\u05d1\u05d5\u05df {platform_name} \u05e9\u05dc\u05da. \u05dc\u05d7\u05e5 \u05e2\u05dc \u05d4\u05e7\u05d9\u05e9\u05d5\u05e8 \u05d4\u05de\u05e6\u05d5\u05e8\u05e3 \u05d0\u05d5 \u05d4\u05e2\u05ea\u05e7 \u05d5\u05d4\u05d3\u05d1\u05e7 \u05d0\u05d5\u05ea\u05d5 \u05dc\u05ea\u05d5\u05da \u05e9\u05d5\u05e8\u05ea \u05d4\u05db\u05ea\u05d5\u05d1\u05ea \u05e9\u05dc \u05d4\u05d3\u05e4\u05d3\u05e4\u05df \u05e9\u05dc\u05da.",
    "Changes": "\u05e9\u05d9\u05e0\u05d5\u05d9\u05d9\u05dd",
    "Changes to steps that are not selected as part of the assignment will not be saved.": "\u05e9\u05d9\u05e0\u05d5\u05d9\u05d9\u05dd \u05d1\u05e9\u05dc\u05d1\u05d9\u05dd \u05e9\u05dc\u05d0 \u05d1\u05d7\u05e8\u05ea\u05dd \u05dc\u05d0 \u05d9\u05d9\u05e9\u05de\u05e8\u05d5 \u05dc\u05d4\u05d2\u05e9\u05ea \u05d4\u05de\u05d8\u05dc\u05d4.",
    "Changing the content learners see": "\u05e9\u05d9\u05e0\u05d5\u05d9 \u05d4\u05ea\u05d5\u05db\u05df \u05e9\u05d4\u05dc\u05d5\u05de\u05d3\u05d9\u05dd \u05e8\u05d5\u05d0\u05d9\u05dd",
    "Changing..": "\u05de\u05d1\u05e6\u05e2 \u05e9\u05d9\u05e0\u05d5\u05d9..",
    "Chapter Asset": "\u05e0\u05db\u05e1 \u05d4\u05e4\u05e8\u05e7",
    "Chapter Name": "\u05e9\u05dd \u05d4\u05e4\u05e8\u05e7",
    "Chapter information": "\u05de\u05d9\u05d3\u05e2 \u05e2\u05dc \u05d4\u05e4\u05e8\u05e7",
    "Chapter name and asset_path are both required": "\u05e9\u05dd \u05d4\u05e4\u05e8\u05e7 \u05d5\u05beasset_path \u05d4\u05dd \u05e9\u05d3\u05d5\u05ea \u05d7\u05d5\u05d1\u05d4",
    "Chapter name is required": "\u05e9\u05dd \u05d4\u05e4\u05e8\u05e7 \u05d4\u05d5\u05d0 \u05e9\u05d3\u05d4 \u05d7\u05d5\u05d1\u05d4",
    "Chapter {order}": "\u05e4\u05e8\u05e7 {order}",
    "Check Video Duration": "\u05d1\u05d3\u05e7\u05d5 \u05d0\u05ea \u05d0\u05d5\u05e8\u05da \u05e1\u05e8\u05d8\u05d5\u05e0\u05d9 \u05d4\u05d5\u05d5\u05d9\u05d3\u05d0\u05d5",
    "Check Your Email": "\u05d1\u05d3\u05d5\u05e7 \u05d0\u05ea \u05d4\u05d3\u05d5\u05d0\u05e8 \u05d4\u05d0\u05dc\u05e7\u05d8\u05e8\u05d5\u05e0\u05d9 \u05e9\u05dc\u05da",
    "Check all that apply": "\u05e0\u05d0 \u05dc\u05e1\u05de\u05df \u05d0\u05ea \u05db\u05dc \u05de\u05d4 \u05e9\u05d4\u05d5\u05dc\u05dd",
    "Check here to apply the above permissions recursively to articles under this one.": "\u05e1\u05de\u05df \u05db\u05d0\u05df \u05e2\u05dc \u05de\u05e0\u05ea \u05dc\u05d4\u05d7\u05d9\u05dc \u05d1\u05d0\u05d5\u05e4\u05df \u05e8\u05e7\u05d5\u05e8\u05e1\u05d9\u05d1\u05d9 \u05d0\u05ea \u05d4\u05e8\u05e9\u05d0\u05d5\u05ea \u05dc\u05db\u05dc \u05d4\u05de\u05d0\u05de\u05e8\u05d9\u05dd \u05d4\u05e0\u05de\u05e6\u05d0\u05d9\u05dd \u05de\u05ea\u05d7\u05ea \u05dc\u05de\u05d0\u05de\u05e8 \u05d6\u05d4.",
    "Check the highlighted fields below and try again.": "\u05e1\u05de\u05df \u05d0\u05ea \u05d4\u05e9\u05d3\u05d5\u05ea \u05d4\u05de\u05d5\u05d3\u05d2\u05e9\u05d9\u05dd \u05dc\u05d4\u05dc\u05df \u05d5\u05e0\u05e1\u05d4 \u05e9\u05d5\u05d1.",
    "Check this box to receive an email digest once a day notifying you about new, unread activity from posts you are following.": "\u05e1\u05de\u05df \u05ea\u05d9\u05d1\u05d4 \u05d6\u05d5 \u05e2\u05dc \u05de\u05e0\u05ea \u05dc\u05e7\u05d1\u05dc \u05ea\u05e7\u05e6\u05d9\u05e8 \u05d9\u05d5\u05de\u05d9 \u05d1\u05d3\u05d5\u05d0\u05e8 \u05d0\u05dc\u05e7\u05d8\u05e8\u05d5\u05e0\u05d9 \u05e2\u05dc \u05e4\u05e2\u05d9\u05dc\u05d5\u05ea \u05d7\u05d3\u05e9\u05d4 \u05d5\u05e2\u05dc \u05d4\u05d5\u05d3\u05e2\u05d5\u05ea \u05e9\u05dc\u05d0 \u05e0\u05e7\u05e8\u05d0\u05d5 \u05d1\u05e4\u05d5\u05e1\u05d8\u05d9\u05dd \u05e9\u05d0\u05ea\u05d4 \u05e2\u05d5\u05e7\u05d1 \u05d0\u05d7\u05e8\u05d9\u05d4\u05dd. ",
