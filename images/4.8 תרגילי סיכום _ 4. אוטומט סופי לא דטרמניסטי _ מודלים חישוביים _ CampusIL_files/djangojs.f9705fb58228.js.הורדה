    "A library has not yet been selected.": "\u05dc\u05d0 \u05e0\u05d1\u05d7\u05e8\u05d4 \u05e1\u05e4\u05e8\u05d9\u05d4.",
    "A license defines how the contents of this block can be shared and reused.": "\u05e8\u05d9\u05e9\u05d9\u05d5\u05df \u05de\u05d2\u05d3\u05d9\u05e8 \u05db\u05d9\u05e6\u05d3 \u05e0\u05d9\u05ea\u05df \u05dc\u05e9\u05ea\u05e3 \u05d5\u05dc\u05e2\u05e9\u05d5\u05ea \u05e9\u05d9\u05de\u05d5\u05e9 \u05d7\u05d5\u05d6\u05e8 \u05d1\u05ea\u05d5\u05db\u05df \u05e9\u05dc \u05d1\u05dc\u05d5\u05e7 \u05d6\u05d4.",
    "A list of courses you have just enrolled in as a verified student": "\u05e8\u05e9\u05d9\u05de\u05ea \u05e7\u05d5\u05e8\u05e1\u05d9\u05dd \u05dc\u05d4\u05dd \u05e0\u05e8\u05e9\u05de\u05ea \u05db\u05e1\u05d8\u05d5\u05d3\u05e0\u05d8 \u05d1\u05e2\u05dc \u05d6\u05d4\u05d5\u05ea \u05de\u05d0\u05d5\u05de\u05ea\u05ea. ",
    "A list of problem/block types to generate the report for. This field can be omitted if the report should include details of allblock types.": "\u05e8\u05e9\u05d9\u05de\u05d4 \u05e9\u05dc \u05e1\u05d5\u05d2\u05d9 \u05d4\u05d1\u05e2\u05d9\u05d5\u05ea/\u05d4\u05d1\u05dc\u05d5\u05e7\u05d9\u05dd \u05e9\u05d1\u05e9\u05d1\u05d9\u05dc\u05dd \u05d4\u05d3\u05d5\u05d7 \u05d9\u05d5\u05e4\u05e7. \u05e0\u05d9\u05ea\u05df \u05dc\u05d4\u05e9\u05de\u05d9\u05d8 \u05e9\u05d3\u05d4 \u05d6\u05d4 \u05d0\u05dd \u05d4\u05d3\u05d5\u05d7 \u05d0\u05de\u05d5\u05e8 \u05dc\u05db\u05dc\u05d5\u05dc \u05e4\u05e8\u05d8\u05d9\u05dd \u05e9\u05dc \u05db\u05dc \u05e1\u05d5\u05d2\u05d9 \u05d4\u05d1\u05dc\u05d5\u05e7\u05d9\u05dd.",
    "A list of usage keys for the blocks to include in the report.": "\u05e8\u05e9\u05d9\u05de\u05d4 \u05e9\u05dc \u05de\u05e4\u05ea\u05d7\u05d5\u05ea \u05e9\u05d9\u05de\u05d5\u05e9 \u05e2\u05d1\u05d5\u05e8 \u05d4\u05d1\u05dc\u05d5\u05e7\u05d9\u05dd \u05e9\u05d9\u05d9\u05db\u05dc\u05dc\u05d5 \u05d1\u05d3\u05d5\u05d7",
    "A list summarizing what students should look forward to in this section.": "\u05e8\u05e9\u05d9\u05de\u05d4 \u05d4\u05de\u05e1\u05de\u05db\u05de\u05ea \u05d0\u05ea \u05de\u05d4 \u05e9\u05e6\u05e4\u05d5\u05d9 \u05dc\u05ea\u05dc\u05de\u05d9\u05d3\u05d9\u05dd \u05d1\u05d7\u05dc\u05e7 \u05d6\u05d4.",
    "A maximum of {0} components may be added.": "\u05de\u05e1\u05e4\u05e8 \u05de\u05e8\u05d1\u05d9 \u05e9\u05dc {0} \u05e8\u05db\u05d9\u05d1\u05d9\u05dd \u05e0\u05d9\u05ea\u05e0\u05d9\u05dd \u05dc\u05d4\u05d5\u05e1\u05e4\u05d4.",
    "A name that identifies your team (maximum 255 characters).": "\u05e9\u05dd \u05e9\u05de\u05d6\u05d4\u05d4 \u05d0\u05ea \u05d4\u05e6\u05d5\u05d5\u05ea \u05e9\u05dc\u05da (255 \u05ea\u05d5\u05d5\u05d9\u05dd \u05dc\u05db\u05dc \u05d4\u05d9\u05d5\u05ea\u05e8).",
    "A new revision of the article was successfully added.": "\u05e0\u05d5\u05e1\u05e4\u05d4 \u05de\u05d4\u05d3\u05d5\u05e8\u05d4 \u05d7\u05d3\u05e9\u05d4 \u05e9\u05dc \u05d4\u05e2\u05e8\u05da \u05d1\u05d4\u05e6\u05dc\u05d7\u05d4.",
    "A new revision was created: Merge between Revision #%(r1)d and Revision #%(r2)d": "\u05d2\u05e8\u05e1\u05d4 \u05d7\u05d3\u05e9\u05d4 \u05e0\u05d5\u05e6\u05e8\u05d4: \u05de\u05d9\u05d6\u05d5\u05d2 \u05d1\u05d9\u05df \u05d2\u05e8\u05e1\u05d4 #%(r1)d \u05d5\u05d2\u05e8\u05e1\u05d4 #%(r2)d",
    "A non zero positive integer is expected": "\u05e6\u05e4\u05d5\u05d9 \u05de\u05e1\u05e4\u05e8 \u05e9\u05dc\u05dd \u05d7\u05d9\u05d5\u05d1\u05d9 \u05e9\u05d0\u05d9\u05e0\u05d5 \u05d0\u05e4\u05e1",
    "A non-root note must always have a slug.": "\u05e2\u05d1\u05d5\u05e8 \u05d4\u05e2\u05e8\u05d4 \u05e9\u05d0\u05d9\u05e0\u05d4 \u05e8\u05d0\u05e9\u05d9\u05ea \u05d7\u05d9\u05d9\u05d1 \u05dc\u05d4\u05d9\u05d5\u05ea \u05ea\u05de\u05d9\u05d3 \u05e9\u05dd \u05e7\u05e6\u05e8 \u05dc\u05de\u05d0\u05de\u05e8. ",
    "A plugin was changed": "\u05ea\u05d5\u05e1\u05e3 \u05e9\u05d5\u05bc\u05e0\u05d4.",
    "A proctored exam attempt for {exam_name} in {course_name} by username: {student_username} was reviewed as {review_status} by the proctored exam review provider.\nReview link: {review_url}": "\u05e0\u05d9\u05e1\u05d9\u05d5\u05df \u05de\u05d1\u05d7\u05df \u05d1\u05d4\u05e9\u05d2\u05d7\u05d4 \u05e2\u05d1\u05d5\u05e8 {exam_name} \u05d1-{course_name} \u05e2\u05dc \u05d9\u05d3\u05d9 \u05e9\u05dd \u05de\u05e9\u05ea\u05de\u05e9: {student_username} \u05e0\u05d1\u05d3\u05e7 \u05d1\u05ea\u05d5\u05e8 {review_status} \u05e2\u05dc \u05d9\u05d3\u05d9 \u05e1\u05e4\u05e7 \u05d1\u05d3\u05d9\u05e7\u05ea \u05de\u05d1\u05d7\u05df.\n \u05d4\u05d9\u05db\u05e0\u05e1\u05d5 \u05dc\u05e7\u05d9\u05e9\u05d5\u05e8: {review_url}",
    "A properly formatted e-mail is required": "\u05db\u05ea\u05d5\u05d1\u05ea \u05d3\u05d5\u05d0\u05e8 \u05d0\u05dc\u05e7\u05d8\u05e8\u05d5\u05e0\u05d9 \u05d7\u05d9\u05d9\u05d1\u05ea \u05dc\u05d4\u05d9\u05d5\u05ea \u05d1\u05e4\u05d5\u05e8\u05de\u05d8 \u05ea\u05e7\u05d9\u05df",
    "A refund request has been initiated for {username} ({email}). To process this request, please visit the link(s) below.": "\u05d1\u05e7\u05e9\u05d4 \u05dc\u05d4\u05d7\u05d6\u05e8 \u05db\u05e1\u05e4\u05d9 \u05e0\u05d5\u05e6\u05e8\u05d4 \u05e2\u05d1\u05d5\u05e8 {username} ({email}). \u05e2\u05dc \u05de\u05e0\u05ea \u05dc\u05e2\u05d1\u05d3 \u05d1\u05e7\u05e9\u05d4 \u05d6\u05d5, \u05d1\u05e7\u05e8 \u05d1\u05e7\u05d9\u05e9\u05d5\u05e8(\u05d9\u05dd) \u05e9\u05dc\u05d4\u05dc\u05df.",
    "A short description of the team to help other learners understand the goals or direction of the team (maximum 300 characters).": "\u05ea\u05d9\u05d0\u05d5\u05e8 \u05e7\u05e6\u05e8 \u05e9\u05dc \u05d4\u05e6\u05d5\u05d5\u05ea \u05e9\u05d9\u05e2\u05d6\u05d5\u05e8 \u05dc\u05ea\u05dc\u05de\u05d9\u05d3\u05d9\u05dd \u05d0\u05d7\u05e8\u05d9\u05dd \u05dc\u05d4\u05d1\u05d9\u05df \u05d0\u05ea \u05d4\u05d9\u05e2\u05d3\u05d9\u05dd \u05d0\u05d5 \u05d4\u05db\u05d9\u05d5\u05d5\u05df \u05e9\u05dc \u05d4\u05e6\u05d5\u05d5\u05ea (300 \u05ea\u05d5\u05d5\u05d9\u05dd \u05dc\u05db\u05dc \u05d4\u05d9\u05d5\u05ea\u05e8).",
    "A short summary of what the file contains": "\u05e1\u05d9\u05db\u05d5\u05dd \u05e7\u05e6\u05e8 \u05e2\u05dc \u05de\u05d4 \u05e9\u05de\u05db\u05d9\u05dc \u05d4\u05e7\u05d5\u05d1\u05e5 ",
    "A slug may not begin with an underscore.": "\u05e9\u05dd \u05e7\u05e6\u05e8 \u05dc\u05de\u05d0\u05de\u05e8 \u05d0\u05d9\u05e0\u05d5 \u05d9\u05db\u05d5\u05dc \u05dc\u05d4\u05ea\u05d7\u05d9\u05dc \u05d1\u05e7\u05d5 \u05ea\u05d7\u05ea\u05d5\u05df",
    "A slug named \"%s\" already exists.": "\u05e9\u05dd \u05de\u05e7\u05d5\u05e6\u05e8 \"%s\" \u05e9\u05dc \u05d4\u05de\u05d0\u05de\u05e8 \u05e7\u05d9\u05d9\u05dd \u05db\u05d1\u05e8 \u05d1\u05de\u05e2\u05e8\u05db\u05ea.",
    "A subcategory name for the discussion. This name appears in the left pane of the discussion forum for the course.": "\u05e9\u05dd \u05ea\u05ea \u05e7\u05d8\u05d2\u05d5\u05e8\u05d9\u05d4 \u05e2\u05d1\u05d5\u05e8 \u05d4\u05d3\u05d9\u05d5\u05df. \u05d4\u05e9\u05dd \u05d4\u05d6\u05d4 \u05de\u05d5\u05e4\u05d9\u05e2 \u05d1\u05d7\u05dc\u05d5\u05e0\u05d9\u05ea \u05d4\u05e9\u05de\u05d0\u05dc\u05d9\u05ea \u05e9\u05dc \u05e4\u05d5\u05e8\u05d5\u05dd \u05d4\u05d3\u05d9\u05d5\u05e0\u05d9\u05dd \u05e9\u05dc \u05d4\u05e7\u05d5\u05e8\u05e1. ",
    "A system error occurred while your course was being processed. Please go to the original course to try the re-run again, or contact your PM for assistance.": "\u05d0\u05d9\u05e8\u05e2\u05d4 \u05e9\u05d2\u05d9\u05d0\u05ea \u05de\u05e2\u05e8\u05db\u05ea \u05d1\u05de\u05d4\u05dc\u05da \u05e2\u05d9\u05d1\u05d5\u05d3 \u05d4\u05e7\u05d5\u05e8\u05e1. \u05e0\u05d0 \u05d2\u05e9 \u05dc\u05e7\u05d5\u05e8\u05e1 \u05d4\u05de\u05e7\u05d5\u05e8\u05d9 \u05d5\u05e0\u05e1\u05d4 \u05e9\u05d5\u05d1 \u05dc\u05d9\u05e6\u05d5\u05e8 \u05de\u05d7\u05d6\u05d5\u05e8 \u05dc\u05d9\u05de\u05d5\u05d3\u05d9\u05dd \u05d7\u05d3\u05e9 \u05d0\u05d5 \u05e6\u05d5\u05e8 \u05e7\u05e9\u05e8 \u05e2\u05dd \u05de\u05e0\u05d4\u05dc \u05d4\u05e4\u05e8\u05d5\u05d9\u05e7\u05d8 \u05e9\u05dc\u05da \u05e2\u05dc \u05de\u05e0\u05ea \u05dc\u05e7\u05d1\u05dc \u05e2\u05d6\u05e8\u05d4. ",
    "A transcript file is required.": "\u05e0\u05d3\u05e8\u05e9 \u05e7\u05d5\u05d1\u05e5 \u05ea\u05de\u05dc\u05d9\u05dc.",
    "A transcript with the \"{language_code}\" language code already exists.": "\u05db\u05d1\u05e8 \u05e7\u05d9\u05d9\u05dd \u05ea\u05de\u05dc\u05d9\u05dc \u05e2\u05dd \u05e7\u05d5\u05d3 \u05d4\u05e9\u05e4\u05d4 \u201e{language_code}\u201d.",
    "A unique id for the report generation task. It can be used to query the latest report generation status.": "\u05de\u05e1\u05e4\u05e8 \u05d6\u05d4\u05d5\u05ea \u05d9\u05d9\u05d7\u05d5\u05d3\u05d9 \u05e2\u05d1\u05d5\u05e8 \u05de\u05e9\u05d9\u05de\u05ea \u05d4\u05e4\u05e7\u05ea \u05d4\u05d3\u05d5\u05d7. \u05e0\u05d9\u05ea\u05df \u05dc\u05d4\u05e9\u05ea\u05de\u05e9 \u05d1\u05d5 \u05db\u05d3\u05d9 \u05dc\u05d1\u05e7\u05e9 \u05d0\u05ea \u05e1\u05d8\u05d8\u05d5\u05e1 \u05d4\u05e4\u05e7\u05ea \u05d4\u05d3\u05d5\u05d7 \u05d4\u05d0\u05d7\u05e8\u05d5\u05df.",
    "A unique identifier for the example certificate.  This is used when we receive a response from the queue to determine which example certificate was processed.": "\u05de\u05d6\u05d4\u05d4 \u05d9\u05d9\u05d7\u05d5\u05d3\u05d9 \u05e2\u05d1\u05d5\u05e8 \u05d4\u05ea\u05e2\u05d5\u05d3\u05d4 \u05dc\u05d3\u05d5\u05d2\u05de\u05d4.  \u05de\u05e9\u05de\u05e9 \u05db\u05e9\u05d0\u05e0\u05d5 \u05de\u05e7\u05d1\u05dc\u05d9\u05dd \u05ea\u05e9\u05d5\u05d1\u05d4 \u05de\u05d4\u05ea\u05d5\u05e8 \u05e2\u05dc \u05de\u05e0\u05ea \u05dc\u05e7\u05d1\u05d5\u05e2 \u05d0\u05d9\u05d6\u05d5 \u05ea\u05e2\u05d5\u05d3\u05d4 \u05dc\u05d3\u05d5\u05d2\u05de\u05d4 \u05e2\u05d5\u05d1\u05d3\u05d4.",
    "A usage key location for a section or a problem. If the location is a block that contains other blocks, (such as the course, section, subsection, or unit blocks) then all blocks under that block will be included in the report.": "\u05de\u05d9\u05e7\u05d5\u05dd \u05de\u05e4\u05ea\u05d7 \u05e9\u05d9\u05de\u05d5\u05e9 \u05e2\u05d1\u05d5\u05e8 \u05e7\u05d8\u05e2 \u05d0\u05d5 \u05d1\u05e2\u05d9\u05d4. \u05d0\u05dd \u05d4\u05de\u05d9\u05e7\u05d5\u05dd \u05d4\u05d5\u05d0 \u05d1\u05dc\u05d5\u05e7 \u05e9\u05de\u05db\u05d9\u05dc \u05d1\u05dc\u05d5\u05e7\u05d9\u05dd \u05d0\u05d7\u05e8\u05d9\u05dd, (\u05db\u05d2\u05d5\u05df \u05d4\u05e7\u05d5\u05e8\u05e1, \u05e1\u05e2\u05d9\u05e3, \u05ea\u05ea-\u05e1\u05e2\u05d9\u05e3 \u05d0\u05d5 \u05d1\u05dc\u05d5\u05e7\u05d9\u05dd \u05e9\u05dc \u05d9\u05d7\u05d9\u05d3\u05d4), \u05d0\u05d6 \u05db\u05dc \u05d4\u05d1\u05dc\u05d5\u05e7\u05d9\u05dd \u05ea\u05d7\u05ea \u05d4\u05d1\u05dc\u05d5\u05e7 \u05d4\u05d6\u05d4 \u05d9\u05d9\u05db\u05dc\u05dc\u05d5 \u05d1\u05d3\u05d5\u05d7.",
    "A valid email address is required": "\u05d3\u05e8\u05d5\u05e9\u05d4 \u05db\u05ea\u05d5\u05d1\u05ea \u05d3\u05d5\u05d0\u05e8 \u05d0\u05dc\u05e7\u05d8\u05e8\u05d5\u05e0\u05d9 \u05ea\u05e7\u05d9\u05e0\u05d4",
    "A {cert_type} certificate signifies that a learner has agreed to abide by the honor code established by {platform_name} and has completed all of the required tasks for this course under its guidelines. A {cert_type} certificate also indicates that the identity of the learner has been checked and is valid.": "\u05ea\u05e2\u05d5\u05d3\u05ea {cert_type} \u05de\u05e9\u05de\u05e2\u05d4 \u05e9\u05dc\u05d5\u05de\u05d3 \u05d4\u05e1\u05db\u05d9\u05dd \u05dc\u05e6\u05d9\u05d9\u05ea \u05dc\u05e7\u05d5\u05d3 \u05d4\u05d0\u05ea\u05d9 \u05e9\u05d9\u05d9\u05e1\u05d3\u05d4 {platform_name} \u05d5\u05d4\u05e9\u05dc\u05d9\u05dd \u05d0\u05ea \u05db\u05dc \u05d4\u05de\u05d8\u05dc\u05d5\u05ea \u05d4\u05d3\u05e8\u05d5\u05e9\u05d5\u05ea \u05d1\u05e7\u05d5\u05e8\u05e1 \u05d1\u05d4\u05ea\u05d0\u05dd \u05dc\u05d4\u05e0\u05d7\u05d9\u05d5\u05ea \u05d0\u05dc\u05d4. \u05ea\u05e2\u05d5\u05d3\u05ea {cert_type} \u05de\u05e6\u05d9\u05d9\u05e0\u05ea \u05d2\u05dd \u05e9\u05d6\u05d4\u05d5\u05ea \u05d4\u05dc\u05d5\u05de\u05d3 \u05e0\u05d1\u05d3\u05e7\u05d4 \u05d5\u05d4\u05d9\u05d0 \u05d7\u05d5\u05e7\u05d9\u05ea.",
    "A. General": "\u05d0. \u05db\u05dc\u05dc\u05d9",
    "ABCDEFGHIJKLMNOPQRSTUVWXYZ": "\u05d0\u05d1\u05d2\u05d3\u05d4\u05d5\u05d6\u05d7\u05d8\u05d9\u05db\u05dc\u05de\u05e0\u05e1\u05e2\u05e4\u05e6\u05e7\u05e8\u05e9\u05ea",
    "ACE Common": "ACE \u05e0\u05e4\u05d5\u05e5 (ACE Common)",
    "API Access": "\u05d2\u05d9\u05e9\u05d4 \u05dc-API",
    "API Access Request": "\u05d1\u05e7\u05e9\u05ea \u05d2\u05d9\u05e9\u05d4 \u05dc-API",
    "API Access Request Status": "\u05e1\u05d8\u05d8\u05d5\u05e1 \u05d1\u05e7\u05e9\u05ea \u05d2\u05d9\u05e9\u05d4 \u05dc-API",
    "API Client ID": "\u05de\u05d6\u05d4\u05d4 \u05dc\u05e7\u05d5\u05d7 \u05e9\u05dc \u05de\u05de\u05e9\u05e7 API",
    "API Client Secret": "\u05dc\u05e7\u05d5\u05d7 \u05e9\u05dc \u05de\u05de\u05e9\u05e7 API \u05e0\u05e1\u05ea\u05e8",
    "API Key": "\u05de\u05e4\u05ea\u05d7 API",
    "API Secret": "\u05e1\u05d5\u05d3 API",
