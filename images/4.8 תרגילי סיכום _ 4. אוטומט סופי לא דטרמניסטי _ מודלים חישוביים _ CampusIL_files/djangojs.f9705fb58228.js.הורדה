    "Learn more about importing a course": "\u05dc\u05de\u05d9\u05d3\u05e2 \u05e0\u05d5\u05e1\u05e3 \u05d0\u05d5\u05d3\u05d5\u05ea \u05d9\u05d1\u05d5\u05d0 \u05e7\u05d5\u05e8\u05e1",
    "Learn more about importing a library": "\u05dc\u05de\u05d9\u05d3\u05e2 \u05e0\u05d5\u05e1\u05e3 \u05d0\u05d5\u05d3\u05d5\u05ea \u05d9\u05d1\u05d5\u05d0 \u05e1\u05e4\u05e8\u05d9\u05d4",
    "Learn more about textbooks": "\u05dc\u05de\u05d9\u05d3\u05e2 \u05e0\u05d5\u05e1\u05e3 \u05e2\u05dc \u05d4\u05e1\u05e4\u05e8\u05d9 \u05dc\u05d9\u05de\u05d5\u05d3",
    "Learn more about the course outline": "\u05dc\u05de\u05d9\u05d3\u05e2 \u05e0\u05d5\u05e1\u05e3 \u05d0\u05d5\u05d3\u05d5\u05ea \u05de\u05ea\u05d0\u05e8 \u05d4\u05e7\u05d5\u05e8\u05e1",
    "Learn more about {license_name}": "\u05dc\u05de\u05d3 \u05e2\u05d5\u05d3 \u05d0\u05d5\u05d3\u05d5\u05ea {license_name}",
    "Learn more about {platform_name}": "\u05dc\u05de\u05d3 \u05e2\u05d5\u05d3 \u05d0\u05d5\u05d3\u05d5\u05ea {platform_name} ",
    "Learn with {platform_name}": "\u05dc\u05de\u05d3 \u05e2\u05dd {platform_name}",
    "Learner": "\u05dc\u05d5\u05de\u05d3",
    "Learner Profile": "\u05e4\u05e8\u05d5\u05e4\u05d9\u05dc \u05d4\u05dc\u05d5\u05de\u05d3",
    "Learner email address or username": "\u05db\u05ea\u05d5\u05d1\u05ea \u05d4\u05d3\u05d5\u05d0\u05e8 \u05d4\u05d0\u05dc\u05e7\u05d8\u05e8\u05d5\u05e0\u05d9 \u05d0\u05d5 \u05e9\u05dd \u05d4\u05de\u05e9\u05ea\u05de\u05e9 \u05e9\u05dc \u05d4\u05dc\u05d5\u05de\u05d3",
    "Learner in {content_group}": "\u05dc\u05d5\u05de\u05d3 \u05d1{content_group}",
    "Learner photo is blurry": "\u05ea\u05de\u05d5\u05e0\u05ea \u05d4\u05dc\u05d5\u05de\u05d3 \u05de\u05d8\u05d5\u05e9\u05d8\u05e9\u05ea",
    "Learner photo not provided": "\u05ea\u05de\u05d5\u05e0\u05ea \u05d4\u05dc\u05d5\u05de\u05d3 \u05dc\u05d0 \u05e1\u05d5\u05e4\u05e7\u05d4",
    "Learner's {platform_name} email address or username": "\u05db\u05ea\u05d5\u05d1\u05ea \u05d3\u05d5\u05d0\u05e8 \u05d0\u05dc\u05e7\u05d8\u05e8\u05d5\u05e0\u05d9 \u05d0\u05d5 \u05e9\u05dd \u05de\u05e9\u05ea\u05de\u05e9 {platform_name} \u05e9\u05dc \u05d4\u05dc\u05d5\u05de\u05d3",
    "Learner's {platform_name} email address or username *": "\u05db\u05ea\u05d5\u05d1\u05ea \u05d3\u05d5\u05d0\u05e8 \u05d0\u05dc\u05e7\u05d8\u05e8\u05d5\u05e0\u05d9 \u05d0\u05d5 \u05e9\u05dd \u05de\u05e9\u05ea\u05de\u05e9 {platform_name} \u05e9\u05dc \u05d4\u05dc\u05d5\u05de\u05d3",
    "Learner's {platform_name} email address or username:": "\u05db\u05ea\u05d5\u05d1\u05ea \u05d4\u05d3\u05d5\u05d0\"\u05dc \u05d0\u05d5 \u05e9\u05dd \u05d4\u05de\u05e9\u05ea\u05de\u05e9 \u05e9\u05dc {platform_name} \u05e9\u05dc \u05d4\u05dc\u05d5\u05de\u05d3:",
    "Learner-specific content, such as learner grades and discussion forum data": "\u05ea\u05d5\u05db\u05df \u05e1\u05e4\u05e6\u05d9\u05e4\u05d9 \u05dc\u05dc\u05d5\u05de\u05d3, \u05db\u05d2\u05d5\u05df \u05e6\u05d9\u05d5\u05e0\u05d9 \u05dc\u05d5\u05de\u05d3 \u05d5\u05e0\u05ea\u05d5\u05e0\u05d9 \u05e4\u05d5\u05e8\u05d5\u05dd \u05d3\u05d9\u05d5\u05e0\u05d9\u05dd",
    "Learners are added to this cohort automatically.": "\u05d4\u05dc\u05d5\u05de\u05d3\u05d9\u05dd \u05d9\u05ea\u05d5\u05d5\u05e1\u05e4\u05d5 \u05dc\u05e7\u05d1\u05d5\u05e6\u05ea \u05dc\u05d9\u05de\u05d5\u05d3 \u05d6\u05d5 \u05d1\u05d0\u05d5\u05e4\u05df \u05d0\u05d5\u05d8\u05d5\u05de\u05d8\u05d9.",
    "Learners are added to this cohort only when you provide their email addresses or usernames on this page.": "\u05d4\u05dc\u05d5\u05de\u05d3\u05d9\u05dd \u05d9\u05ea\u05d5\u05d5\u05e1\u05e4\u05d5 \u05dc\u05e7\u05d1\u05d5\u05e6\u05ea \u05dc\u05d9\u05de\u05d5\u05d3 \u05d6\u05d5 \u05e8\u05e7 \u05db\u05d0\u05e9\u05e8 \u05ea\u05e1\u05e4\u05e7 \u05d0\u05ea \u05db\u05ea\u05d5\u05d1\u05d5\u05ea \u05d4\u05d3\u05d5\u05d0\u05e8 \u05d4\u05d0\u05dc\u05e7\u05d8\u05e8\u05d5\u05e0\u05d9 \u05d0\u05d5 \u05e9\u05de\u05d5\u05ea \u05d4\u05de\u05e9\u05ea\u05de\u05e9\u05d9\u05dd \u05d1\u05e2\u05de\u05d5\u05d3 \u05d6\u05d4.",
    "Learners can access their certificate as soon as they achieve a passing grade above the course grade threshold. Note: learners can achieve a passing grade before encountering all assignments in some course configurations.": "\u05d4\u05dc\u05d5\u05de\u05d3\u05d9\u05dd \u05d9\u05db\u05d5\u05dc\u05d9\u05dd \u05dc\u05d2\u05e9\u05ea \u05dc\u05ea\u05e2\u05d5\u05d3\u05d4 \u05e9\u05dc\u05d4\u05dd \u05d1\u05e8\u05d2\u05e2 \u05e9\u05d4\u05dd \u05de\u05e9\u05d9\u05d2\u05d9\u05dd \u05e6\u05d9\u05d5\u05df \u05e2\u05d5\u05d1\u05e8 \u05de\u05e2\u05dc \u05e6\u05d9\u05d5\u05df \u05d4\u05e1\u05e3 \u05e9\u05dc \u05d4\u05e7\u05d5\u05e8\u05e1. \u05d4\u05e2\u05e8\u05d4: \u05d4\u05dc\u05d5\u05de\u05d3\u05d9\u05dd \u05d9\u05db\u05d5\u05dc\u05d9\u05dd \u05dc\u05d4\u05e9\u05d9\u05d2 \u05e6\u05d9\u05d5\u05df \u05e2\u05d5\u05d1\u05e8 \u05dc\u05e4\u05e0\u05d9 \u05e9\u05d4\u05dd \u05e0\u05ea\u05e7\u05dc\u05d9\u05dd \u05d1\u05db\u05dc \u05d4\u05de\u05d8\u05dc\u05d5\u05ea \u05d1\u05ea\u05e6\u05d5\u05e8\u05d5\u05ea \u05de\u05e1\u05d5\u05d9\u05de\u05d5\u05ea \u05e9\u05dc \u05d4\u05e7\u05d5\u05e8\u05e1.",
    "Learners do not see the subsection in the course outline. The subsection is not included in grade calculations.": "\u05d4\u05dc\u05d5\u05de\u05d3\u05d9\u05dd \u05d0\u05d9\u05e0\u05dd \u05e8\u05d5\u05d0\u05d9\u05dd \u05d0\u05ea \u05ea\u05ea-\u05d4\u05e4\u05e8\u05e7 \u05d1\u05de\u05ea\u05d5\u05d5\u05d4 \u05d4\u05e7\u05d5\u05e8\u05e1. \u05ea\u05ea-\u05d4\u05e4\u05e8\u05e7 \u05d0\u05d9\u05e0\u05d5 \u05db\u05dc\u05d5\u05dc \u05d1\u05d7\u05d9\u05e9\u05d5\u05d1\u05d9 \u05d4\u05e6\u05d9\u05d5\u05df.",
    "Learners do not see whether their answers to assessments were correct or incorrect, nor the score received, until after the course end date has passed.": "\u05d4\u05dc\u05d5\u05de\u05d3\u05d9\u05dd \u05d0\u05d9\u05e0\u05dd \u05e8\u05d5\u05d0\u05d9\u05dd \u05d0\u05dd \u05ea\u05e9\u05d5\u05d1\u05d5\u05ea\u05d9\u05d4\u05dd \u05dc\u05de\u05d1\u05d3\u05e7\u05d9\u05dd \u05d4\u05d9\u05d5 \u05e0\u05db\u05d5\u05e0\u05d5\u05ea \u05d0\u05d5 \u05dc\u05d0 \u05e0\u05db\u05d5\u05e0\u05d5\u05ea, \u05d5\u05d2\u05dd \u05dc\u05d0 \u05d0\u05ea \u05d4\u05e6\u05d9\u05d5\u05df \u05e9\u05d4\u05ea\u05e7\u05d1\u05dc, \u05d0\u05dc\u05d0 \u05dc\u05d0\u05d7\u05e8 \u05e1\u05d9\u05d5\u05dd \u05d4\u05e7\u05d5\u05e8\u05e1.",
    "Learners do not see whether their answers to assessments were correct or incorrect, nor the score received, until after the due date for the subsection has passed.": "\u05d4\u05dc\u05d5\u05de\u05d3\u05d9\u05dd \u05d0\u05d9\u05e0\u05dd \u05e8\u05d5\u05d0\u05d9\u05dd \u05d0\u05dd \u05ea\u05e9\u05d5\u05d1\u05d5\u05ea\u05d9\u05d4\u05dd \u05dc\u05de\u05d1\u05d3\u05e7\u05d9\u05dd \u05d4\u05d9\u05d5 \u05e0\u05db\u05d5\u05e0\u05d5\u05ea \u05d0\u05d5 \u05e9\u05d2\u05d5\u05d9\u05d5\u05ea, \u05d5\u05d2\u05dd \u05dc\u05d0 \u05d0\u05ea \u05d4\u05e6\u05d9\u05d5\u05df \u05e9\u05d4\u05ea\u05e7\u05d1\u05dc, \u05d0\u05dc\u05d0 \u05dc\u05d0\u05d7\u05e8 \u05e9\u05de\u05d5\u05e2\u05d3 \u05d4\u05d9\u05e2\u05d3 \u05e9\u05dc \u05d4\u05ea\u05ea-\u05e1\u05e2\u05d9\u05e3 \u05d7\u05dc\u05e3.",
    "Learners engage best with short videos followed by opportunities to practice. Ensure that 80% or more of course videos are less than 10 minutes long.": "\u05dc\u05d5\u05de\u05d3\u05d9\u05dd \u05de\u05d2\u05d9\u05d1\u05d9\u05dd \u05d1\u05e6\u05d5\u05e8\u05d4 \u05d4\u05d8\u05d5\u05d1\u05d4 \u05d1\u05d9\u05d5\u05ea\u05e8 \u05dc\u05e1\u05e8\u05d8\u05d5\u05e0\u05d9\u05dd \u05e7\u05e6\u05e8\u05d9\u05dd \u05e9\u05d0\u05d7\u05e8\u05d9\u05d4\u05dd \u05d9\u05e9 \u05dc\u05d4\u05dd \u05d4\u05d6\u05d3\u05de\u05e0\u05d5\u05ea \u05dc\u05ea\u05e8\u05d2\u05d5\u05dc. \u05d5\u05d3\u05d0\u05d5 \u05e9\u05d0\u05d5\u05e8\u05db\u05dd \u05e9\u05dc 80% \u05d0\u05d5 \u05d9\u05d5\u05ea\u05e8 \u05de\u05df \u05d4\u05e1\u05e8\u05d8\u05d5\u05e0\u05d9\u05dd \u05d1\u05e7\u05d5\u05e8\u05e1 \u05e4\u05d7\u05d5\u05ea \u05de-10 \u05d3\u05e7\u05d5\u05ea.",
    "Learners in the {track_name} Track": "\u05dc\u05d5\u05de\u05d3\u05d9\u05dd \u05d4\u05e0\u05de\u05e6\u05d0\u05d9\u05dd \u05d1\u05de\u05e1\u05dc\u05d5\u05dc {track_name} ",
    "Learners never see whether their answers to assessments are correct or incorrect, nor the score received.": "\u05d4\u05dc\u05d5\u05de\u05d3\u05d9\u05dd \u05d0\u05e3 \u05e4\u05e2\u05dd \u05dc\u05d0 \u05e8\u05d5\u05d0\u05d9\u05dd \u05d0\u05dd \u05d4\u05ea\u05e9\u05d5\u05d1\u05d5\u05ea \u05e9\u05dc\u05d4\u05dd \u05dc\u05d4\u05e2\u05e8\u05db\u05d5\u05ea \u05e0\u05db\u05d5\u05e0\u05d5\u05ea \u05d0\u05d5 \u05dc\u05d0 \u05e0\u05db\u05d5\u05e0\u05d5\u05ea, \u05d5\u05d2\u05dd \u05dc\u05d0 \u05d0\u05ea \u05d4\u05e6\u05d9\u05d5\u05df \u05e9\u05e7\u05d9\u05d1\u05dc\u05d5.",
    "Learners see the published subsection and can access its content.": "\u05d4\u05dc\u05d5\u05de\u05d3\u05d9\u05dd \u05e8\u05d5\u05d0\u05d9\u05dd \u05d0\u05ea \u05ea\u05ea \u05d4\u05e4\u05e8\u05e7 \u05e9\u05e4\u05d5\u05e8\u05e1\u05dd \u05d5\u05d9\u05db\u05d5\u05dc\u05d9\u05dd \u05dc\u05d2\u05e9\u05ea \u05dc\u05ea\u05d5\u05db\u05e0\u05d5.",
    "Learners who require verification must pass the selected checkpoint to see the content in this unit. Learners who do not require verification see this content by default.": "\u05ea\u05dc\u05de\u05d9\u05d3\u05d9\u05dd \u05d4\u05d3\u05d5\u05e8\u05e9\u05d9\u05dd \u05d0\u05d9\u05de\u05d5\u05ea \u05d7\u05d9\u05d9\u05d1\u05d9\u05dd \u05dc\u05e2\u05d1\u05d5\u05e8 \u05d0\u05ea \u05e0\u05e7\u05d5\u05d3\u05ea \u05d4\u05d1\u05d9\u05e7\u05d5\u05e8\u05ea \u05e9\u05e0\u05d1\u05d7\u05e8\u05d4 \u05e2\u05dc \u05de\u05e0\u05ea \u05dc\u05e8\u05d0\u05d5\u05ea \u05d0\u05ea \u05d4\u05ea\u05d5\u05db\u05df \u05d1\u05d9\u05d7\u05d9\u05d3\u05d4 \u05d6\u05d5. \u05ea\u05dc\u05de\u05d9\u05d3\u05d9\u05dd \u05e9\u05d0\u05d9\u05e0\u05dd \u05d3\u05d5\u05e8\u05e9\u05d9\u05dd \u05d0\u05d9\u05de\u05d5\u05ea, \u05e8\u05d5\u05d0\u05d9\u05dd \u05d0\u05ea \u05ea\u05d5\u05db\u05df \u05d6\u05d4 \u05db\u05d1\u05e8\u05d9\u05e8\u05ea \u05de\u05d7\u05d3\u05dc.",
    "Learners with passing grades can access their certificate after the date that you set has elapsed.": "\u05dc\u05d5\u05de\u05d3\u05d9\u05dd \u05e2\u05dd \u05e6\u05d9\u05d5\u05e0\u05d9\u05dd \u05e2\u05d5\u05d1\u05e8\u05d9\u05dd \u05d9\u05db\u05d5\u05dc\u05d9\u05dd \u05dc\u05d2\u05e9\u05ea \u05dc\u05ea\u05e2\u05d5\u05d3\u05d4 \u05e9\u05dc\u05d4\u05dd \u05dc\u05d0\u05d7\u05e8 \u05e9\u05d7\u05dc\u05e3 \u05d4\u05ea\u05d0\u05e8\u05d9\u05da \u05e9\u05d4\u05d2\u05d3\u05e8\u05ea\u05dd.",
    "Learners with passing grades can access their certificate once the end date of the course has elapsed.": "\u05dc\u05d5\u05de\u05d3\u05d9\u05dd \u05e2\u05dd \u05e6\u05d9\u05d5\u05e0\u05d9\u05dd \u05e2\u05d5\u05d1\u05e8\u05d9\u05dd \u05d9\u05db\u05d5\u05dc\u05d9\u05dd \u05dc\u05d2\u05e9\u05ea \u05dc\u05ea\u05e2\u05d5\u05d3\u05d4 \u05e9\u05dc\u05d4\u05dd \u05dc\u05d0\u05d7\u05e8 \u05e9\u05ea\u05d0\u05e8\u05d9\u05da \u05d4\u05e1\u05d9\u05d5\u05dd \u05e9\u05dc \u05d4\u05e7\u05d5\u05e8\u05e1 \u05d7\u05dc\u05e3.",
    "Learning Context Key": "\u05de\u05e4\u05ea\u05d7 \u05d4\u05e7\u05e9\u05e8 \u05dc\u05de\u05d9\u05d3\u05d4",
    "Learning Outcome": "\u05ea\u05d5\u05e6\u05d0\u05ea \u05dc\u05de\u05d9\u05d3\u05d4",
    "Learning Outcomes": "\u05ea\u05d5\u05e6\u05d0\u05d5\u05ea \u05d4\u05dc\u05de\u05d9\u05d3\u05d4",
    "Learning Sequences": "\u05e8\u05e6\u05e3 \u05dc\u05de\u05d9\u05d3\u05d4",
    "Learning Sequences and Outlines": "\u05e8\u05e6\u05e4\u05d9 \u05d5\u05de\u05ea\u05d5\u05d5\u05d9 \u05dc\u05de\u05d9\u05d3\u05d4",
    "Learning is More than Just Lectures": "\u05dc\u05de\u05d9\u05d3\u05d4 \u05d4\u05d9\u05d0 \u05d9\u05d5\u05ea\u05e8 \u05de\u05d4\u05e8\u05e6\u05d0\u05d5\u05ea \u05d1\u05dc\u05d1\u05d3",
    "Learning to Grade": "\u05dc\u05dc\u05de\u05d5\u05d3 \u05db\u05d9\u05e6\u05d3 \u05dc\u05ea\u05ea \u05e6\u05d9\u05d5\u05e0\u05d9\u05dd",
    "Leave Current Session": "\u05e2\u05d6\u05d9\u05d1\u05ea \u05d4\u05e9\u05d9\u05e2\u05d5\u05e8 \u05d4\u05e0\u05d5\u05db\u05d7\u05d9",
    "Leave Team": "\u05e2\u05d6\u05d5\u05d1 \u05e6\u05d5\u05d5\u05ea",
    "Leave the current session and decide later": "\u05e2\u05d6\u05d9\u05d1\u05ea \u05d4\u05e9\u05d9\u05e2\u05d5\u05e8 \u05d4\u05e0\u05d5\u05db\u05d7\u05d9 \u05d5\u05d4\u05d7\u05dc\u05d8\u05d4 \u05d1\u05e9\u05dc\u05d1 \u05de\u05d0\u05d5\u05d7\u05e8 \u05d9\u05d5\u05ea\u05e8",
