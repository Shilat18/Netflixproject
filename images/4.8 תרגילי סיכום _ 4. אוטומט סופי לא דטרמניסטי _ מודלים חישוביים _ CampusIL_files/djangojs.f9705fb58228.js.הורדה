    "Zone Size": "\u05d2\u05d5\u05d3\u05dc \u05d0\u05d6\u05d5\u05e8",
    "Zone borders": "\u05d2\u05d1\u05d5\u05dc\u05d5\u05ea \u05d4\u05d0\u05d6\u05d5\u05e8",
