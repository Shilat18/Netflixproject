    "Request to change %(platform_name)s account e-mail": "\u05d1\u05e7\u05e9 \u05dc\u05e9\u05e0\u05d5\u05ea \u05d0\u05ea \u05db\u05ea\u05d5\u05d1\u05ea \u05d4\u05d3\u05d5\u05d0\u05e8 \u05d4\u05d0\u05e7\u05d8\u05e8\u05d5\u05e0\u05d9 \u05d4\u05de\u05e7\u05d5\u05e9\u05e8\u05ea \u05dc\u05d7\u05e9\u05d1\u05d5\u05df  %(platform_name)s ",
    "Request user's email": "\u05d1\u05e7\u05e9 \u05d0\u05ea \u05db\u05ea\u05d5\u05d1\u05ea \u05d4\u05d3\u05d5\u05d0\u05f4\u05dc \u05e9\u05dc \u05d4\u05de\u05e9\u05ea\u05de\u05e9",
    "Request user's username": "\u05d1\u05e7\u05e9 \u05d0\u05ea \u05e9\u05dd \u05d4\u05de\u05e9\u05ea\u05de\u05e9 \u05e9\u05dc \u05d4\u05de\u05e9\u05ea\u05de\u05e9",
    "Requested task is already running": "\u05d4\u05de\u05e9\u05d9\u05de\u05d4 \u05d4\u05de\u05d1\u05d5\u05e7\u05e9\u05ea \u05db\u05d1\u05e8 \u05e4\u05e2\u05d9\u05dc\u05d4",
    "Requester": "\u05de\u05d1\u05e7\u05e9",
    "Require students to pass an exam before beginning the course.": "\u05d1\u05e7\u05e9 \u05de\u05e1\u05d8\u05d5\u05d3\u05e0\u05d8\u05d9\u05dd \u05dc\u05e2\u05d1\u05d5\u05e8 \u05d1\u05d7\u05d9\u05e0\u05d4 \u05d1\u05d8\u05e8\u05dd \u05d9\u05d7\u05dc\u05d5 \u05d0\u05ea \u05d4\u05e7\u05d5\u05e8\u05e1",
    "Required": "\u05e9\u05d3\u05d4 \u05d7\u05d5\u05d1\u05d4",
    "Required Fields": "\u05e9\u05d3\u05d5\u05ea \u05d7\u05d5\u05d1\u05d4",
    "Required Information": "\u05de\u05d9\u05d3\u05e2 \u05d3\u05e8\u05d5\u05e9",
    "Required Information to Create a New Course": "\u05de\u05d9\u05d3\u05e2 \u05d7\u05d5\u05d1\u05d4 \u05d4\u05d3\u05e8\u05d5\u05e9 \u05e2\u05dc \u05de\u05e0\u05ea \u05dc\u05d9\u05e6\u05d5\u05e8 \u05e7\u05d5\u05e8\u05e1 \u05d7\u05d3\u05e9",
    "Required Information to Create a New Library": "\u05de\u05d9\u05d3\u05e2 \u05d7\u05d5\u05d1\u05d4 \u05d4\u05d3\u05e8\u05d5\u05e9 \u05e2\u05dc \u05de\u05e0\u05ea \u05dc\u05d9\u05e6\u05d5\u05e8 \u05e1\u05e4\u05e8\u05d9\u05d4 \u05d7\u05d3\u05e9\u05d4",
    "Required Information to Create a re-run of a course": "\u05de\u05d9\u05d3\u05e2 \u05d4\u05d3\u05e8\u05d5\u05e9 \u05dc\u05d9\u05e6\u05d9\u05e8\u05ea \u05de\u05d7\u05d6\u05d5\u05e8 \u05dc\u05d9\u05de\u05d5\u05d3\u05d9\u05dd \u05d7\u05d3\u05e9 \u05dc\u05e7\u05d5\u05e8\u05e1",
    "Required data to force publish course.": "\u05e0\u05ea\u05d5\u05e0\u05d9\u05dd \u05e0\u05d7\u05d5\u05e6\u05d9\u05dd \u05dc\u05d0\u05d9\u05dc\u05d5\u05e5 \u05e4\u05e8\u05e1\u05d5\u05dd \u05d4\u05e7\u05d5\u05e8\u05e1.",
    "Required field.": "\u05e9\u05d3\u05d4 \u05d7\u05d5\u05d1\u05d4",
    "Required fields are noted by <strong class=\"indicator\">bold text and an asterisk (*)</strong>.": "\u05e9\u05d3\u05d5\u05ea \u05d7\u05d5\u05d1\u05d4 \u05de\u05e1\u05d5\u05de\u05e0\u05d9\u05dd \u05d1\u05d0\u05de\u05e6\u05e2\u05d5\u05ea<strong class=\"indicator\">\u05d8\u05e7\u05e1\u05d8 \u05de\u05d5\u05d3\u05d2\u05e9 \u05d5\u05db\u05d5\u05db\u05d1\u05d9\u05ea (*)</strong>.",
    "Required fields are noted by {strong_indicator}bold text and an asterisk (*).{strong_close}": "\u05e9\u05d3\u05d5\u05ea \u05e0\u05d3\u05e8\u05e9\u05d9\u05dd \u05de\u05e1\u05d5\u05de\u05e0\u05d9\u05dd \u05d1{strong_indicator}\u05d8\u05e7\u05e1\u05d8 \u05de\u05d5\u05d3\u05d2\u05e9 \u05d5\u05db\u05d5\u05db\u05d1\u05d9\u05ea (*).{strong_close}",
    "Required if 'proctortrack' is selected as your proctoring provider. Enter an email address to be contacted by the support team whenever there are escalations (e.g. appeals, delayed reviews, etc.).": "\u05e0\u05d3\u05e8\u05e9 \u05d0\u05dd Proctortrack \u05e0\u05d1\u05d7\u05e8 \u05d1\u05ea\u05d5\u05e8 \u05e1\u05e4\u05e7 \u05d4\u05d4\u05e9\u05d2\u05d7\u05d4 \u05e9\u05dc\u05db\u05dd. \u05d4\u05db\u05e0\u05d9\u05e1\u05d5 \u05db\u05ea\u05d5\u05d1\u05ea \u05d3\u05d5\u05d0\"\u05dc \u05dc\u05d9\u05e6\u05d9\u05e8\u05ea \u05e7\u05e9\u05e8 \u05de\u05e6\u05d3 \u05e6\u05d5\u05d5\u05ea \u05d4\u05ea\u05de\u05d9\u05db\u05d4 \u05d1\u05e2\u05dc \u05de\u05e7\u05e8\u05d4 \u05d1\u05d5 \u05d9\u05e9\u05e0\u05d4 \u05d4\u05e1\u05dc\u05de\u05d4 (\u05dc\u05de\u05e9\u05dc \u05e2\u05e8\u05e2\u05d5\u05e8, \u05e1\u05e7\u05d9\u05e8\u05d5\u05ea \u05d1\u05e2\u05d9\u05db\u05d5\u05d1 \u05d5\u05db\u05d5').",
    "Requirements": "\u05d3\u05e8\u05d9\u05e9\u05d5\u05ea",
    "Requirements for Course Credit": "\u05d3\u05e8\u05d9\u05e9\u05d5\u05ea \u05dc\u05e0\u05e7\u05d5\u05d3\u05d5\u05ea \u05d6\u05db\u05d5\u05ea \u05d1\u05e7\u05d5\u05e8\u05e1",
    "Requires instructor access.": "\u05d1\u05e7\u05e9 \u05d2\u05d9\u05e9\u05d4 \u05db\u05de\u05d3\u05e8\u05d9\u05da",
    "Rescore": "\u05ea\u05df \u05e6\u05d9\u05d5\u05df \u05de\u05d7\u05d3\u05e9",
    "Rescore All Learners' Submissions": "\u05d7\u05e9\u05d1 \u05de\u05d7\u05d3\u05e9 \u05d0\u05ea \u05e6\u05d9\u05d5\u05df \u05db\u05dc \u05d4\u05dc\u05d5\u05de\u05d3\u05d9\u05dd",
    "Rescore All Problems": "\u05ea\u05df \u05e6\u05d9\u05d5\u05df \u05de\u05d7\u05d3\u05e9 \u05dc\u05db\u05dc \u05d4\u05d1\u05e2\u05d9\u05d5\u05ea",
    "Rescore All Problems Only If Score Improves": "\u05ea\u05df \u05e6\u05d9\u05d5\u05df \u05de\u05d7\u05d3\u05e9 \u05dc\u05db\u05dc \u05d4\u05d1\u05e2\u05d9\u05d5\u05ea \u05e8\u05e7 \u05d0\u05dd \u05d4\u05e6\u05d9\u05d5\u05df \u05de\u05e9\u05ea\u05e4\u05e8",
    "Rescore Learner's Submission": "\u05ea\u05df \u05e6\u05d9\u05d5\u05df \u05de\u05d7\u05d3\u05e9 \u05dc\u05d4\u05d2\u05e9\u05d5\u05ea \u05d4\u05dc\u05d5\u05de\u05d3",
    "Rescore Only If Score Improves": "\u05ea\u05df \u05e6\u05d9\u05d5\u05df \u05de\u05d7\u05d3\u05e9 \u05e8\u05e7 \u05d0\u05dd \u05d4\u05e6\u05d9\u05d5\u05df \u05de\u05e9\u05ea\u05e4\u05e8",
    "Rescore Only If Scores Improve": "\u05d7\u05e9\u05d1 \u05e6\u05d9\u05d5\u05df \u05de\u05d7\u05d3\u05e9 \u05e8\u05e7 \u05d0\u05dd \u05d4\u05e6\u05d9\u05d5\u05df \u05de\u05e9\u05ea\u05e4\u05e8",
    "Rescore any responses that have been submitted. The 'Rescore All Problems Only If Score Improves' option updates the learner's scores only if it improves in the learner's favor.": "\u05ea\u05df \u05e6\u05d9\u05d5\u05df \u05de\u05d7\u05d3\u05e9 \u05dc\u05db\u05dc \u05ea\u05e9\u05d5\u05d1\u05d4 \u05e9\u05d4\u05d5\u05d2\u05e9\u05d4. \u05d4\u05d0\u05e4\u05e9\u05e8\u05d5\u05ea '\u05ea\u05df \u05e6\u05d9\u05d5\u05df \u05de\u05d7\u05d3\u05e9 \u05e8\u05e7 \u05d0\u05dd \u05d4\u05e6\u05d9\u05d5\u05df \u05de\u05e9\u05ea\u05e4\u05e8' \u05de\u05e2\u05d3\u05db\u05e0\u05ea \u05d0\u05ea \u05e6\u05d9\u05d5\u05df \u05d4\u05dc\u05d5\u05de\u05d3 \u05e8\u05e7 \u05d0\u05dd \u05d4\u05d9\u05d0 \u05de\u05e9\u05e4\u05e8\u05ea \u05d0\u05ea \u05e6\u05d9\u05d5\u05e0\u05d5  \u05dc\u05d8\u05d5\u05d1\u05ea\u05d5.",
    "Rescore problem '<%- problem_id %>' for all students?": "\u05dc\u05ea\u05ea \u05e6\u05d9\u05d5\u05df \u05de\u05d7\u05d3\u05e9 \u05e2\u05d1\u05d5\u05e8 \u05d1\u05e2\u05d9\u05d4 '<%- problem_id %>' \u05dc\u05db\u05dc\u05dc \u05d4\u05e1\u05d8\u05d5\u05d3\u05e0\u05d8\u05d9\u05dd? ",
    "Rescore submitted responses. The 'Rescore Only If Scores Improve' option updates a learner's score only if it improves in the learner's favor.": "\u05ea\u05df \u05e6\u05d9\u05d5\u05df \u05de\u05d7\u05d3\u05e9 \u05dc\u05ea\u05e9\u05d5\u05d1\u05d5\u05ea \u05e9\u05e0\u05e9\u05dc\u05d7\u05d5. \u05d4\u05d0\u05e4\u05e9\u05e8\u05d5\u05ea '\u05ea\u05df \u05e6\u05d9\u05d5\u05df \u05de\u05d7\u05d3\u05e9 \u05e8\u05e7 \u05d0\u05dd \u05d4\u05e6\u05d9\u05d5\u05df \u05de\u05e9\u05ea\u05e4\u05e8' \u05de\u05e2\u05d3\u05db\u05e0\u05ea \u05d0\u05ea \u05e6\u05d9\u05d5\u05df \u05d4\u05dc\u05d5\u05de\u05d3 \u05e8\u05e7 \u05d0\u05dd \u05d4\u05d9\u05d0 \u05de\u05e9\u05e4\u05e8\u05ea \u05d0\u05ea \u05d4\u05e6\u05d9\u05d5\u05df \u05dc\u05d8\u05d5\u05d1\u05ea\u05d5.",
    "Research shows that a diverse content experience drives learner engagement. We recommend that 80% or more of your learning sequences or subsections include multiple content types (such as video, discussion, or problem).": "\u05de\u05d7\u05e7\u05e8\u05d9\u05dd \u05de\u05e8\u05d0\u05d9\u05dd \u05e9\u05d7\u05d5\u05d5\u05d9\u05d9\u05ea \u05ea\u05d5\u05db\u05df \u05de\u05d2\u05d5\u05d5\u05e0\u05ea \u05de\u05e0\u05d9\u05e2\u05d4 \u05d0\u05ea \u05de\u05e2\u05d5\u05e8\u05d1\u05d5\u05ea \u05d4\u05dc\u05d5\u05de\u05d3\u05d9\u05dd. \u05d0\u05e0\u05d7\u05e0\u05d5 \u05de\u05de\u05dc\u05d9\u05e6\u05d9\u05dd \u05e9-80% \u05d0\u05d5 \u05d9\u05d5\u05ea\u05e8 \u05de\u05e8\u05e6\u05e4\u05d9 \u05d4\u05dc\u05d9\u05de\u05d5\u05d3 \u05e9\u05dc\u05db\u05dd \u05d0\u05d5 \u05de\u05d9\u05d7\u05d9\u05d3\u05d5\u05ea \u05d4\u05de\u05e9\u05e0\u05d4 \u05e9\u05dc\u05d4\u05dd \u05d9\u05db\u05dc\u05dc\u05d5 \u05db\u05de\u05d4 \u05e1\u05d5\u05d2\u05d9 \u05ea\u05d5\u05db\u05df (\u05db\u05d2\u05d5\u05df \u05e1\u05e8\u05d8\u05d5\u05df \u05d5\u05d9\u05d3\u05d0\u05d5, \u05d3\u05d9\u05d5\u05df \u05d0\u05d5 \u05d1\u05e2\u05d9\u05d4).",
    "Reset": "\u05d0\u05ea\u05d7\u05dc",
    "Reset Attempts to Zero": "\u05d0\u05e4\u05e1 \u05e0\u05d9\u05e1\u05d9\u05d5\u05e0\u05d5\u05ea",
    "Reset Learner's Attempts to Zero": "\u05d0\u05e4\u05e1 \u05d0\u05ea \u05e0\u05d9\u05e1\u05d9\u05d5\u05e0\u05d5\u05ea \u05d4\u05dc\u05d5\u05de\u05d3",
    "Reset My Password": "\u05d0\u05e4\u05e1 \u05e1\u05d9\u05e1\u05de\u05d4",
    "Reset Password": "\u05d0\u05d9\u05e4\u05d5\u05e1 \u05e1\u05d9\u05e1\u05de\u05d4",
    "Reset Your Password": "\u05d4\u05d6\u05d9\u05e0\u05d5 \u05e1\u05d9\u05e1\u05de\u05d4 \u05d7\u05d3\u05e9\u05d4",
    "Reset Your {platform_name} Password": "\u05d0\u05e4\u05e1 \u05d0\u05ea \u05e1\u05d9\u05e1\u05de\u05ea\u05da \u05d1-{platform_name}",
    "Reset attempts for all students on problem '<%- problem_id %>'?": "\u05d0\u05e4\u05e1 \u05e0\u05d9\u05e1\u05d9\u05d5\u05e0\u05d5\u05ea \u05e2\u05d1\u05d5\u05e8 \u05db\u05dc \u05d4\u05e1\u05d8\u05d5\u05d3\u05e0\u05d8\u05d9\u05dd \u05d1\u05d1\u05e2\u05d9\u05d4  '<%- problem_id %>'? ",
    "Reset due date for student": "\u05e7\u05d1\u05e2 \u05de\u05d7\u05d3\u05e9 \u05ea\u05d0\u05e8\u05d9\u05da \u05d9\u05e2\u05d3 \u05e2\u05d1\u05d5\u05e8 \u05e1\u05d8\u05d5\u05d3\u05e0\u05d8",
    "Reset values": "\u05d0\u05e4\u05e1 \u05e2\u05e8\u05db\u05d9\u05dd",
    "Reset your answer": "\u05d0\u05e4\u05e1 \u05d0\u05ea \u05ea\u05e9\u05d5\u05d1\u05ea\u05da",
    "Resetting a problem's due date rescinds a due date extension for a student on a particular subsection. This will revert the due date for the student back to the problem's original due date.": "\u05d0\u05d9\u05e4\u05d5\u05e1 \u05ea\u05d0\u05e8\u05d9\u05da \u05d4\u05d9\u05e2\u05d3 \u05e9\u05dc \u05d1\u05e2\u05d9\u05d4, \u05d9\u05d1\u05d8\u05dc \u05d2\u05dd \u05d4\u05d0\u05e8\u05db\u05ea \u05d6\u05de\u05df \u05e9\u05e0\u05d9\u05ea\u05e0\u05d4 \u05dc\u05dc\u05d5\u05de\u05d3\u05d9\u05dd \u05d1\u05ea\u05ea \u05e4\u05e8\u05e7 \u05e1\u05e4\u05d9\u05e6\u05e4\u05d9. \u05e4\u05e2\u05d5\u05dc\u05d4 \u05d6\u05d5 \u05ea\u05d7\u05d6\u05d9\u05e8 \u05d0\u05ea \u05ea\u05d0\u05e8\u05d9\u05da \u05d4\u05d9\u05e2\u05d3 \u05e9\u05dc \u05d4\u05dc\u05d5\u05de\u05d3 \u05dc\u05ea\u05d0\u05e8\u05d9\u05da \u05d4\u05d9\u05e2\u05d3 \u05d4\u05de\u05e7\u05d5\u05e8\u05d9 \u05e9\u05dc \u05d4\u05d1\u05e2\u05d9\u05d4.",
    "Resetting extensions": "\u05e7\u05d1\u05e2 \u05de\u05d7\u05d3\u05e9 \u05d4\u05d0\u05e8\u05db\u05d5\u05ea",
    "Response to %(thread_title)s": "\u05ea\u05d2\u05d5\u05d1\u05d4 \u05dc-%(thread_title)s",
    "Responses could not be loaded. Refresh the page and try again.": "\u05dc\u05d0 \u05e0\u05d9\u05ea\u05df \u05dc\u05d4\u05e2\u05dc\u05d5\u05ea \u05ea\u05d2\u05d5\u05d1\u05d5\u05ea. \u05e8\u05e2\u05e0\u05df \u05d0\u05ea \u05d4\u05e2\u05de\u05d5\u05d3 \u05d5\u05e0\u05e1\u05d4 \u05e9\u05e0\u05d9\u05ea.",
    "Restore": "\u05e9\u05d7\u05d6\u05e8",
    "Restore enrollment code": "\u05e9\u05d7\u05d6\u05e8 \u05e7\u05d5\u05d3 \u05d4\u05e8\u05e9\u05de\u05d4",
    "Restore image": "\u05e9\u05d7\u05d6\u05d5\u05e8 \u05ea\u05de\u05d5\u05e0\u05d4",
    "Restore last draft": "\u05e9\u05d7\u05d6\u05e8 \u05d8\u05d9\u05d5\u05d8\u05d4 \u05d0\u05d7\u05e8\u05d5\u05e0\u05d4",
    "Restoring article": "\u05de\u05e9\u05d7\u05d6\u05e8 \u05de\u05d0\u05de\u05e8",
    "Restoring to this revision will mark the article as deleted.": "\u05e9\u05d7\u05d6\u05d5\u05e8 \u05dc\u05e2\u05d3\u05db\u05d5\u05df \u05d6\u05d4 \u05d9\u05de\u05d7\u05e7 \u05d0\u05ea \u05d4\u05de\u05d0\u05de\u05e8.",
    "Restrict access to:": "\u05d4\u05d2\u05d1\u05dc\u05ea \u05d4\u05d2\u05d9\u05e9\u05d4 \u05dc\u05d8\u05d5\u05d1\u05ea:",
