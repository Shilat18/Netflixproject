    "You are currently sharing a limited profile.": "\u05d0\u05ea\u05d4 \u05de\u05e9\u05ea\u05e3 \u05db\u05e8\u05d2\u05e2 \u05e4\u05e8\u05d5\u05e4\u05d9\u05dc \u05d7\u05dc\u05e7\u05d9.",
    "You are deleting an article. Please confirm.": "\u05d0\u05ea\u05d4 \u05e2\u05d5\u05de\u05d3 \u05dc\u05de\u05d7\u05d5\u05e7 \u05d0\u05ea \u05d4\u05de\u05d0\u05de\u05e8. \u05e0\u05d0 \u05d0\u05e9\u05e8.",
    "You are deleting an article. This means that its children will be deleted as well. If you choose to purge, children will also be purged!": "\u05d4\u05e0\u05da \u05e2\u05d5\u05de\u05d3 \u05dc\u05de\u05d7\u05d5\u05e7 \u05d0\u05ea \u05d4\u05de\u05d0\u05de\u05e8. \u05de\u05e9\u05de\u05e2\u05d5\u05ea \u05d3\u05d1\u05e8 \u05d4\u05d9\u05d0 \u05db\u05d9 \u05db\u05dc \u05de\u05d0\u05de\u05e8\u05d9 \u05d4\u05de\u05e9\u05e0\u05d4 \u05d9\u05d9\u05de\u05d7\u05e7\u05d5 \u05d2\u05dd \u05db\u05df. \u05d0\u05dd \u05ea\u05d1\u05d7\u05e8 \u05dc\u05de\u05d7\u05d5\u05e7, \u05de\u05d0\u05de\u05e8\u05d9 \u05d4\u05de\u05e9\u05e0\u05d4 \u05e9\u05dc \u05d4\u05de\u05d0\u05de\u05e8 \u05d9\u05d9\u05de\u05d7\u05e7\u05d5 \u05d2\u05dd \u05d4\u05dd!",
    "You are eligible for credit from {providers_string}": "\u05d0\u05ea\u05d4 \u05db\u05e9\u05d9\u05e8 \u05dc\u05e7\u05d1\u05dc\u05ea \u05e0\u05e7\u05d5\u05d3\u05d5\u05ea \u05d6\u05db\u05d5\u05ea \u05de-{providers_string}",
