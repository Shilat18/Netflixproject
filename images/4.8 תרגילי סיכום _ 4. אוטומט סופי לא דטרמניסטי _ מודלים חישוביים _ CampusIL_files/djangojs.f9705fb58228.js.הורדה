    "Edit Coupon Code": "\u05e2\u05e8\u05d5\u05da \u05e7\u05d5\u05d3 \u05e9\u05d5\u05d1\u05e8",
    "Edit Coupon Code Information": "\u05e2\u05e8\u05d5\u05da \u05d0\u05ea \u05e4\u05e8\u05d8\u05d9 \u05e7\u05d5\u05d3 \u05d4\u05e9\u05d5\u05d1\u05e8",
    "Edit HTML": "\u05e2\u05e8\u05d5\u05da HTML",
    "Edit Library List.": "\u05e2\u05e8\u05d5\u05da \u05e8\u05e9\u05d9\u05de\u05ea \u05e1\u05e4\u05e8\u05d9\u05d4",
