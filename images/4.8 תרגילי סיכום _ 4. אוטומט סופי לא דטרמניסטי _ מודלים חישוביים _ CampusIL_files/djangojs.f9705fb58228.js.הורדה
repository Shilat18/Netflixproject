    "All payment options are currently unavailable.": "\u05db\u05dc \u05d0\u05e4\u05e9\u05e8\u05d5\u05d9\u05d5\u05ea \u05d4\u05ea\u05e9\u05dc\u05d5\u05dd \u05d0\u05d9\u05e0\u05df \u05d6\u05de\u05d9\u05e0\u05d5\u05ea \u05db\u05e8\u05d2\u05e2.",
    "All possible words from all learners.": "\u05db\u05dc \u05d4\u05de\u05d9\u05dc\u05d9\u05dd \u05d4\u05d0\u05e4\u05e9\u05e8\u05d9\u05d5\u05ea \u05de\u05db\u05dc \u05d4\u05dc\u05d5\u05de\u05d3\u05d9\u05dd.",
    "All professional education courses are fee-based, and require payment to complete the enrollment process.": "\u05db\u05dc \u05d4\u05e7\u05d5\u05e8\u05e1\u05d9\u05dd \u05d1\u05d7\u05d9\u05e0\u05d5\u05da \u05d4\u05de\u05e7\u05e6\u05d5\u05e2\u05d9 \u05de\u05d1\u05d5\u05e1\u05e1\u05d9\u05dd \u05e2\u05dc \u05ea\u05e9\u05dc\u05d5\u05dd, \u05d5\u05dc\u05db\u05df \u05e0\u05d3\u05e8\u05e9 \u05ea\u05e9\u05dc\u05d5\u05dd \u05e2\u05dc \u05de\u05e0\u05ea \u05dc\u05d4\u05e9\u05dc\u05d9\u05dd \u05d0\u05ea \u05ea\u05d4\u05dc\u05d9\u05da \u05d4\u05d4\u05e8\u05e9\u05de\u05d4.",
    "All rights reserved": "\u05db\u05dc \u05d4\u05d6\u05db\u05d5\u05d9\u05d5\u05ea \u05e9\u05de\u05d5\u05e8\u05d5\u05ea",
    "All rights reserved except where noted. edX, Open edX and the edX and Open edX logos are registered trademarks of edX Inc.": "\u05db\u05dc \u05d4\u05d6\u05db\u05d5\u05d9\u05d5\u05ea \u05e9\u05de\u05d5\u05e8\u05d5\u05ea, \u05dc\u05de\u05e2\u05d8 \u05d4\u05d9\u05db\u05df \u05e9\u05e6\u05d5\u05d9\u05df. edX, Open edX \u05d5\u05d4\u05e1\u05de\u05dc\u05d9\u05dd \u05e9\u05dc edX \u05d5-Open edX \u05d4\u05dd \u05e1\u05d9\u05de\u05e0\u05d9\u05dd \u05de\u05e1\u05d7\u05e8\u05d9\u05d9\u05dd \u05e8\u05e9\u05d5\u05de\u05d9\u05dd \u05e9\u05dc edX Inc.",
    "All subsections": "\u05db\u05dc \u05ea\u05ea\u05d9 \u05d4\u05e7\u05d8\u05e2\u05d9\u05dd",
    "All teams": "\u05db\u05dc \u05d4\u05e6\u05d5\u05d5\u05ea\u05d9\u05dd",
    "All units": "\u05db\u05dc \u05d4\u05d9\u05d7\u05d9\u05d3\u05d5\u05ea",
    "All units have been added.": "\u05db\u05dc \u05d4\u05d9\u05d7\u05d9\u05d3\u05d5\u05ea \u05e0\u05d5\u05e1\u05e4\u05d5.",
    "All users on the Exception list": "\u05db\u05dc \u05d4\u05de\u05e9\u05ea\u05de\u05e9\u05d9\u05dd \u05d1\u05e8\u05e9\u05d9\u05de\u05ea \u05d4\u05d7\u05e8\u05d9\u05d2\u05d9\u05dd",
    "All users on the Exception list who do not yet have a certificate": "\u05db\u05dc \u05d4\u05de\u05e9\u05ea\u05de\u05e9\u05d9\u05dd \u05d1\u05e8\u05e9\u05d9\u05de\u05ea \u05d4\u05d7\u05e8\u05d9\u05d2\u05d9\u05dd \u05e9\u05dc\u05d0 \u05e7\u05d9\u05d1\u05dc\u05d5 \u05e2\u05d3\u05d9\u05d9\u05df \u05ea\u05e2\u05d5\u05d3\u05d4",
    "Allow": "\u05d0\u05e4\u05e9\u05e8",
    "Allow Anonymous Discussion Posts": "\u05d0\u05e4\u05e9\u05e8 \u05e4\u05d5\u05e1\u05d8\u05d9\u05dd \u05d0\u05e0\u05d5\u05e0\u05d9\u05de\u05d9\u05d9\u05dd \u05d1\u05d3\u05d9\u05d5\u05df",
    "Allow Anonymous Discussion Posts to Peers": "\u05d0\u05e4\u05e9\u05e8 \u05e4\u05d5\u05e1\u05d8\u05d9\u05dd \u05d0\u05e0\u05d5\u05e0\u05d9\u05de\u05d9\u05dd \u05d1\u05d3\u05d9\u05d5\u05df \u05dc\u05e2\u05de\u05d9\u05ea\u05d9\u05dd",
    "Allow Feature Based Enrollment visibility to be overriden on a per-component basis in Studio.": "\u05d0\u05e4\u05e9\u05e8\u05d5\u05ea \u05dc\u05e0\u05e8\u05d0\u05d5\u05ea \u05e9\u05dc \u05e8\u05d9\u05e9\u05d5\u05dd \u05de\u05d1\u05d5\u05e1\u05e1 \u05de\u05d0\u05e4\u05d9\u05d9\u05df \u05dc\u05d3\u05e8\u05d9\u05e1\u05d4 \u05e2\u05dc \u05d1\u05e1\u05d9\u05e1 \u05e8\u05db\u05d9\u05d1 \u05d1\u05e1\u05d8\u05d5\u05d3\u05d9\u05d5.",
    "Allow List": "\u05e8\u05e9\u05d9\u05de\u05ea \u05d4\u05d9\u05ea\u05e8\u05d9\u05dd",
    "Allow Opting Out of Proctored Exams": "\u05d0\u05e4\u05e9\u05e8 \u05d4\u05e1\u05db\u05de\u05d4 \u05dc\u05de\u05d1\u05d7\u05e0\u05d9 \u05d7\u05d5\u05e5",
    "Allow Public Wiki Access": "\u05d0\u05e4\u05e9\u05e8 \u05d2\u05d9\u05e9\u05d4 \u05e6\u05d9\u05d1\u05d5\u05e8\u05d9\u05ea \u05dc-Wiki.",
    "Allow Skip": "\u05d0\u05e4\u05e9\u05e8 \u05d3\u05d9\u05dc\u05d5\u05d2",
    "Allow a learner who has used up all attempts to work on the problem again.": "\u05d0\u05e4\u05e9\u05e8 \u05dc\u05dc\u05d5\u05de\u05d3 \u05e9\u05d4\u05e9\u05ea\u05de\u05e9 \u05d1\u05db\u05dc \u05d4\u05e0\u05d9\u05e1\u05d9\u05d5\u05e0\u05d5\u05ea \u05e9\u05dc\u05d5 \u05dc\u05e2\u05d1\u05d5\u05d3 \u05e9\u05d5\u05d1 \u05e2\u05dc \u05d1\u05e2\u05d9\u05d4.",
    "Allow course instructors to assign CCX Coach roles, and allow coaches to manage Custom Courses on edX. When false, Custom Courses cannot be created, but existing Custom Courses will be preserved.": "\u05d0\u05e4\u05e9\u05e8 \u05dc\u05de\u05e0\u05d7\u05d9 \u05d4\u05e7\u05d5\u05e8\u05e1 \u05dc\u05d4\u05e7\u05e6\u05d5\u05ea \u05ea\u05e4\u05e7\u05d9\u05d3\u05d9 \u05de\u05e0\u05d7\u05d4 \u05db\u05d9\u05ea\u05d4 \u05d5\u05dc\u05de\u05e0\u05d7\u05d9\u05dd \u05dc\u05e9\u05e0\u05d5\u05ea \u05d0\u05ea \u05d4\u05e7\u05d5\u05e8\u05e1\u05d9\u05dd \u05d4\u05de\u05d5\u05ea\u05d0\u05de\u05d9\u05dd \u05d0\u05d9\u05e9\u05d9\u05ea \u05d1-edX. \u05d1\u05de\u05d9\u05d3\u05d4 \u05d5\u05dc\u05d0, \u05dc\u05d0 \u05e0\u05d9\u05ea\u05df \u05dc\u05d9\u05e6\u05d5\u05e8 \u05d0\u05ea \u05d4\u05e7\u05d5\u05e8\u05e1\u05d9\u05dd \u05d4\u05de\u05d5\u05ea\u05d0\u05de\u05d9\u05dd \u05d0\u05d9\u05e9\u05d9\u05ea, \u05d0\u05da \u05d9\u05d9\u05e9\u05de\u05e8\u05d5 \u05e7\u05d5\u05e8\u05e1\u05d9\u05dd \u05de\u05d5\u05ea\u05d0\u05de\u05d9\u05dd \u05d0\u05d9\u05e9\u05d9\u05ea \u05e7\u05d9\u05d9\u05de\u05d9\u05dd.",
    "Allow learners to highlight passages and make notes right in the course.": "\u05d0\u05e4\u05e9\u05e8\u05d5 \u05dc\u05dc\u05d5\u05de\u05d3\u05d9\u05dd \u05dc\u05e1\u05de\u05df \u05e7\u05d8\u05e2\u05d9\u05dd \u05d5\u05dc\u05e8\u05e9\u05d5\u05dd \u05d4\u05e2\u05e8\u05d5\u05ea \u05d0\u05d9\u05e9\u05d9\u05d5\u05ea \u05d9\u05e9\u05d9\u05e8\u05d5\u05ea \u05d1\u05ea\u05d5\u05da \u05d4\u05e7\u05d5\u05e8\u05e1.",
    "Allow others to copy, distribute, display and perform only verbatim copies of your work, not derivative works based upon it. This option is incompatible with \"Share Alike\".": "\u05de\u05d5\u05ea\u05e8 \u05dc\u05d0\u05d7\u05e8\u05d9\u05dd \u05dc\u05d4\u05e2\u05ea\u05d9\u05e7, \u05dc\u05d4\u05e4\u05d9\u05e5, \u05dc\u05d4\u05e6\u05d9\u05d2 \u05d5\u05dc\u05d1\u05e6\u05e2 \u05d0\u05da \u05d5\u05e8\u05e7 \u05e2\u05d5\u05ea\u05e7\u05d9\u05dd \u05de\u05d3\u05d5\u05d9\u05e7\u05d9\u05dd \u05e9\u05dc \u05e2\u05d1\u05d5\u05d3\u05ea\u05da \u05d5\u05dc\u05d0 \u05e2\u05d1\u05d5\u05d3\u05d5\u05ea \u05d4\u05e0\u05d2\u05d6\u05e8\u05d5\u05ea \u05de\u05de\u05e0\u05d4. \u05d0\u05e4\u05e9\u05e8\u05d5\u05ea \u05d6\u05d5 \u05d0\u05d9\u05e0\u05d4 \u05de\u05ea\u05d0\u05d9\u05de\u05d4 \u05dc\u05d4\u05d2\u05d5\u05d5\u05df \u201e\u05e9\u05d9\u05ea\u05d5\u05e3 \u05d6\u05d4\u05d4\u201d.",
    "Allow others to copy, distribute, display and perform your copyrighted work but only if they give credit the way you request. Currently, this option is required.": "\u05de\u05d5\u05ea\u05e8 \u05dc\u05d0\u05d7\u05e8\u05d9\u05dd \u05dc\u05d4\u05e2\u05ea\u05d9\u05e7, \u05dc\u05d4\u05e4\u05d9\u05e5, \u05dc\u05d4\u05e6\u05d9\u05d2 \u05d5\u05dc\u05d1\u05e6\u05e2 \u05d0\u05ea \u05d4\u05e2\u05d1\u05d5\u05d3\u05d4 \u05d4\u05de\u05d5\u05d2\u05e0\u05ea \u05d1\u05d6\u05db\u05d5\u05d9\u05d5\u05ea \u05d4\u05d9\u05d5\u05e6\u05e8\u05d9\u05dd \u05e9\u05dc\u05da, \u05d0\u05da \u05e8\u05e7 \u05d0\u05dd \u05d4\u05dd \u05de\u05db\u05d9\u05e8\u05d9\u05dd \u05d1\u05d6\u05db\u05d5\u05d9\u05d5\u05ea\u05d9\u05da \u05e2\u05dc \u05e4\u05d9 \u05d1\u05e7\u05e9\u05ea\u05da. \u05e0\u05db\u05d5\u05df \u05dc\u05e2\u05db\u05e9\u05d9\u05d5, \u05d0\u05e4\u05e9\u05e8\u05d5\u05ea \u05d6\u05d5 \u05d4\u05d9\u05d0 \u05d7\u05d5\u05d1\u05d4.",
    "Allow others to copy, distribute, display and perform your work - and derivative works based upon it - but for noncommercial purposes only.": "\u05de\u05d5\u05ea\u05e8 \u05dc\u05d0\u05d7\u05e8\u05d9\u05dd \u05dc\u05d4\u05e2\u05ea\u05d9\u05e7, \u05dc\u05d4\u05e4\u05d9\u05e5, \u05dc\u05d4\u05e6\u05d9\u05d2 \u05d5\u05dc\u05d1\u05e6\u05e2 \u05d0\u05ea \u05d9\u05e6\u05d9\u05e8\u05ea\u05da - \u05d5\u05d9\u05e6\u05d9\u05e8\u05d5\u05ea \u05d4\u05e0\u05d2\u05d6\u05e8\u05d5\u05ea \u05de\u05de\u05e0\u05d4 - \u05e9\u05dc\u05d0 \u05dc\u05de\u05d8\u05e8\u05d5\u05ea \u05de\u05e1\u05d7\u05e8.",
    "Allow others to distribute derivative works only under a license identical to the license that governs your work. This option is incompatible with \"No Derivatives\".": "\u05de\u05d5\u05ea\u05e8 \u05dc\u05d0\u05d7\u05e8\u05d9\u05dd \u05dc\u05d4\u05e4\u05d9\u05e5 \u05e2\u05d1\u05d5\u05d3\u05d5\u05ea \u05e0\u05d2\u05d6\u05e8\u05d5\u05ea \u05d0\u05da \u05d5\u05e8\u05e7 \u05d1\u05e8\u05d9\u05e9\u05d9\u05d5\u05df \u05d3\u05d5\u05de\u05d4 \u05dc\u05e8\u05d9\u05e9\u05d9\u05d5\u05df \u05e9\u05e7\u05d9\u05d9\u05dd \u05dc\u05d9\u05e6\u05d9\u05e8\u05ea. \u05d0\u05e4\u05e9\u05e8\u05d5\u05ea \u05d6\u05d5 \u05d0\u05d9\u05e0\u05d4 \u05ea\u05d5\u05d0\u05de\u05ea \u05dc\u05be\u201e\u05dc\u05dc\u05d0 \u05e0\u05d2\u05d6\u05e8\u05d5\u05ea\u201d.",
    "Allow students to download the timed transcript. A link to download the file appears below the video. By default, the transcript is an .srt or .txt file. If you want to provide the transcript for download in a different format, upload a file by using the Upload Handout field.": "\u05d0\u05e4\u05e9\u05e8 \u05dc\u05e1\u05d8\u05d5\u05d3\u05e0\u05d8\u05d9\u05dd \u05dc\u05d4\u05d5\u05e8\u05d9\u05d3 \u05d0\u05ea \u05d4\u05ea\u05de\u05dc\u05d9\u05dc \u05d4\u05de\u05ea\u05d5\u05d6\u05de\u05df. \u05e7\u05d9\u05e9\u05d5\u05e8 \u05dc\u05d4\u05d5\u05e8\u05d3\u05ea \u05d4\u05e7\u05d5\u05d1\u05e5 \u05d9\u05d5\u05e4\u05d9\u05e2 \u05de\u05ea\u05d7\u05ea \u05dc\u05e1\u05e8\u05d8\u05d5\u05df \u05d4\u05d5\u05d5\u05d9\u05d3\u05d0\u05d5. \u05db\u05d1\u05e8\u05d9\u05e8\u05ea \u05de\u05d7\u05d3\u05dc, \u05d4\u05ea\u05de\u05dc\u05d9\u05dc \u05d4\u05d5\u05d0 \u05e7\u05d5\u05d1\u05e5 srt. \u05d0\u05d5 txt. \u05d0\u05dd \u05d1\u05e8\u05e6\u05d5\u05e0\u05da \u05dc\u05e1\u05e4\u05e7 \u05d0\u05ea \u05d4\u05ea\u05de\u05dc\u05d9\u05dc \u05dc\u05d4\u05d5\u05e8\u05d3\u05d4 \u05d1\u05e4\u05d5\u05e8\u05de\u05d8 \u05e9\u05d5\u05e0\u05d4, \u05d4\u05e2\u05dc\u05d4 \u05e7\u05d5\u05d1\u05e5 \u05d1\u05d0\u05de\u05e6\u05e2\u05d5\u05ea \u05e9\u05d9\u05de\u05d5\u05e9 \u05d1\u05e9\u05d3\u05d4 '\u05d4\u05e2\u05dc\u05d4 \u05d3\u05e3 \u05de\u05d9\u05d3\u05e2'.",
    "Allow students to download versions of this video in different formats if they cannot use the edX video player or do not have access to YouTube. You must add at least one non-YouTube URL in the Video File URLs field.": "\u05d0\u05e4\u05e9\u05e8 \u05dc\u05e1\u05d8\u05d5\u05d3\u05e0\u05d8\u05d9\u05dd \u05dc\u05d4\u05d5\u05e8\u05d9\u05d3 \u05d2\u05e8\u05e1\u05d0\u05d5\u05ea \u05e9\u05dc \u05e1\u05e8\u05d8\u05d5\u05df \u05d5\u05d9\u05d3\u05d0\u05d5 \u05d6\u05d4 \u05d1\u05e4\u05d5\u05e8\u05de\u05d8\u05d9\u05dd \u05e9\u05d5\u05e0\u05d9\u05dd \u05d1\u05de\u05d9\u05d3\u05d4 \u05d5\u05d0\u05d9\u05e0\u05dd \u05d9\u05db\u05d5\u05dc\u05d9\u05dd \u05dc\u05d4\u05e9\u05ea\u05de\u05e9 \u05d1\u05e0\u05d2\u05df \u05d5\u05d9\u05d3\u05d0\u05d5 \u05e9\u05dc edX \u05d0\u05d5 \u05e9\u05d0\u05d9\u05df \u05dc\u05d4\u05dd \u05d2\u05d9\u05e9\u05d4 \u05dc\u05d9\u05d5\u05d8\u05d9\u05d5\u05d1. \u05e2\u05dc\u05d9\u05d9\u05da \u05dc\u05d4\u05d5\u05e1\u05d9\u05e3 \u05dc\u05e4\u05d7\u05d5\u05ea \u05db\u05ea\u05d5\u05d1\u05ea URL \u05d0\u05d7\u05ea \u05e9\u05d0\u05d9\u05e0\u05e0\u05d4 \u05db\u05ea\u05d5\u05d1\u05ea \u05e9\u05dc \u05d9\u05d5\u05d8\u05d9\u05d5\u05d1 \u05d1\u05e9\u05d3\u05d4 \"\u05db\u05ea\u05d5\u05d1\u05d5\u05ea URL \u05dc\u05e7\u05d1\u05e6\u05d9 \u05d5\u05d9\u05d3\u05d0\u05d5\".",
    "Allow students to generate certificates for this course?": "\u05dc\u05d0\u05e4\u05e9\u05e8 \u05dc\u05e1\u05d8\u05d5\u05d3\u05e0\u05d8\u05d9\u05dd \u05dc\u05d9\u05e6\u05d5\u05e8 \u05ea\u05e2\u05d5\u05d3\u05d5\u05ea \u05e2\u05d1\u05d5\u05e8 \u05e7\u05d5\u05e8\u05e1 \u05d6\u05d4?",
    "Allow the learner to take the exam again.": "\u05d0\u05e4\u05e9\u05e8 \u05dc\u05dc\u05d5\u05de\u05d3 \u05dc\u05d1\u05e6\u05e2 \u05e9\u05d5\u05d1 \u05d0\u05ea \u05d4\u05de\u05d1\u05d7\u05df",
    "Allow users who enrolled in an allowed country to access restricted courses from excluded countries.": "\u05d0\u05e4\u05e9\u05e8 \u05dc\u05de\u05e9\u05ea\u05de\u05e9\u05d9\u05dd \u05e9\u05e0\u05e8\u05e9\u05de\u05d5 \u05d1\u05de\u05d3\u05d9\u05e0\u05d4 \u05de\u05d5\u05e8\u05e9\u05d4 \u05dc\u05d2\u05e9\u05ea \u05dc\u05e7\u05d5\u05e8\u05e1\u05d9\u05dd \u05de\u05d5\u05d2\u05d1\u05dc\u05d9\u05dd \u05de\u05de\u05d3\u05d9\u05e0\u05d5\u05ea \u05e9\u05dc\u05d0 \u05e0\u05db\u05dc\u05dc\u05d5.",
    "Allowance Section": "\u05e4\u05e8\u05e7 \u05d4\u05de\u05e2\u05e0\u05e7",
    "Allowance Type": "\u05e1\u05d5\u05d2 \u05d4\u05d4\u05e7\u05e6\u05d1\u05d4",
    "Allowance Value": "\u05e2\u05e8\u05da \u05d4\u05d4\u05e7\u05e6\u05d1\u05d4",
    "Allowances": "\u05d4\u05e7\u05e6\u05d1\u05d5\u05ea",
    "Allows all learners to work on the problem again.": "\u05de\u05d0\u05e4\u05e9\u05e8 \u05dc\u05db\u05dc \u05d4\u05dc\u05d5\u05de\u05d3\u05d9\u05dd \u05dc\u05e2\u05d1\u05d5\u05d3 \u05e9\u05d5\u05d1 \u05e2\u05dc \u05d1\u05e2\u05d9\u05d4.",
    "Allows courses to share the same css class across runs even if they have different numbers.": "\u05de\u05d0\u05e4\u05e9\u05e8 \u05dc\u05e7\u05d5\u05e8\u05e1\u05d9\u05dd \u05dc\u05e9\u05ea\u05e3 \u05d0\u05ea \u05d0\u05d5\u05ea\u05d5 \u05db\u05d9\u05ea\u05ea CSS \u05d1\u05d4\u05e8\u05e6\u05d5\u05ea \u05d2\u05dd \u05d0\u05dd \u05d9\u05e9 \u05dc\u05d4\u05dd \u05de\u05e1\u05e4\u05e8\u05d9\u05dd \u05e9\u05d5\u05e0\u05d9\u05dd.",
    "Allows hiding of the progress tab.": "\u05d0\u05e4\u05e9\u05e8 \u05d4\u05e1\u05ea\u05e8\u05d4 \u05e9\u05dc \u05db\u05e8\u05d8\u05d9\u05e1\u05d9\u05d9\u05ea \u05d4\u05d4\u05ea\u05e7\u05d3\u05de\u05d5\u05ea.",
    "Allows specification of an external link to replace discussion forums.": "\u05de\u05d0\u05e4\u05e9\u05e8 \u05de\u05e4\u05e8\u05d8 \u05e9\u05dc \u05e7\u05d9\u05e9\u05d5\u05e8 \u05d7\u05d9\u05e6\u05d5\u05e0\u05d9 \u05e2\u05dc \u05de\u05e0\u05ea \u05dc\u05d4\u05d7\u05dc\u05d9\u05e3 \u05e4\u05d5\u05e8\u05d5\u05de\u05d9 \u05d3\u05d9\u05d5\u05df.",
    "Almost there!": "\u05db\u05de\u05e2\u05d8 \u05e9\u05dd!",
    "Almost there! In order to complete your sign up we need you to verify your email address ({email}). An activation message and next steps should be waiting for you there.": "\u05db\u05de\u05e2\u05d8 \u05e1\u05d9\u05d9\u05de\u05ea! \u05e2\u05dc \u05de\u05e0\u05ea \u05dc\u05d4\u05e9\u05dc\u05d9\u05dd \u05d0\u05ea \u05d4\u05e8\u05e9\u05de\u05ea\u05da, \u05e2\u05dc\u05d9\u05da \u05dc\u05d0\u05de\u05ea \u05d0\u05ea \u05db\u05ea\u05d5\u05d1\u05ea \u05d4\u05d3\u05d5\u05d0\"\u05dc \u05e9\u05dc\u05da({email}). \u05d4\u05d5\u05d3\u05e2\u05ea \u05d4\u05e4\u05e2\u05dc\u05d4 \u05d5\u05e4\u05d9\u05e8\u05d5\u05d8 \u05d4\u05e9\u05dc\u05d1\u05d9\u05dd \u05d4\u05d1\u05d0\u05d9\u05dd \u05ea\u05de\u05ea\u05d9\u05df \u05dc\u05da \u05e9\u05dd.",
    "Already a course team member": "\u05db\u05d1\u05e8 \u05d7\u05d1\u05e8 \u05d1\u05e6\u05d5\u05d5\u05ea \u05d4\u05e7\u05d5\u05e8\u05e1",
    "Already a library team member": "\u05db\u05d1\u05e8 \u05d7\u05d1\u05e8 \u05d1\u05e6\u05d5\u05d5\u05ea \u05d4\u05e1\u05e4\u05e8\u05d9\u05d9\u05d4",
    "Already a member": "\u05db\u05d1\u05e8 \u05d7\u05d1\u05e8",
    "Already have a {studio_name} Account? Sign In": "\u05e8\u05e9\u05d5\u05dd \u05db\u05d1\u05e8  \u05dc-{studio_name}? \u05d4\u05ea\u05d7\u05d1\u05e8",
    "Already have an account?": "\u05d9\u05e9 \u05dc\u05e0\u05d5 \u05de\u05e9\u05ea\u05de\u05e9 \u05e7\u05d9\u05d9\u05dd?",
    "Already have an {platformName} account?": "\u05db\u05d1\u05e8 \u05e0\u05e8\u05e9\u05de\u05ea \u05dc {platformName}?",
    "Already registered?": "\u05e8\u05e9\u05d5\u05dd \u05db\u05d1\u05e8?",
    "Also receive emails about article edits": "\u05e7\u05d9\u05d1\u05dc \u05d2\u05dd \u05d3\u05d5\u05d0\u05e8 \u05d0\u05dc\u05e7\u05d8\u05e8\u05d5\u05e0\u05d9 \u05dc\u05d2\u05d1\u05d9 \u05e9\u05d9\u05e0\u05d5\u05d9\u05d9\u05dd \u05d1\u05de\u05d0\u05de\u05e8",
    "Alternative source": "\u05de\u05e7\u05d5\u05e8 \u05d7\u05dc\u05d5\u05e4\u05d9",
    "Always": "\u05ea\u05de\u05d9\u05d3",
    "Always divide content-specific discussion topics": "\u05d7\u05dc\u05e7\u05d5 \u05d1\u05d0\u05d5\u05e4\u05df \u05d2\u05d5\u05e8\u05e3 \u05d0\u05ea \u05db\u05dc \u05e0\u05d5\u05e9\u05d0\u05d9 \u05d4\u05d3\u05d9\u05d5\u05e0\u05d9\u05dd \u05dc\u05e4\u05d9 \u05ea\u05d5\u05db\u05df \u05e1\u05e4\u05e6\u05d9\u05e4\u05d9",
    "Always show assessment results": "\u05dc\u05d4\u05e6\u05d9\u05d2 \u05ea\u05de\u05d9\u05d3 \u05d0\u05ea \u05ea\u05d5\u05e6\u05d0\u05d5\u05ea \u05d4\u05e2\u05e8\u05db\u05d4",
    "Among other things, we and the educational institutions that provide courses through this site may use the information about you collected through the Site (including Lerner Data) in connection with the following. In cases where we share or disclose your Learner Data: (1) the third party recipients are required to handle the Learner Data in a confidential manner and to maintain adequate security to protect the information from loss, misuse, unauthorized access or disclosure, alteration, and destruction; and (2) we will only disclose and share Learner Data that is required by the third party to fulfill the purpose stated at the time of collection.": "\u05d1\u05d9\u05df \u05d4\u05d9\u05ea\u05e8, \u05d0\u05e0\u05d5, \u05de\u05d5\u05e1\u05d3\u05d5\u05ea \u05d7\u05d9\u05e0\u05d5\u05da \u05d5\u05d2\u05d5\u05e4\u05d9\u05dd \u05d0\u05d7\u05e8\u05d9\u05dd (\u05dc\u05d4\u05dc\u05df:\"\u05de\u05d5\u05e1\u05d3\u05d5\u05ea \u05d4\u05d7\u05d9\u05e0\u05d5\u05da\"), \u05d4\u05de\u05e1\u05e4\u05e7\u05d9\u05dd \u05e7\u05d5\u05e8\u05e1\u05d9\u05dd \u05d1\u05d0\u05de\u05e6\u05e2\u05d5\u05ea \u05d4\u05d0\u05ea\u05e8, \u05e2\u05e9\u05d5\u05d9\u05d9\u05dd \u05dc\u05d4\u05e9\u05ea\u05de\u05e9 \u05d1\u05de\u05d9\u05d3\u05e2 \u05e2\u05dc\u05d9\u05db\u05dd \u05e9\u05d9\u05d9\u05d0\u05e1\u05e3 \u05de\u05df \u05d4\u05d0\u05ea\u05e8 (\u05db\u05d5\u05dc\u05dc \u05e0\u05ea\u05d5\u05e0\u05d9 \u05d4\u05dc\u05d5\u05de\u05d3) \u05d1\u05de\u05e7\u05e8\u05d9\u05dd \u05e9\u05dc\u05d4\u05dc\u05df. \u05d1\u05de\u05e7\u05e8\u05d4 \u05e9\u05e0\u05e9\u05ea\u05e3 \u05d0\u05d5 \u05e0\u05de\u05e1\u05d5\u05e8 \u05d0\u05ea \u05e0\u05ea\u05d5\u05e0\u05d9 \u05d4\u05dc\u05d5\u05de\u05d3 \u05d0\u05d5\u05d3\u05d5\u05ea\u05d9\u05da: (1) \u05e0\u05d3\u05e8\u05e9\u05d9\u05dd \u05e6\u05d3\u05d3\u05d9\u05dd \u05e9\u05dc\u05d9\u05e9\u05d9\u05d9\u05dd \u05d4\u05de\u05e7\u05d1\u05dc\u05d9\u05dd \u05d0\u05ea \u05e0\u05ea\u05d5\u05e0\u05d9 \u05d4\u05dc\u05d5\u05de\u05d3 \u05dc\u05e0\u05d4\u05d5\u05d2 \u05d1\u05e0\u05ea\u05d5\u05e0\u05d9\u05dd \u05d0\u05dc\u05d5 \u05d1\u05d0\u05d5\u05e4\u05df \u05d7\u05e1\u05d5\u05d9 \u05d5\u05dc\u05d4\u05e4\u05e2\u05d9\u05dc \u05d0\u05de\u05e6\u05e2\u05d9 \u05d0\u05d1\u05d8\u05d7\u05d4 \u05de\u05e1\u05e4\u05e7\u05d9\u05dd \u05dc\u05e9\u05dd \u05d4\u05d4\u05d2\u05e0\u05d4 \u05e2\u05dc \u05d4\u05de\u05d9\u05d3\u05e2 \u05de\u05d0\u05d5\u05d1\u05d3\u05df, \u05e9\u05d9\u05de\u05d5\u05e9 \u05d1\u05dc\u05ea\u05d9 \u05d4\u05d5\u05dc\u05dd, \u05d2\u05d9\u05e9\u05d4 \u05d1\u05dc\u05ea\u05d9 \u05de\u05d5\u05e8\u05e9\u05d4 \u05d0\u05d5 \u05d7\u05e9\u05d9\u05e4\u05d4, \u05e9\u05d9\u05e0\u05d5\u05d9 \u05d5\u05d4\u05e9\u05de\u05d3\u05d4; (2) \u05d0\u05e0\u05d5 \u05e0\u05d7\u05e9\u05d5\u05e3 \u05d5\u05e0\u05e9\u05ea\u05e3 \u05d0\u05ea \u05e0\u05ea\u05d5\u05e0\u05d9 \u05d4\u05dc\u05d5\u05de\u05d3 \u05d1\u05e4\u05e0\u05d9 \u05e6\u05d3 \u05d2' \u05e8\u05e7 \u05db\u05e9\u05d4\u05d3\u05d1\u05e8 \u05d9\u05d9\u05d3\u05e8\u05e9 \u05e2\u05dc \u05d9\u05d3\u05d9 \u05e6\u05d3 \u05d2' \u05dc\u05e9\u05dd \u05d1\u05d9\u05e6\u05d5\u05e2 \u05d0\u05d7\u05ea \u05d4\u05de\u05d8\u05e8\u05d5\u05ea \u05e9\u05d4\u05d5\u05e6\u05d4\u05e8\u05d5 \u05d1\u05e4\u05e0\u05d9\u05da, \u05d1\u05e2\u05ea \u05d0\u05d9\u05e1\u05d5\u05e3 \u05d4\u05de\u05d9\u05d3\u05e2.",
    "Among other things, we, educational institutes and other bodies )hereinafter, \"the Educational Institutes\", providing courses by way of the Website, may use information about you gathered from teh Website (including Student Data) in the following cases. In case we share or deliver your Student Data: (1) third parties that receive the Student Data are required to handle these data in a confedential way and employ security means sufficient for protection of the information from loss, improper use, unauthorized access of exposure, alteration and destruction; (2) we will disclose and share the Student Data with a third party only when requested by a third party for execution of either of the objectives declared to you upon gathering of the information.": "\u05d1\u05d9\u05df \u05d4\u05d9\u05ea\u05e8, \u05d0\u05e0\u05d5, \u05de\u05d5\u05e1\u05d3\u05d5\u05ea \u05d7\u05d9\u05e0\u05d5\u05da \u05d5\u05d2\u05d5\u05e4\u05d9\u05dd \u05d0\u05d7\u05e8\u05d9\u05dd (\u05dc\u05d4\u05dc\u05df:\"\u05de\u05d5\u05e1\u05d3\u05d5\u05ea \u05d4\u05d7\u05d9\u05e0\u05d5\u05da\"), \u05d4\u05de\u05e1\u05e4\u05e7\u05d9\u05dd \u05e7\u05d5\u05e8\u05e1\u05d9\u05dd \u05d1\u05d0\u05de\u05e6\u05e2\u05d5\u05ea \u05d4\u05d0\u05ea\u05e8, \u05e2\u05e9\u05d5\u05d9\u05d9\u05dd \u05dc\u05d4\u05e9\u05ea\u05de\u05e9 \u05d1\u05de\u05d9\u05d3\u05e2 \u05e2\u05dc\u05d9\u05db\u05dd \u05e9\u05d9\u05d9\u05d0\u05e1\u05e3 \u05de\u05df \u05d4\u05d0\u05ea\u05e8 (\u05db\u05d5\u05dc\u05dc \u05e0\u05ea\u05d5\u05e0\u05d9 \u05d4\u05dc\u05d5\u05de\u05d3) \u05d1\u05de\u05e7\u05e8\u05d9\u05dd \u05e9\u05dc\u05d4\u05dc\u05df. \u05d1\u05de\u05e7\u05e8\u05d4 \u05e9\u05e0\u05e9\u05ea\u05e3 \u05d0\u05d5 \u05e0\u05de\u05e1\u05d5\u05e8 \u05d0\u05ea \u05e0\u05ea\u05d5\u05e0\u05d9 \u05d4\u05dc\u05d5\u05de\u05d3 \u05d0\u05d5\u05d3\u05d5\u05ea\u05d9\u05da: (1) \u05e0\u05d3\u05e8\u05e9\u05d9\u05dd \u05e6\u05d3\u05d3\u05d9\u05dd \u05e9\u05dc\u05d9\u05e9\u05d9\u05d9\u05dd \u05d4\u05de\u05e7\u05d1\u05dc\u05d9\u05dd \u05d0\u05ea \u05e0\u05ea\u05d5\u05e0\u05d9 \u05d4\u05dc\u05d5\u05de\u05d3 \u05dc\u05e0\u05d4\u05d5\u05d2 \u05d1\u05e0\u05ea\u05d5\u05e0\u05d9\u05dd \u05d0\u05dc\u05d5 \u05d1\u05d0\u05d5\u05e4\u05df \u05d7\u05e1\u05d5\u05d9 \u05d5\u05dc\u05d4\u05e4\u05e2\u05d9\u05dc \u05d0\u05de\u05e6\u05e2\u05d9 \u05d0\u05d1\u05d8\u05d7\u05d4 \u05de\u05e1\u05e4\u05e7\u05d9\u05dd \u05dc\u05e9\u05dd \u05d4\u05d4\u05d2\u05e0\u05d4 \u05e2\u05dc \u05d4\u05de\u05d9\u05d3\u05e2 \u05de\u05d0\u05d5\u05d1\u05d3\u05df, \u05e9\u05d9\u05de\u05d5\u05e9 \u05d1\u05dc\u05ea\u05d9 \u05d4\u05d5\u05dc\u05dd, \u05d2\u05d9\u05e9\u05d4 \u05d1\u05dc\u05ea\u05d9 \u05de\u05d5\u05e8\u05e9\u05d4 \u05d0\u05d5 \u05d7\u05e9\u05d9\u05e4\u05d4, \u05e9\u05d9\u05e0\u05d5\u05d9 \u05d5\u05d4\u05e9\u05de\u05d3\u05d4; (2) \u05d0\u05e0\u05d5 \u05e0\u05d7\u05e9\u05d5\u05e3 \u05d5\u05e0\u05e9\u05ea\u05e3 \u05d0\u05ea \u05e0\u05ea\u05d5\u05e0\u05d9 \u05d4\u05dc\u05d5\u05de\u05d3 \u05d1\u05e4\u05e0\u05d9 \u05e6\u05d3 \u05d2' \u05e8\u05e7 \u05db\u05e9\u05d4\u05d3\u05d1\u05e8 \u05d9\u05d9\u05d3\u05e8\u05e9 \u05e2\u05dc \u05d9\u05d3\u05d9 \u05e6\u05d3 \u05d2' \u05dc\u05e9\u05dd \u05d1\u05d9\u05e6\u05d5\u05e2 \u05d0\u05d7\u05ea \u05d4\u05de\u05d8\u05e8\u05d5\u05ea \u05e9\u05d4\u05d5\u05e6\u05d4\u05e8\u05d5 \u05d1\u05e4\u05e0\u05d9\u05da, \u05d1\u05e2\u05ea \u05d0\u05d9\u05e1\u05d5\u05e3 \u05d4\u05de\u05d9\u05d3\u05e2.",
    "Amount of time after the due date that submissions will be accepted": "\u05de\u05e9\u05da \u05d4\u05d6\u05de\u05df \u05dc\u05d0\u05d7\u05e8 \u05ea\u05d0\u05e8\u05d9\u05da \u05d4\u05d9\u05e2\u05d3 \u05d1\u05d5 \u05d9\u05ea\u05e7\u05d1\u05dc\u05d5 \u05e2\u05d3\u05d9\u05d9\u05df \u05d4\u05d4\u05d2\u05e9\u05d5\u05ea ",
    "An Unknown error occurred during the unpacking step.": "\u05d0\u05d9\u05e8\u05e2\u05d4 \u05e9\u05d2\u05d9\u05d0\u05d4 \u05dc\u05d0 \u05d9\u05d3\u05d5\u05e2\u05d4 \u05d1\u05de\u05d4\u05dc\u05da \u05e9\u05dc\u05d1 \u05d4\u05e4\u05d9\u05e8\u05d5\u05e7.",
    "An access key for the example certificate.  This is used when we receive a response from the queue to validate that the sender is the same entity we asked to generate the certificate.": "\u05de\u05e4\u05ea\u05d7 \u05d2\u05d9\u05e9\u05d4 \u05e2\u05d1\u05d5\u05e8 \u05d4\u05ea\u05e2\u05d5\u05d3\u05d4 \u05dc\u05d3\u05d5\u05d2\u05de\u05d4.  \u05de\u05e9\u05de\u05e9 \u05db\u05e9\u05d0\u05e0\u05d5 \u05de\u05e7\u05d1\u05dc\u05d9\u05dd \u05ea\u05e9\u05d5\u05d1\u05d4 \u05de\u05d4\u05ea\u05d5\u05e8 \u05db\u05d3\u05d9 \u05dc\u05d0\u05de\u05ea \u05e9\u05d4\u05e9\u05d5\u05dc\u05d7 \u05d4\u05d5\u05d0 \u05d0\u05d5\u05ea\u05d4 \u05d9\u05e9\u05d5\u05ea \u05e9\u05d1\u05d9\u05e7\u05e9\u05e0\u05d5 \u05de\u05de\u05e0\u05d4 \u05dc\u05d9\u05e6\u05d5\u05e8 \u05d0\u05ea \u05d4\u05ea\u05e2\u05d5\u05d3\u05d4.",
    "An access_token is required when passing value ({}) for provider.": "\u05d3\u05e8\u05d5\u05e9 access_token \u05db\u05d0\u05e9\u05e8 \u05e2\u05d5\u05d1\u05e8\u05d9\u05dd \u05d0\u05ea \u05e2\u05e8\u05da ({}) \u05e2\u05d1\u05d5\u05e8 \u05e1\u05e4\u05e7. ",
    "An account with email {email} exists but the provided username {username} is different. Enrolling anyway with {email}.": "\u05e7\u05d9\u05d9\u05dd \u05db\u05d1\u05e8 \u05d7\u05e9\u05d1\u05d5\u05df \u05dc\u05db\u05ea\u05d5\u05d1\u05ea {email} \u05d0\u05da \u05e9\u05dd \u05d4\u05de\u05e9\u05ea\u05de\u05e9 \u05e9\u05e0\u05d9\u05ea\u05df {username} \u05e9\u05d5\u05e0\u05d4. \u05d4\u05d9\u05e8\u05e9\u05dd \u05d1\u05db\u05dc \u05d6\u05d0\u05ea \u05e2\u05dd {email}.   ",
    "An account with the Email '{email}' already exists.": "\u05d7\u05e9\u05d1\u05d5\u05df \u05e2\u05dd \u05d3\u05d5\u05d0\u05e8 \u05d0\u05dc\u05e7\u05d8\u05e8\u05d5\u05e0\u05d9 '{email}' \u05e7\u05d9\u05d9\u05dd \u05db\u05d1\u05e8.",
    "An account with the Public Username '{username}' already exists.": "\u05d7\u05e9\u05d1\u05d5\u05df \u05e2\u05dd \u05e9\u05dd \u05de\u05e9\u05ea\u05de\u05e9 '{username}' \u05e7\u05d9\u05d9\u05dd \u05db\u05d1\u05e8.",
    "An account with the new e-mail address already exists.": "\u05d7\u05e9\u05d1\u05d5\u05df \u05e2\u05dd \u05db\u05ea\u05d5\u05d1\u05ea \u05d3\u05d5\u05d0\u05e8 \u05d0\u05dc\u05e7\u05d8\u05e8\u05d5\u05e0\u05d9 \u05d7\u05d3\u05e9\u05d4 \u05db\u05d1\u05e8 \u05e7\u05d9\u05d9\u05dd.",
    "An answer option has been left blank. Please review and edit the component.": "\u05d0\u05e4\u05e9\u05e8\u05d5\u05ea \u05ea\u05e9\u05d5\u05d1\u05d4 \u05e0\u05d5\u05ea\u05e8\u05d4 \u05e8\u05d9\u05e7\u05d4. \u05d0\u05e0\u05d0 \u05e2\u05d9\u05d9\u05e0\u05d5 \u05d5\u05e2\u05e8\u05db\u05d5 \u05d0\u05ea \u05d4\u05e8\u05db\u05d9\u05d1.",
    "An edX Verified Certificate signifies that the learner has agreed to abide by the edX honor code and completed all of the required tasks of this course under its guidelines, as well as having their photo ID checked to verify their identity.": "\u05d0\u05d9\u05e9\u05d5\u05e8 edX Verified \u05de\u05e6\u05d9\u05d9\u05df \u05e9\u05d4\u05dc\u05d5\u05de\u05d3 \u05d4\u05e1\u05db\u05d9\u05dd \u05dc\u05e6\u05d9\u05d9\u05ea \u05dc\u05e7\u05d5\u05d3 \u05d4\u05db\u05d1\u05d5\u05d3 \u05e9\u05dc edX \u05d5\u05d4\u05e9\u05dc\u05d9\u05dd \u05d0\u05ea \u05db\u05dc \u05d4\u05de\u05e9\u05d9\u05de\u05d5\u05ea \u05d4\u05e0\u05d3\u05e8\u05e9\u05d5\u05ea \u05e9\u05dc \u05e7\u05d5\u05e8\u05e1 \u05d6\u05d4 \u05d1\u05d4\u05ea\u05d0\u05dd \u05dc\u05d4\u05e0\u05d7\u05d9\u05d5\u05ea \u05e9\u05dc\u05d5, \u05d1\u05e0\u05d5\u05e1\u05e3 \u05dc\u05d1\u05d3\u05d9\u05e7\u05ea \u05ea\u05e2\u05d5\u05d3\u05ea \u05d4\u05d6\u05d4\u05d5\u05ea \u05e9\u05dc\u05d5 \u05e2\u05dd \u05ea\u05de\u05d5\u05e0\u05d4 \u05db\u05d3\u05d9 \u05dc\u05d0\u05de\u05ea \u05d0\u05ea \u05d6\u05d4\u05d5\u05ea\u05d5.",
    "An email has been sent to {userEmail} with a link for you to activate your account.": "\u05e0\u05e9\u05dc\u05d7\u05d4 \u05d4\u05d5\u05d3\u05e2\u05ea \u05d3\u05d5\u05d0\u05e8 \u05d0\u05dc\u05e7\u05d8\u05e8\u05d5\u05e0\u05d9 \u05dc {userEmail} \u05e2\u05dd \u05e7\u05d9\u05e9\u05d5\u05e8 \u05e2\u05d1\u05d5\u05e8\u05da \u05e2\u05dc \u05de\u05e0\u05ea \u05dc\u05d4\u05e4\u05e2\u05d9\u05dc \u05d0\u05ea \u05d4\u05d7\u05e9\u05d1\u05d5\u05df.",
    "An employee (a user whose email has current site's domain name) whose email exists in this model, can be able to login from login screen through email and password. And if any employee's email doesn't exist in this model then that employee can login via third party authentication backend only.": "\u05e2\u05d5\u05d1\u05d3 (\u05de\u05e9\u05ea\u05de\u05e9 \u05e9\u05db\u05ea\u05d5\u05d1\u05ea \u05d4\u05d3\u05d5\u05d0\"\u05dc \u05e9\u05dc\u05d5 \u05db\u05d5\u05dc\u05dc\u05ea \u05d0\u05ea \u05e9\u05dd \u05d4\u05d3\u05d5\u05de\u05d9\u05d9\u05df \u05e9\u05dc \u05d4\u05d0\u05ea\u05e8 \u05d4\u05e0\u05d5\u05db\u05d7\u05d9) \u05e9\u05db\u05ea\u05d5\u05d1\u05ea \u05d4\u05d3\u05d5\u05d0\"\u05dc \u05e9\u05dc\u05d5 \u05e7\u05d9\u05d9\u05de\u05ea \u05d1\u05de\u05d5\u05d3\u05dc \u05d6\u05d4, \u05d9\u05db\u05d5\u05dc \u05dc\u05d4\u05d9\u05db\u05e0\u05e1 \u05de\u05de\u05e1\u05da \u05d4\u05db\u05e0\u05d9\u05e1\u05d4 \u05dc\u05de\u05e2\u05e8\u05db\u05ea \u05d1\u05d0\u05de\u05e6\u05e2\u05d5\u05ea \u05db\u05ea\u05d5\u05d1\u05ea \u05d3\u05d5\u05d0\"\u05dc \u05d5\u05e1\u05d9\u05e1\u05de\u05d4. \u05d5\u05d0\u05dd \u05db\u05ea\u05d5\u05d1\u05ea \u05d4\u05d3\u05d5\u05d0\"\u05dc \u05e9\u05dc \u05e2\u05d5\u05d1\u05d3 \u05db\u05dc\u05e9\u05d4\u05d5 \u05d0\u05d9\u05e0\u05d4 \u05e7\u05d9\u05d9\u05de\u05ea \u05d1\u05de\u05d5\u05d3\u05dc \u05d6\u05d4, \u05d4\u05e2\u05d5\u05d1\u05d3 \u05d9\u05db\u05d5\u05dc \u05dc\u05d4\u05d9\u05db\u05e0\u05e1 \u05dc\u05de\u05e2\u05e8\u05db\u05ea \u05d3\u05e8\u05da \u05ea\u05d4\u05dc\u05d9\u05da \u05d0\u05d9\u05de\u05d5\u05ea \u05e6\u05d3-\u05e9\u05dc\u05d9\u05e9\u05d9 \u05d1\u05dc\u05d1\u05d3.",
    "An error has occurred. Check your Internet connection and try again.": "\u05d0\u05d9\u05e8\u05e2\u05d4 \u05e9\u05d2\u05d9\u05d0\u05d4. \u05d1\u05d3\u05d5\u05e7 \u05d0\u05ea \u05d7\u05d9\u05d1\u05d5\u05e8 \u05d4\u05d0\u05d9\u05e0\u05d8\u05e8\u05e0\u05d8 \u05d5\u05e0\u05e1\u05d4 \u05e9\u05d5\u05d1.",
    "An error has occurred. Make sure that you are connected to the Internet, and then try refreshing the page.": "\u05d0\u05d9\u05e8\u05e2\u05d4 \u05e9\u05d2\u05d9\u05d0\u05d4. \u05d5\u05d3\u05d0 \u05db\u05d9 \u05d0\u05ea\u05d4 \u05de\u05d7\u05d5\u05d1\u05e8 \u05dc\u05d0\u05d9\u05e0\u05d8\u05e8\u05e0\u05d8, \u05d5\u05d0\u05d6 \u05e8\u05e2\u05e0\u05df \u05d0\u05ea \u05d4\u05d3\u05e3.",
    "An error has occurred. Please ensure that you are logged in to enroll.": "\u05e9\u05d2\u05d9\u05d0\u05d4 \u05d4\u05ea\u05e8\u05d7\u05e9\u05d4. \u05d9\u05e9 \u05dc\u05d1\u05d3\u05d5\u05e7 \u05e9\u05d0\u05ea\u05dd \u05de\u05d7\u05d5\u05d1\u05e8\u05d9\u05dd \u05dc\u05d0\u05ea\u05e8, \u05d5\u05dc\u05d0\u05d7\u05e8 \u05de\u05db\u05df \u05e0\u05d9\u05ea\u05df \u05dc\u05d4\u05d9\u05e8\u05e9\u05dd \u05dc\u05e7\u05d5\u05e8\u05e1.",
    "An error has occurred. Please try again later.": "\u05d0\u05d9\u05e8\u05e2\u05d4 \u05e9\u05d2\u05d9\u05d0\u05d4. \u05d0\u05e0\u05d0 \u05e0\u05e1\u05d4 \u05e9\u05d5\u05d1 \u05de\u05d0\u05d5\u05d7\u05e8 \u05d9\u05d5\u05ea\u05e8.",
    "An error has occurred. Please try again.": "\u05d0\u05d9\u05e8\u05e2\u05d4 \u05e9\u05d2\u05d9\u05d0\u05d4. \u05e0\u05e1\u05d5 \u05e9\u05d5\u05d1.",
    "An error has occurred. Please try reloading the page.": "\u05d0\u05d9\u05e8\u05e2\u05d4 \u05e9\u05d2\u05d9\u05d0\u05d4. \u05d0\u05e0\u05d0 \u05e0\u05e1\u05d4 \u05dc\u05d8\u05e2\u05d5\u05df \u05de\u05d7\u05d3\u05e9 \u05d0\u05ea \u05d4\u05e2\u05de\u05d5\u05d3.",
    "An error has occurred. Refresh the page, and then try again.": "\u05d0\u05d9\u05e8\u05e2\u05d4 \u05e9\u05d2\u05d9\u05d0\u05d4. \u05e8\u05e2\u05e0\u05df \u05d0\u05ea \u05d4\u05e2\u05de\u05d5\u05d3 \u05d5\u05e0\u05e1\u05d4 \u05e9\u05d5\u05d1.",
    "An error has occurred. Task was not created.": "\u05d0\u05d9\u05e8\u05e2\u05d4 \u05e9\u05d2\u05d9\u05d0\u05d4. \u05e0\u05d0 \u05e0\u05d5\u05e6\u05e8\u05d4 \u05de\u05e9\u05d9\u05de\u05d4.",
    "An error has occurred. Try refreshing the page, or check your Internet connection.": "\u05d0\u05d9\u05e8\u05e2\u05d4 \u05e9\u05d2\u05d9\u05d0\u05d4. \u05e0\u05e1\u05d4 \u05dc\u05e8\u05e2\u05e0\u05df \u05d0\u05ea \u05d4\u05d3\u05e3 \u05d0\u05d5 \u05d1\u05d3\u05d5\u05e7 \u05d0\u05ea \u05d7\u05d9\u05d1\u05d5\u05e8 \u05d4\u05d0\u05d9\u05e0\u05d8\u05e8\u05e0\u05d8.",
    "An error has occurred. Wait a few minutes, and then try again.": "\u05d0\u05d9\u05e8\u05e2\u05d4 \u05e9\u05d2\u05d9\u05d0\u05d4. \u05d4\u05de\u05ea\u05d9\u05e0\u05d5 \u05de\u05e1\u05e4\u05e8 \u05d3\u05e7\u05d5\u05ea \u05d5\u05dc\u05d0\u05d7\u05e8 \u05de\u05db\u05df \u05e0\u05e1\u05d5 \u05e9\u05d5\u05d1.",
    "An error occurred in {studio_name} and the page could not be loaded. Please try again in a few moments.": "\u05e9\u05d2\u05d9\u05d0\u05d4 \u05d0\u05d9\u05e8\u05e2\u05d4 \u05d1-{studio_name} \u05d5\u05dc\u05d0 \u05e0\u05d9\u05ea\u05df \u05d4\u05d9\u05d4 \u05dc\u05d8\u05e2\u05d5\u05df \u05d0\u05ea \u05d4\u05e2\u05de\u05d5\u05d3. \u05e0\u05e1\u05d4 \u05e9\u05d5\u05d1 \u05d1\u05e2\u05d5\u05d3 \u05de\u05e1\u05e4\u05e8 \u05d3\u05e7\u05d5\u05ea.",
    "An error occurred retrieving your email. Please try again later, and contact technical support if the problem persists.": "\u05d0\u05d9\u05e8\u05e2\u05d4 \u05e9\u05d2\u05d9\u05d0\u05d4 \u05d1\u05d0\u05d7\u05d6\u05d5\u05e8 \u05d4\u05d3\u05d5\u05d0\u05e8 \u05d4\u05d0\u05dc\u05e7\u05d8\u05e8\u05d5\u05e0\u05d9 \u05e9\u05dc\u05da. \u05d0\u05e0\u05d0 \u05e0\u05e1\u05d4 \u05e9\u05d5\u05d1 \u05de\u05d0\u05d5\u05d7\u05e8 \u05d9\u05d5\u05ea\u05e8. \u05d0\u05dd \u05d4\u05d1\u05e2\u05d9\u05d4 \u05e0\u05de\u05e9\u05db\u05ea, \u05e4\u05e0\u05d4 \u05dc\u05ea\u05de\u05d9\u05db\u05d4 \u05d8\u05db\u05e0\u05d9\u05ea. ",
    "An error occurred when signing you in to %s.": "\u05d0\u05d9\u05e8\u05e2\u05d4 \u05e9\u05d2\u05d9\u05d0\u05d4 \u05d1\u05d6\u05de\u05df \u05d4\u05d7\u05d9\u05d1\u05d5\u05e8 \u05e9\u05dc\u05da \u05dc-%s.",
    "An error occurred while attempting to retrieve or save the information below. Please try again later.": "\u05d0\u05d9\u05e8\u05e2\u05d4 \u05e9\u05d2\u05d9\u05d0\u05d4 \u05d1\u05e2\u05ea \u05d4\u05e0\u05d9\u05e1\u05d9\u05d5\u05df \u05dc\u05de\u05e9\u05d5\u05da \u05d0\u05d5 \u05dc\u05e9\u05de\u05d5\u05e8 \u05d0\u05ea \u05d4\u05de\u05d9\u05d3\u05e2 \u05e9\u05dc\u05d4\u05dc\u05df. \u05e0\u05d0 \u05dc\u05e0\u05e1\u05d5\u05ea \u05e9\u05d5\u05d1 \u05de\u05d0\u05d5\u05d7\u05e8 \u05d9\u05d5\u05ea\u05e8.",
    "An error occurred while deleting the score.": "\u05d0\u05d9\u05e8\u05e2\u05d4 \u05e9\u05d2\u05d9\u05d0\u05d4 \u05d1\u05de\u05d4\u05dc\u05da \u05de\u05d7\u05d9\u05e7\u05ea \u05d4\u05e6\u05d9\u05d5\u05df.",
    "An error occurred while looking up team membership. Try refreshing the page.": "\u05d0\u05d9\u05e8\u05e2\u05d4 \u05e9\u05d2\u05d9\u05d0\u05d4 \u05d1\u05e2\u05ea \u05d7\u05d9\u05e4\u05d5\u05e9 \u05d4\u05d7\u05d1\u05e8\u05d5\u05ea \u05d1\u05e6\u05d5\u05d5\u05ea. \u05e0\u05e1\u05d5 \u05dc\u05e8\u05e2\u05e0\u05df \u05d0\u05ea \u05d4\u05e2\u05de\u05d5\u05d3.",
    "An error occurred while removing the member from the team. Try again.": "\u05d0\u05d9\u05e8\u05e2\u05d4 \u05e9\u05d2\u05d9\u05d0\u05d4 \u05d1\u05d6\u05de\u05df \u05d4\u05e1\u05e8\u05ea \u05d7\u05d1\u05e8 \u05de\u05d4\u05e6\u05d5\u05d5\u05ea. \u05e0\u05e1\u05d4 \u05e9\u05d5\u05d1.",
    "An error occurred while starting certificate generation.": "\u05d0\u05d9\u05e8\u05e2\u05d4 \u05e9\u05d2\u05d9\u05d0\u05d4 \u05d1\u05e2\u05ea \u05d4\u05ea\u05d7\u05dc\u05ea \u05d9\u05e6\u05d9\u05e8\u05ea \u05ea\u05e2\u05d5\u05d3\u05d5\u05ea.",
    "An error occurred while trying to save your tabs": "\u05d0\u05d9\u05e8\u05e2\u05d4 \u05e9\u05d2\u05d9\u05d0\u05d4 \u05d1\u05e2\u05ea \u05e0\u05d9\u05e1\u05d9\u05d5\u05df \u05dc\u05e9\u05de\u05d5\u05e8 \u05e2\u05dc \u05d4\u05dc\u05e9\u05d5\u05e0\u05d9\u05d5\u05ea",
    "An error occurred with SymbolicResponse. The error was: {error_msg}": "\u05d0\u05d9\u05e8\u05e2\u05d4 \u05e9\u05d2\u05d9\u05d0\u05d4 \u05d1-SymbolicResponse. \u05d4\u05e9\u05d2\u05d9\u05d0\u05d4 \u05d4\u05d9\u05ea\u05d4: {error_msg}",
    "An error occurred with this transaction. For help, contact {support_email}.": "\u05d0\u05d9\u05e8\u05e2\u05d4 \u05e9\u05d2\u05d9\u05d0\u05d4 \u05d1\u05e2\u05e1\u05e7\u05d4 \u05d6\u05d5. \u05dc\u05e7\u05d1\u05dc\u05ea \u05e2\u05d6\u05e8\u05d4, \u05e6\u05d5\u05e8 \u05e7\u05e9\u05e8 \u05e2\u05dd {support_email}.",
    "An error occurred.": "\u05d0\u05d9\u05e8\u05e2\u05d4 \u05e9\u05d2\u05d9\u05d0\u05d4.",
    "An error occurred. Make sure that the student's username or email address is correct and try again.": "\u05d0\u05d9\u05e8\u05e2\u05d4 \u05e9\u05d2\u05d9\u05d0\u05d4. \u05d0\u05e0\u05d0 \u05d5\u05d3\u05d0 \u05db\u05d9 \u05e9\u05dd \u05d4\u05de\u05e9\u05ea\u05de\u05e9 \u05e9\u05dc \u05d4\u05e1\u05d8\u05d5\u05d3\u05e0\u05d8 \u05d0\u05d5 \u05db\u05ea\u05d5\u05d1\u05ea \u05d4\u05d3\u05d5\u05d0\u05e8 \u05d4\u05d0\u05dc\u05e7\u05d8\u05e8\u05d5\u05e0\u05d9 \u05e9\u05dc\u05d5 \u05e0\u05db\u05d5\u05e0\u05d4 \u05d5\u05e0\u05e1\u05d4 \u05e9\u05d5\u05d1.",
    "An error occurred. Please reload the page.": "\u05d0\u05d9\u05e8\u05e2\u05d4 \u05e9\u05d2\u05d9\u05d0\u05d4. \u05e0\u05d0 \u05d8\u05e2\u05df \u05de\u05d7\u05d3\u05e9 \u05d0\u05ea \u05d4\u05e2\u05de\u05d5\u05d3.",
    "An error occurred. Please try again later.": "\u05d0\u05d9\u05e8\u05e2\u05d4 \u05e9\u05d2\u05d9\u05d0\u05d4. \u05e0\u05e1\u05d4 \u05e9\u05d5\u05d1 \u05de\u05d0\u05d5\u05d7\u05e8 \u05d9\u05d5\u05ea\u05e8.",
    "An error occurred. Please try again.": "\u05d0\u05d9\u05e8\u05e2\u05d4 \u05e9\u05d2\u05d9\u05d0\u05d4. \u05e0\u05d0 \u05e0\u05e1\u05d4 \u05e9\u05d5\u05d1.",
    "An error occurred. Try again.": "\u05d0\u05d9\u05e8\u05e2\u05d4 \u05e9\u05d2\u05d9\u05d0\u05d4. \u05e0\u05e1\u05d4 \u05e9\u05d5\u05d1.",
    "An error occurred. Try loading the page again.": "\u05d0\u05d9\u05e8\u05e2\u05d4 \u05e9\u05d2\u05d9\u05d0\u05d4. \u05e0\u05e1\u05d4 \u05dc\u05d8\u05e2\u05d5\u05df \u05e9\u05d5\u05d1 \u05d0\u05ea \u05d4\u05e2\u05de\u05d5\u05d3.",
    "An error occurred. Unable to load drag and drop problem.": "\u05d0\u05d9\u05e8\u05e2\u05d4 \u05e9\u05d2\u05d9\u05d0\u05d4. \u05dc\u05d0 \u05e0\u05d9\u05ea\u05df \u05dc\u05d4\u05e2\u05dc\u05d5\u05ea \u05d1\u05e2\u05d9\u05d9\u05ea \u05d2\u05e8\u05d9\u05e8\u05d4 \u05d5\u05e9\u05d7\u05e8\u05d5\u05e8.",
    "An extended due date must be later than the original due date.": "\u05d4\u05d0\u05e8\u05db\u05ea \u05ea\u05d0\u05e8\u05d9\u05da \u05d4\u05d9\u05e2\u05d3 \u05d7\u05d9\u05d9\u05d1\u05ea \u05dc\u05d4\u05d9\u05d5\u05ea \u05de\u05d0\u05d5\u05d7\u05e8\u05ea \u05d9\u05d5\u05ea\u05e8 \u05de\u05ea\u05d0\u05e8\u05d9\u05da \u05d4\u05d9\u05e2\u05d3 \u05d4\u05de\u05e7\u05d5\u05e8\u05d9.",
    "An external link": "\u05e7\u05d9\u05e9\u05d5\u05e8 \u05d7\u05d9\u05e6\u05d5\u05e0\u05d9",
    "An image file is required.": "\u05e0\u05d3\u05e8\u05e9 \u05e7\u05d5\u05d1\u05e5 \u05ea\u05de\u05d5\u05e0\u05d4.",
    "An image was added: %s": "\u05e0\u05d5\u05e1\u05e4\u05d4 \u05ea\u05de\u05d5\u05e0\u05d4: %s",
    "An isosceles triangle with three layers of similar height. It is shown upright, so the widest layer is located at the bottom, and the narrowest layer is located at the top.": "\u05de\u05e9\u05d5\u05dc\u05e9 \u05e9\u05d5\u05d5\u05d4-\u05e9\u05d5\u05e7\u05d9\u05d9\u05dd \u05d1\u05e2\u05dc \u05e9\u05dc\u05d5\u05e9 \u05e9\u05db\u05d1\u05d5\u05ea \u05d1\u05d2\u05d5\u05d1\u05d4 \u05d3\u05d5\u05de\u05d4. \u05d4\u05d5\u05d0 \u05de\u05d5\u05e6\u05d2 \u05d0\u05e0\u05db\u05d9\u05ea, \u05db\u05da \u05e9\u05d4\u05e9\u05db\u05d1\u05d4 \u05d4\u05e8\u05d7\u05d1\u05d4 \u05d1\u05d9\u05d5\u05ea\u05e8 \u05e0\u05de\u05e6\u05d0\u05ea \u05d1\u05ea\u05d7\u05ea\u05d9\u05ea, \u05d5\u05d4\u05e9\u05db\u05d1\u05d4 \u05d4\u05e6\u05e8\u05d4 \u05d1\u05d9\u05d5\u05ea\u05e8 \u05e0\u05de\u05e6\u05d0\u05ea \u05dc\u05de\u05e2\u05dc\u05d4.",
    "An unexpected error has occurred.": "\u05e9\u05d2\u05d9\u05d0\u05d4 \u05d1\u05dc\u05ea\u05d9 \u05e6\u05e4\u05d5\u05d9\u05d4 \u05d4\u05ea\u05e8\u05d7\u05e9\u05d4",
    "An unexpected error occurred while regenerating certificates.": "\u05d0\u05d9\u05e8\u05e2\u05d4 \u05e9\u05d2\u05d9\u05d0\u05d4 \u05dc\u05d0 \u05e6\u05e4\u05d5\u05d9\u05d4 \u05d1\u05d6\u05de\u05df \u05d9\u05e6\u05d9\u05e8\u05ea \u05ea\u05e2\u05d5\u05d3\u05d5\u05ea \u05de\u05d7\u05d3\u05e9.",
    "An unexpected error occurred.  Please try again.": "\u05d0\u05d9\u05e8\u05e2\u05d4 \u05e9\u05d2\u05d9\u05d0\u05d4 \u05dc\u05d0 \u05e6\u05e4\u05d5\u05d9\u05d4.  \u05e0\u05e1\u05d4 \u05e9\u05d5\u05d1.",
    "An {cert_type} certificate demonstrates a high level of achievement in a program of study, and includes verification of the student's identity.": "\u05ea\u05e2\u05d5\u05d3\u05ea {cert_type} \u05de\u05d3\u05d2\u05d9\u05de\u05d4 \u05e8\u05de\u05ea \u05d4\u05d9\u05e9\u05d2\u05d9\u05dd \u05d2\u05d1\u05d5\u05d4\u05d4 \u05d1\u05ea\u05db\u05e0\u05d9\u05ea \u05d4\u05dc\u05d9\u05de\u05d5\u05d3\u05d9\u05dd \u05d5\u05db\u05d5\u05dc\u05dc\u05ea \u05d0\u05d9\u05de\u05d5\u05ea \u05d6\u05d4\u05d5\u05ea \u05d4\u05e1\u05d8\u05d5\u05d3\u05e0\u05d8.",
    "An {cert_type} certificate signifies that a learner has agreed to abide by the honor code established by {platform_name} and has completed all of the required tasks for this course under its guidelines.": "\u05ea\u05e2\u05d5\u05d3\u05ea {cert_type} \u05de\u05e9\u05de\u05e2\u05d4 \u05e9\u05dc\u05d5\u05de\u05d3 \u05d4\u05e1\u05db\u05d9\u05dd \u05dc\u05e6\u05d9\u05d9\u05ea \u05dc\u05e7\u05d5\u05d3 \u05d4\u05d0\u05ea\u05d9 \u05e9\u05d9\u05d9\u05e1\u05d3\u05d4 {platform_name} \u05d5\u05d4\u05e9\u05dc\u05d9\u05dd \u05d0\u05ea \u05db\u05dc \u05d4\u05de\u05d8\u05dc\u05d5\u05ea \u05d4\u05d3\u05e8\u05d5\u05e9\u05d5\u05ea \u05d1\u05e7\u05d5\u05e8\u05e1 \u05d1\u05d4\u05ea\u05d0\u05dd \u05dc\u05d4\u05e0\u05d7\u05d9\u05d5\u05ea \u05d0\u05dc\u05d4.",
    "Analytics": "\u05d0\u05e0\u05dc\u05d9\u05d8\u05d9\u05e7\u05e1",
    "Anchor": "\u05e2\u05d5\u05d2\u05df",
    "Anchors": "\u05e2\u05d5\u05d2\u05e0\u05d9\u05dd",
    "Annotated": "\u05d4\u05e2\u05e8\u05d5\u05ea \u05d4\u05d1\u05d5\u05d3\u05e7",
    "Annotated SHA1": "\u05d4\u05e2\u05e8\u05ea SHA1",
    "Annotated file from instructor": "\u05de\u05e6\u05d5\u05e8\u05e3 \u05e7\u05d5\u05d1\u05e5 \u05e2\u05dd \u05d4\u05e2\u05e8\u05d5\u05ea \u05d4 \u05d1\u05d5\u05d3\u05e7",
    "Annotated file name": "\u05e9\u05dd \u05e7\u05d5\u05d1\u05e5 \u05e2\u05dd \u05d4\u05e2\u05e8\u05d5\u05ea",
    "Annotation": "\u05d4\u05e1\u05d1\u05e8",
    "Annotation Input": "\u05d4\u05d6\u05e0\u05ea \u05d4\u05e1\u05d1\u05e8\u05d9\u05dd",
    "Annual Household Income": "\u05d4\u05db\u05e0\u05e1\u05ea \u05d1\u05d9\u05ea \u05d0\u05d1 \u05e9\u05e0\u05ea\u05d9\u05ea",
    "Anonymized User IDs": "\u05de\u05d6\u05d4\u05d9 \u05de\u05e9\u05ea\u05de\u05e9\u05d9\u05dd \u05d0\u05e0\u05d5\u05e0\u05d9\u05de\u05d9\u05d9\u05dd",
    "Answer": "\u05ea\u05e9\u05d5\u05d1\u05d4",
    "Answer ID": "\u05de\u05d6\u05d4\u05d4 \u05ea\u05e9\u05d5\u05d1\u05d4",
    "Answer not provided for {input_type}": "\u05dc\u05d0 \u05e1\u05d5\u05e4\u05e7\u05d5 \u05ea\u05e9\u05d5\u05d1\u05d5\u05ea \u05e2\u05d1\u05d5\u05e8 {input_type}",
    "Answer received.": "\u05d4\u05ea\u05e9\u05d5\u05d1\u05d4 \u05d4\u05ea\u05e7\u05d1\u05dc\u05d4.",
    "Answer submitted.": "\u05ea\u05e9\u05d5\u05d1\u05d4 \u05e0\u05e2\u05e0\u05ea\u05d4.",
    "Answer:": ":\u05ea\u05e9\u05d5\u05d1\u05d4",
    "Answered": "\u05e0\u05e2\u05e0\u05d4",
    "Answers are displayed within the problem": "\u05d4\u05ea\u05e9\u05d5\u05d1\u05d5\u05ea \u05de\u05d5\u05e6\u05d2\u05d5\u05ea \u05d1\u05ea\u05d5\u05da \u05d4\u05d1\u05e2\u05d9\u05d4",
    "Any Type": "\u05db\u05dc \u05e1\u05d5\u05d2",
    "Any additional information about the course that the platform needs or that allows integration with external systems such as CRM software. Enter a dictionary of values in JSON format, such as { \"my_custom_setting\": \"value\", \"other_setting\": \"value\" }": "\u05db\u05dc \u05de\u05d9\u05d3\u05e2 \u05e0\u05d5\u05e1\u05e3 \u05e2\u05dc \u05d4\u05e7\u05d5\u05e8\u05e1 \u05e9\u05d4\u05e4\u05dc\u05d8\u05e4\u05d5\u05e8\u05de\u05d4 \u05e6\u05e8\u05d9\u05db\u05d4 \u05d0\u05d5 \u05de\u05d0\u05e4\u05e9\u05e8 \u05d0\u05d9\u05e0\u05d8\u05d2\u05e8\u05e6\u05d9\u05d4 \u05e2\u05dd \u05de\u05e2\u05e8\u05db\u05d5\u05ea \u05d7\u05d9\u05e6\u05d5\u05e0\u05d9\u05d5\u05ea \u05db\u05de\u05d5 \u05ea\u05d5\u05db\u05e0\u05ea CRM. \u05d4\u05db\u05e0\u05d9\u05e1\u05d5 \u05e2\u05e8\u05db\u05d9 \u05de\u05d9\u05dc\u05d5\u05df \u05d1\u05e4\u05d5\u05e8\u05de\u05d8 JSON, \u05db\u05de\u05d5 { \"my_custom_setting\": \"value\", \"other_setting\": \"value\" }",
    "Any content that has listed this content as a prerequisite will also have access limitations removed.": "\u05d2\u05dd \u05d1\u05db\u05dc \u05ea\u05d5\u05db\u05df \u05e9\u05e8\u05e9\u05dd \u05ea\u05d5\u05db\u05df \u05d6\u05d4 \u05db\u05d3\u05e8\u05d9\u05e9\u05d4 \u05de\u05d5\u05e7\u05d3\u05de\u05ea \u05d9\u05d5\u05e1\u05e8\u05d5 \u05de\u05d2\u05d1\u05dc\u05d5\u05ea \u05d4\u05d2\u05d9\u05e9\u05d4.",
    "Any course progress or grades from your current session will be lost.": "\u05db\u05dc \u05d4\u05ea\u05e7\u05d3\u05de\u05d5\u05ea \u05d1\u05e7\u05d5\u05e8\u05e1 \u05d0\u05d5 \u05e6\u05d9\u05d5\u05e0\u05d9\u05dd \u05de\u05d4\u05e9\u05d9\u05e2\u05d5\u05e8 \u05d4\u05e0\u05d5\u05db\u05d7\u05d9 \u05e9\u05dc\u05db\u05dd \u05d9\u05d0\u05d1\u05d3\u05d5.",
    "Any divided discussion topics are divided based on cohort.": "\u05db\u05dc \u05e0\u05d5\u05e9\u05d0\u05d9 \u05d4\u05d3\u05d9\u05d5\u05e0\u05d9\u05dd \u05de\u05d7\u05d5\u05dc\u05e7\u05d9\u05dd \u05e2\u05dc \u05d1\u05e1\u05d9\u05e1 \u05e7\u05d1\u05d5\u05e6\u05d5\u05ea \u05d4\u05dc\u05de\u05d9\u05d3\u05d4",
    "Any divided discussion topics are divided based on enrollment track.": "\u05db\u05dc \u05e0\u05d5\u05e9\u05d0\u05d9 \u05d4\u05d3\u05d9\u05d5\u05df \u05d4\u05de\u05d7\u05d5\u05dc\u05e7\u05d9\u05dd \u05de\u05d7\u05d5\u05dc\u05e7\u05d9\u05dd \u05dc\u05e4\u05d9 \u05de\u05e1\u05dc\u05d5\u05dc \u05d4\u05d4\u05e8\u05e9\u05de\u05d4.",
    "Any group configurations": "\u05db\u05dc \u05ea\u05e6\u05d5\u05e8\u05d5\u05ea \u05e7\u05d1\u05d5\u05e6\u05ea\u05d9\u05d5\u05ea",
    "Any policies you modify here override all other information you've defined elsewhere in {studio_name}. Do not edit policies unless you are familiar with both their purpose and syntax.": "\u05de\u05d3\u05d9\u05e0\u05d9\u05d5\u05ea \u05e9\u05ea\u05e9\u05e0\u05d4 \u05db\u05d0\u05df, \u05ea\u05e2\u05e7\u05d5\u05e3 \u05d0\u05ea \u05db\u05dc \u05d4\u05de\u05d9\u05d3\u05e2 \u05e9\u05d4\u05d2\u05d3\u05e8\u05ea \u05d1\u05de\u05e7\u05d5\u05de\u05d5\u05ea \u05d0\u05d7\u05e8\u05d9\u05dd \u05d1{studio_name}. \u05d0\u05dc \u05ea\u05e2\u05e8\u05d5\u05da \u05de\u05d3\u05d9\u05e0\u05d9\u05d5\u05ea \u05d6\u05d5 \u05d0\u05dd \u05d0\u05d9\u05e0\u05da \u05de\u05db\u05d9\u05e8 \u05d0\u05ea \u05de\u05d8\u05e8\u05ea\u05d4 \u05d5\u05d0\u05ea \u05ea\u05d7\u05d1\u05d9\u05e8\u05d4.",
    "Appears on the course catalog page when students roll over the course name. Limit to ~150 characters": "\u05de\u05d5\u05e4\u05d9\u05e2 \u05d1\u05e2\u05de\u05d5\u05d3 \u05e7\u05d8\u05dc\u05d5\u05d2 \u05d4\u05e7\u05d5\u05e8\u05e1\u05d9\u05dd \u05db\u05d0\u05e9\u05e8 \u05e1\u05d8\u05d5\u05d3\u05e0\u05d8\u05d9\u05dd \u05de\u05e8\u05d7\u05e4\u05d9\u05dd \u05de\u05e2\u05dc \u05e9\u05dd \u05d4\u05e7\u05d5\u05e8\u05e1. \u05d4\u05d2\u05d1\u05dc \u05dc~150 \u05ea\u05d5\u05d5\u05d9\u05dd.  ",
    "Application Name": "\u05e9\u05dd \u05d4\u05d0\u05e4\u05dc\u05d9\u05e7\u05e6\u05d9\u05d4",
    "Applications or questions regarding the Website's activity can be sent byway of e-mail to": "\u05d1\u05db\u05dc \u05e4\u05e0\u05d9\u05d4 \u05d0\u05d5 \u05e9\u05d0\u05dc\u05d4 \u05d4\u05e0\u05d5\u05d2\u05e2\u05ea \u05dc\u05e4\u05e2\u05d9\u05dc\u05d5\u05ea \u05d4\u05d0\u05ea\u05e8, \u05e0\u05d9\u05ea\u05df \u05dc\u05e4\u05e0\u05d5\u05ea \u05d1\u05d0\u05de\u05e6\u05e2\u05d5\u05ea \u05db\u05ea\u05d5\u05d1\u05ea \u05d4\u05d3\u05d5\u05d0\"\u05dc.",
    "Apply for Financial Assistance": "\u05d4\u05d2\u05e9 \u05d1\u05e7\u05e9\u05d4 \u05dc\u05e2\u05d6\u05e8\u05d4 \u05db\u05e1\u05e4\u05d9\u05ea",
    "Approve grade": "\u05d0\u05d9\u05e9\u05d5\u05e8 \u05e6\u05d9\u05d5\u05df",
    "Approved": "\u05de\u05d0\u05d5\u05e9\u05e8",
    "April": "\u05d0\u05e4\u05e8\u05d9\u05dc",
    "Archived Courses": "\u05e7\u05d5\u05e8\u05e1\u05d9\u05dd \u05d1\u05d0\u05e8\u05db\u05d9\u05d5\u05df",
    "Are you having trouble finding a team to join?": "\u05d4\u05d0\u05dd \u05d0\u05ea\u05d4 \u05de\u05ea\u05e7\u05e9\u05d4 \u05dc\u05de\u05e6\u05d5\u05d0 \u05e6\u05d5\u05d5\u05ea \u05dc\u05d4\u05e6\u05d8\u05e8\u05e3 \u05d0\u05dc\u05d9\u05d5?",
    "Are you staff on an existing {studio_name} course?": "\u05d4\u05d0\u05dd \u05d0\u05ea\u05d4 \u05d7\u05d1\u05e8 \u05e6\u05d5\u05d5\u05ea \u05d1\u05e7\u05d5\u05e8\u05e1 \u05e7\u05d9\u05d9\u05dd \u05d1{studio_name}?",
    "Are you sure that you want to flag this submission?": "\u05d4\u05d0\u05dd \u05d0\u05ea\u05d4 \u05d1\u05d8\u05d5\u05d7 \u05e9\u05d0\u05ea\u05d4 \u05e8\u05d5\u05e6\u05d4 \u05dc\u05e1\u05de\u05df \u05d4\u05d2\u05e9\u05d4 \u05d6\u05d5?",
    "Are you sure that you want to leave this session?": "\u05d4\u05d0\u05dd \u05d0\u05ea\u05dd \u05d1\u05d8\u05d5\u05d7\u05d9\u05dd \u05e9\u05d1\u05e8\u05e6\u05d5\u05e0\u05db\u05dd \u05dc\u05e2\u05d6\u05d5\u05d1 \u05d0\u05ea \u05d4\u05e9\u05d9\u05e2\u05d5\u05e8 \u05d4\u05d6\u05d4?",
    "Are you sure you want to cancel retirement for user \"%(username)s\"? ": "\u05dc\u05d1\u05d8\u05dc \u05d0\u05ea \u05e4\u05e8\u05d9\u05e9\u05ea \u05d4\u05de\u05e9\u05ea\u05de\u05e9 \u201e%(username)s\u201d?",
    "Are you sure you want to change to a different session?": "\u05d4\u05d0\u05dd \u05d0\u05ea\u05dd \u05d1\u05d8\u05d5\u05d7\u05d9\u05dd \u05e9\u05d1\u05e8\u05e6\u05d5\u05e0\u05db\u05dd \u05dc\u05e2\u05d1\u05d5\u05e8 \u05dc\u05e9\u05d9\u05e2\u05d5\u05e8 \u05d0\u05d7\u05e8?",
