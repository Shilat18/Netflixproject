    "Complete our course feedback survey": "\u05d4\u05e9\u05dc\u05dd \u05d0\u05ea \u05e1\u05e7\u05e8 \u05d4\u05de\u05e9\u05d5\u05d1 \u05e9\u05dc \u05d4\u05e7\u05d5\u05e8\u05e1",
