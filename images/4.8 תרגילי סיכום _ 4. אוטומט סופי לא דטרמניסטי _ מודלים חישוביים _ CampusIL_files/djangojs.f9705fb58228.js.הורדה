    "Select True to request the user's username.": "\u05d1\u05d7\u05e8 \u05d1\u05d0\u05e4\u05e9\u05e8\u05d5\u05ea '\u05e0\u05db\u05d5\u05df' \u05e2\u05dc \u05de\u05e0\u05ea \u05dc\u05d1\u05e7\u05e9 \u05d0\u05ea \u05e9\u05dd \u05d4\u05de\u05e9\u05ea\u05de\u05e9 \u05e9\u05dc \u05d4\u05de\u05e9\u05ea\u05de\u05e9.",
    "Select Visual to enter content and have the editor automatically create the HTML. Select Raw to edit HTML directly. If you change this setting, you must save the component and then re-open it for editing.": "\u05d1\u05d7\u05e8 \u05ea\u05de\u05d5\u05e0\u05d4 \u05d0\u05dc\u05d9\u05d4 \u05d9\u05e9 \u05dc\u05d4\u05d6\u05d9\u05df \u05ea\u05d5\u05db\u05df \u05d5\u05d4\u05e2\u05d5\u05e8\u05da \u05d9\u05d1\u05e6\u05e2 \u05d1\u05d0\u05d5\u05e4\u05df \u05d0\u05d5\u05d8\u05d5\u05de\u05d8\u05d9 \u05d0\u05ea \u05d4-HTML. \u05d1\u05d7\u05e8 RAW \u05dc\u05e2\u05e8\u05d9\u05db\u05ea HTML \u05d9\u05e9\u05d9\u05e8\u05d5\u05ea. \u05d0\u05dd \u05d4\u05d2\u05d3\u05e8\u05d4 \u05d6\u05d5 \u05de\u05e9\u05ea\u05e0\u05d4, \u05e2\u05dc\u05d9\u05da \u05dc\u05e9\u05de\u05d5\u05e8 \u05d0\u05ea \u05d4\u05e8\u05db\u05d9\u05d1 \u05d5\u05dc\u05e4\u05ea\u05d5\u05d7 \u05d0\u05d5\u05ea\u05d5 \u05de\u05d7\u05d3\u05e9 \u05dc\u05e2\u05e8\u05d9\u05db\u05d4.",
    "Select a .tar.gz File to Replace Your Course Content": "\u05d1\u05d7\u05e8 \u05e7\u05d5\u05d1\u05e5  .tar.gz \u05dc\u05d4\u05d7\u05dc\u05e4\u05ea \u05ea\u05d5\u05db\u05df \u05d4\u05e7\u05d5\u05e8\u05e1 \u05e9\u05dc\u05da",
    "Select a .tar.gz File to Replace Your Library Content": "\u05d1\u05d7\u05e8 \u05e7\u05d5\u05d1\u05e5 .tar.gz \u05dc\u05d4\u05d7\u05dc\u05e4\u05ea \u05ea\u05d5\u05db\u05df \u05d4\u05e1\u05e4\u05e8\u05d9\u05d4 \u05e9\u05dc\u05da",
    "Select a Content Group": "\u05d1\u05d7\u05e8 \u05e7\u05d1\u05d5\u05e6\u05ea \u05ea\u05d5\u05db\u05df",
    "Select a Group Configuration": "\u05d1\u05d7\u05e8 \u05d4\u05d2\u05d3\u05e8\u05ea \u05e7\u05d1\u05d5\u05e6\u05d4",
    "Select a Library.": "\u05d1\u05d7\u05e8 \u05e1\u05e4\u05e8\u05d9\u05d4.",
    "Select a category": "\u05d1\u05d7\u05e8\u05d5 \u05e7\u05d8\u05d2\u05d5\u05e8\u05d9\u05d4",
    "Select a chapter": "\u05d1\u05d7\u05e8 \u05e4\u05e8\u05e7",
    "Select a cohort": "\u05d1\u05d7\u05e8 \u05e7\u05d1\u05d5\u05e6\u05ea \u05dc\u05d9\u05de\u05d5\u05d3",
    "Select a cohort to manage": "\u05d1\u05d7\u05e8 \u05e7\u05d1\u05d5\u05e6\u05ea \u05dc\u05d9\u05de\u05d5\u05d3 \u05dc\u05e0\u05d4\u05dc",
    "Select a component type under {strong_start}Add New Component{strong_end}. Then select a template.": "\u05d1\u05d7\u05e8 \u05e1\u05d5\u05d2 \u05e8\u05db\u05d9\u05d1 \u05d1{strong_start}\u05d4\u05d5\u05e1\u05e3 \u05e8\u05db\u05d9\u05d1 \u05e0\u05d5\u05e1\u05e3{strong_end}. \u05dc\u05d0\u05d7\u05e8 \u05de\u05db\u05df \u05d1\u05d7\u05e8 \u05ea\u05d1\u05e0\u05d9\u05ea.",
    "Select a course or select \"Not specific to a course\" for your support request.": "\u05d1\u05d7\u05e8\u05d5 \u05e7\u05d5\u05e8\u05e1 \u05d0\u05d5 \u05d1\u05d7\u05e8\u05d5 \"\u05dc\u05d0 \u05e1\u05e4\u05e6\u05d9\u05e4\u05d9 \u05dc\u05e7\u05d5\u05e8\u05e1\" \u05dc\u05d1\u05e7\u05e9\u05ea \u05d4\u05ea\u05de\u05d9\u05db\u05d4 \u05e9\u05dc\u05db\u05dd.",
    "Select a course team role:": "\u05d1\u05d7\u05e8 \u05ea\u05e4\u05e7\u05d9\u05d3 \u05e6\u05d5\u05d5\u05ea \u05d1\u05e7\u05d5\u05e8\u05e1:",
    "Select a file": "\u05d1\u05d7\u05d9\u05e8\u05ea \u05e7\u05d5\u05d1\u05e5",
    "Select a group type": "\u05e0\u05d0 \u05dc\u05d1\u05d7\u05d5\u05e8 \u05e1\u05d5\u05d2 \u05e7\u05d1\u05d5\u05e6\u05d4",
    "Select a prerequisite subsection and enter a minimum score percentage and minimum completion percentage to limit access to this subsection. Allowed values are 0-100": "\u05d1\u05d7\u05e8\u05d5 \u05ea\u05ea-\u05e1\u05e2\u05d9\u05e3 \u05d3\u05e8\u05d5\u05e9 \u05d5\u05d4\u05d6\u05d9\u05e0\u05d5 \u05d0\u05d7\u05d5\u05d6 \u05e6\u05d9\u05d5\u05df \u05de\u05d9\u05e0\u05d9\u05de\u05dc\u05d9 \u05d5\u05d0\u05d7\u05d5\u05d6 \u05d4\u05e9\u05dc\u05de\u05d4 \u05de\u05d9\u05e0\u05d9\u05de\u05dc\u05d9 \u05db\u05d3\u05d9 \u05dc\u05d4\u05d2\u05d1\u05d9\u05dc \u05d0\u05ea \u05d4\u05d2\u05d9\u05e9\u05d4 \u05dc\u05ea\u05ea-\u05e1\u05e2\u05d9\u05e3 \u05d6\u05d4. \u05d4\u05e2\u05e8\u05db\u05d9\u05dd \u05d4\u05de\u05d5\u05ea\u05e8\u05d9\u05dd \u05d4\u05dd 0-100",
    "Select a problem to generate a CSV         file that lists all student answers to the problem. You also select a section or chapter to include         results of all problems in that section or chapter.": "\u05d9\u05e9 \u05dc\u05d1\u05d7\u05d5\u05e8 \u05d1\u05e2\u05d9\u05d4 \u05db\u05dc\u05e9\u05d4\u05d9 \u05db\u05d3\u05d9 \u05dc\u05d9\u05e6\u05d5\u05e8 \u05e7\u05d5\u05d1\u05e5 csv \u05d4\u05de\u05e4\u05e8\u05d8 \u05d0\u05ea \u05db\u05dc \u05ea\u05e9\u05d5\u05d1\u05d5\u05ea \u05d4\u05dc\u05d5\u05de\u05d3\u05d9\u05dd \u05dc\u05d0\u05d5\u05ea\u05d4 \u05d1\u05e2\u05d9\u05d4 \u05e1\u05e4\u05e6\u05d9\u05e4\u05d9\u05ea. \u05e2\u05dc\u05d9\u05da \u05d2\u05dd \u05dc\u05d1\u05d7\u05d5\u05e8 \u05de\u05e7\u05d8\u05e2 \u05d0\u05d5 \u05e4\u05e8\u05e7 \u05db\u05d3\u05d9 \u05dc\u05db\u05dc\u05d5\u05dc \u05ea\u05d5\u05e6\u05d0\u05d5\u05ea \u05e9\u05dc \u05db\u05dc \u05d4\u05d1\u05e2\u05d9\u05d5\u05ea \u05d4\u05de\u05e9\u05d5\u05d9\u05d9\u05db\u05d5\u05ea \u05dc\u05d0\u05d5\u05ea\u05d5 \u05de\u05e7\u05d8\u05e2 \u05d0\u05d5 \u05e4\u05e8\u05e7.",
    "Select a problem to generate a CSV file that lists all student answers to the problem. You also select a section or chapter to include results of all problems in that section or chapter.": "\u05e6\u05e8\u05d5 \u05e7\u05d5\u05d1\u05e5 csv \u05d4\u05de\u05db\u05d9\u05dc \u05d0\u05ea \u05db\u05dc \u05ea\u05e9\u05d5\u05d1\u05d5\u05ea \u05d4\u05dc\u05d5\u05de\u05d3\u05d9\u05dd \u05d0\u05e9\u05e8 \u05d4\u05e9\u05d9\u05d1\u05d5 \u05e2\u05dc \u05d1\u05e2\u05d9\u05d4 \u05e1\u05e4\u05e6\u05d9\u05e4\u05d9\u05ea. \u05d1\u05d9\u05db\u05d5\u05dc\u05ea\u05db\u05dd \u05dc\u05d1\u05d7\u05d5\u05e8 \u05e4\u05e8\u05e7 \u05d0\u05d5 \u05d1\u05e2\u05d9\u05d4 \u05d1\u05db\u05d3\u05d9 \u05dc\u05db\u05dc\u05d5\u05dc \u05d0\u05ea \u05db\u05dc\u05dc \u05d4\u05ea\u05e9\u05d5\u05d1\u05d5\u05ea \u05d1\u05d7\u05dc\u05e7\u05d9\u05dd \u05d0\u05dc\u05d5 ",
    "Select a section or problem": "\u05d1\u05d7\u05e8\u05d5 \u05e4\u05e8\u05e7 \u05d0\u05d5 \u05d1\u05e2\u05d9\u05d4",
    "Select a session:": "\u05d1\u05d7\u05d9\u05e8\u05ea \u05e9\u05d9\u05e2\u05d5\u05e8:",
    "Select a subject for your support request.": "\u05d1\u05d7\u05e8\u05d5 \u05e0\u05d5\u05e9\u05d0 \u05dc\u05d1\u05e7\u05e9\u05ea \u05d4\u05ea\u05de\u05d9\u05db\u05d4 \u05e9\u05dc\u05db\u05dd.",
    "Select a time allotment for the exam. If it is over 24 hours, type in the amount of time. You can grant individual learners extra time to complete the exam through the Instructor Dashboard.": "\u05d1\u05d7\u05e8 \u05d1\u05d6\u05de\u05df \u05e9\u05d4\u05d5\u05e7\u05e6\u05d1 \u05dc\u05de\u05d1\u05d7\u05df. \u05d0\u05dd \u05d7\u05dc\u05e4\u05d5 24 \u05e9\u05e2\u05d5\u05ea, \u05d4\u05e7\u05dc\u05d3 \u05d0\u05ea \u05de\u05e9\u05da \u05d4\u05d6\u05de\u05df. \u05ea\u05d5\u05db\u05dc \u05dc\u05d4\u05e2\u05e0\u05d9\u05e7 \u05d6\u05de\u05df \u05e0\u05d5\u05e1\u05e3 \u05dc\u05dc\u05d5\u05de\u05d3\u05d9\u05dd \u05d0\u05d9\u05e0\u05d3\u05d9\u05d1\u05d9\u05d3\u05d5\u05d0\u05dc\u05d9\u05d9\u05dd \u05e2\u05dc \u05de\u05e0\u05ea \u05dc\u05d4\u05e9\u05dc\u05d9\u05dd \u05d0\u05ea \u05d4\u05de\u05d1\u05d7\u05df \u05d1\u05d0\u05de\u05e6\u05e2\u05d5\u05ea \u05dc\u05d5\u05d7 \u05d4\u05d1\u05e7\u05e8\u05d4 \u05e9\u05dc \u05d4\u05de\u05d3\u05e8\u05d9\u05da.",
    "Select all": "\u05d1\u05d7\u05e8 \u05d4\u05db\u05dc",
    "Select an option": "\u05d1\u05d7\u05d9\u05e8\u05ea \u05d0\u05e4\u05e9\u05e8\u05d5\u05ea",
    "Select another problem type.": "\u05d1\u05d7\u05e8 \u05e1\u05d5\u05d2 \u05d1\u05e2\u05d9\u05d4 \u05d0\u05d7\u05e8.",
    "Select current industry": "\u05d1\u05d7\u05d9\u05e8\u05ea \u05ea\u05e2\u05e1\u05d5\u05e7\u05d4 \u05e0\u05d5\u05db\u05d7\u05d9\u05ea",
    "Select employment status": "\u05d1\u05d7\u05d9\u05e8\u05ea \u05de\u05e6\u05d1 \u05ea\u05e2\u05e1\u05d5\u05e7\u05d4",
    "Select fidelity": "\u05d1\u05d7\u05d9\u05e8\u05ea \u05d3\u05d9\u05d5\u05e7",
    "Select gender": "\u05d1\u05d7\u05d9\u05e8\u05ea \u05de\u05d2\u05d3\u05e8",
    "Select guardian education": "\u05d1\u05d7\u05d9\u05e8\u05ea \u05d4\u05e9\u05db\u05dc\u05ea \u05de\u05d2\u05d3\u05dc\u05d9\u05dd",
    "Select income": "\u05d1\u05d7\u05d9\u05e8\u05ea \u05d4\u05db\u05e0\u05e1\u05d4",
    "Select language": "\u05d1\u05d7\u05d9\u05e8\u05ea \u05e9\u05e4\u05d4",
    "Select level of education": "\u05d1\u05d7\u05d9\u05e8\u05ea \u05d3\u05e8\u05d2\u05ea \u05d4\u05e9\u05db\u05dc\u05d4",
    "Select military status": "\u05d1\u05d7\u05d9\u05e8\u05ea \u05de\u05e6\u05d1 \u05e6\u05d1\u05d0\u05d9",
    "Select one or more groups:": "\u05e0\u05d0 \u05dc\u05d1\u05d7\u05d5\u05e8 \u05e7\u05d1\u05d5\u05e6\u05d4 \u05d0\u05d7\u05ea \u05d0\u05d5 \u05d9\u05d5\u05ea\u05e8:",
    "Select prospective industry": "\u05d1\u05d7\u05d9\u05e8\u05ea \u05ea\u05e2\u05e1\u05d5\u05e7\u05d4 \u05e8\u05e6\u05d5\u05d9\u05d4",
    "Select the Configure icon for a section or subsection to set its release date. When you configure a subsection, you can also set the grading policy and due date.": "\u05d1\u05d7\u05e8 \u05d0\u05ea \u05d0\u05d9\u05d9\u05e7\u05d5\u05df \u05d4\u05d4\u05d2\u05d3\u05e8\u05d5\u05ea \u05e9\u05dc \u05e4\u05e8\u05e7 \u05d0\u05d5 \u05ea\u05ea-\u05e4\u05e8\u05e7 \u05e2\u05dc \u05de\u05e0\u05ea \u05dc\u05d4\u05d2\u05d3\u05d9\u05e8 \u05ea\u05d0\u05e8\u05d9\u05da \u05e9\u05d7\u05e8\u05d5\u05e8. \u05db\u05d0\u05e9\u05e8 \u05d0\u05ea\u05d4 \u05de\u05d2\u05d3\u05d9\u05e8 \u05ea\u05ea-\u05e4\u05e8\u05e7, \u05d9\u05e9 \u05d1\u05d0\u05e4\u05e9\u05e8\u05d5\u05ea\u05da \u05dc\u05e7\u05d1\u05d5\u05e2 \u05ea\u05e7\u05e0\u05d5\u05df \u05e6\u05d9\u05d5\u05e0\u05d9\u05dd \u05d5\u05ea\u05d0\u05e8\u05d9\u05da \u05d9\u05e2\u05d3 \u05dc\u05d4\u05d2\u05e9\u05d4.   ",
    "Select the course for which you want to earn a verified certificate. If the course does not appear in the list, make sure that you have enrolled in the audit track for the course.": "\u05d1\u05d7\u05e8 \u05d0\u05ea \u05d4\u05e7\u05d5\u05e8\u05e1 \u05e9\u05d1\u05e8\u05e6\u05d5\u05e0\u05da \u05dc\u05e7\u05d1\u05dc \u05d1\u05d5 \u05ea\u05e2\u05d5\u05d3\u05d4 \u05de\u05d0\u05d5\u05de\u05ea\u05ea. \u05d0\u05dd \u05d4\u05e7\u05d5\u05e8\u05e1 \u05d0\u05d9\u05e0\u05d5 \u05de\u05d5\u05e4\u05d9\u05e2 \u05d1\u05e8\u05e9\u05d9\u05de\u05d4, \u05d5\u05d3\u05d0 \u05e9\u05e0\u05e8\u05e9\u05de\u05ea \u05d1\u05de\u05e1\u05dc\u05d5\u05dc \u05d4\u05e9\u05d5\u05de\u05e2 \u05d4\u05d7\u05d5\u05e4\u05e9\u05d9 \u05dc\u05e7\u05d5\u05e8\u05e1 \u05d6\u05d4.",
    "Select the course-wide discussion topics that you want to divide.": "\u05d1\u05d7\u05e8\u05d5 \u05d0\u05ea \u05d4\u05e0\u05d5\u05e9\u05d0\u05d9\u05dd \u05dc\u05d3\u05d9\u05d5\u05df \u05e9\u05d1\u05e8\u05e6\u05d5\u05e0\u05da \u05dc\u05d7\u05dc\u05e7 \u05dc\u05e4\u05d9 \u05d0\u05d5\u05db\u05dc\u05d5\u05e1\u05d9\u05d5\u05ea.",
    "Select the default license for course content": "\u05d1\u05d7\u05e8 \u05d1\u05e8\u05d9\u05e9\u05d9\u05d5\u05df \u05d1\u05e8\u05d9\u05e8\u05ea \u05d4\u05de\u05d7\u05d3\u05dc \u05dc\u05ea\u05d5\u05db\u05df \u05d4\u05e7\u05d5\u05e8\u05e1",
    "Select the highest level of education you have completed.": "\u05e0\u05d0 \u05dc\u05d1\u05d7\u05d5\u05e8 \u05d0\u05ea \u05d3\u05e8\u05d2\u05ea \u05d4\u05d4\u05e9\u05db\u05dc\u05d4 \u05d4\u05d2\u05d1\u05d5\u05d4\u05d4 \u05d1\u05d9\u05d5\u05ea\u05e8 \u05e9\u05e8\u05db\u05e9\u05ea.",
    "Select the library from which you want to draw content.": "\u05d1\u05d7\u05e8 \u05e1\u05e4\u05e8\u05d9\u05d4 \u05e9\u05de\u05de\u05e0\u05d4 \u05d0\u05ea\u05d4 \u05e8\u05d5\u05e6\u05d4 \u05dc\u05e9\u05dc\u05d5\u05e3 \u05d0\u05ea \u05d4\u05ea\u05d5\u05db\u05df.",
    "Select the time zone for displaying course dates. If you do not specify a time zone, course dates, including assignment deadlines, will be displayed in your browser's local time zone.": "\u05d1\u05d7\u05e8 \u05d0\u05ea \u05d0\u05d6\u05d5\u05e8 \u05d4\u05d6\u05de\u05df \u05dc\u05e6\u05d5\u05e8\u05da \u05ea\u05e6\u05d5\u05d2\u05ea \u05ea\u05d0\u05e8\u05d9\u05db\u05d9 \u05e7\u05d5\u05e8\u05e1. \u05d1\u05de\u05d9\u05d3\u05d4 \u05d5\u05dc\u05d0 \u05ea\u05e6\u05d9\u05d9\u05df \u05d0\u05ea \u05d0\u05d6\u05d5\u05e8 \u05d4\u05d6\u05de\u05df, \u05ea\u05d0\u05e8\u05d9\u05db\u05d9 \u05d4\u05e7\u05d5\u05e8\u05e1 \u05db\u05d5\u05dc\u05dc \u05ea\u05d0\u05e8\u05d9\u05db\u05d9 \u05d9\u05e2\u05d3 \u05e9\u05dc \u05de\u05e9\u05d9\u05de\u05d5\u05ea \u05d9\u05d5\u05e6\u05d2\u05d5 \u05d1\u05d3\u05e4\u05d3\u05e4\u05df \u05db\u05d0\u05d6\u05d5\u05e8 \u05d4\u05d6\u05de\u05df \u05d4\u05de\u05e7\u05d5\u05de\u05d9 \u05e9\u05dc\u05da.",
    "Select turnaround": "\u05d1\u05d7\u05d9\u05e8\u05ea \u05d6\u05de\u05df \u05d1\u05d9\u05e6\u05d5\u05e2",
    "Select your country or region of residence.": "\u05e0\u05d0 \u05dc\u05d1\u05d7\u05d5\u05e8 \u05d0\u05ea \u05de\u05d3\u05d9\u05e0\u05ea \u05d0\u05d5 \u05d0\u05d6\u05d5\u05e8 \u05d4\u05de\u05d2\u05d5\u05e8\u05d9\u05dd \u05e9\u05dc\u05da.",
    "Select your profession.": "\u05e0\u05d0 \u05dc\u05d1\u05d7\u05d5\u05e8 \u05d0\u05ea \u05d4\u05e2\u05d9\u05e1\u05d5\u05e7 \u05e9\u05dc\u05da.",
    "Select your specialty.": "\u05e0\u05d0 \u05dc\u05d1\u05d7\u05d5\u05e8 \u05d0\u05ea \u05d4\u05d4\u05ea\u05de\u05d7\u05d5\u05ea \u05e9\u05dc\u05da.",
