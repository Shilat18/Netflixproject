    "The following parameters are required: {missing}.": "\u05d4\u05de\u05e9\u05ea\u05e0\u05d9\u05dd \u05d4\u05d1\u05d0\u05d9\u05dd \u05e0\u05d7\u05d5\u05e6\u05d9\u05dd: {missing}.",
    "The following users are no longer enrolled in the course:": "\u05d4\u05de\u05e9\u05ea\u05de\u05e9\u05d9\u05dd \u05d4\u05d1\u05d0\u05d9\u05dd \u05db\u05d1\u05e8 \u05d0\u05d9\u05e0\u05dd \u05e8\u05e9\u05d5\u05de\u05d9\u05dd \u05dc\u05e7\u05d5\u05e8\u05e1:",
    "The following users do not exist: {usernames}.": "\u05d4\u05de\u05e9\u05ea\u05de\u05e9\u05d9\u05dd \u05d4\u05d1\u05d0\u05d9\u05dd \u05d0\u05d9\u05e0\u05dd \u05e7\u05d9\u05d9\u05de\u05d9\u05dd: {usernames}.",
    "The following warnings were generated:": "\u05d4\u05d0\u05d6\u05d4\u05e8\u05d5\u05ea \u05d4\u05d1\u05d0\u05d5\u05ea \u05e0\u05d5\u05e6\u05e8\u05d5:",
