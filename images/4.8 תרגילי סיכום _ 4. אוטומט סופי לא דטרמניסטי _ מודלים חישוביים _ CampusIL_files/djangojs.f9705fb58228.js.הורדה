    "I don't have the academic or language prerequisites": "\u05d0\u05d9\u05df \u05dc\u05d9 \u05d3\u05e8\u05d9\u05e9\u05d5\u05ea \u05e7\u05d3\u05dd \u05d0\u05e7\u05d3\u05de\u05d9\u05d5\u05ea \u05d0\u05d5 \u05e9\u05e4\u05d4",
    "I don't have the time": "\u05d0\u05d9\u05df \u05dc\u05d9 \u05d6\u05de\u05df",
