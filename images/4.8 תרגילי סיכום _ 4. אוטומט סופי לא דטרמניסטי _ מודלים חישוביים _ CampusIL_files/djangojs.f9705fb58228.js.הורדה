    "This answer is partially correct.": "\u05d4\u05ea\u05e9\u05d5\u05d1\u05d4 \u05e0\u05db\u05d5\u05e0\u05d4 \u05d1\u05d7\u05dc\u05e7\u05d4.",
    "This article cannot be deleted because it has children or is a root article.": "\u05de\u05d0\u05de\u05e8 \u05d6\u05d4 \u05d0\u05d9\u05e0\u05d5 \u05d9\u05db\u05d5\u05dc \u05dc\u05d4\u05d9\u05de\u05d7\u05e7 \u05de\u05db\u05d9\u05d5\u05d5\u05df \u05e9\u05d9\u05e9 \u05dc\u05d5 \u05de\u05d0\u05de\u05e8\u05d9 \u05de\u05e9\u05e0\u05d4 \u05d0\u05d5 \u05e9\u05d4\u05d9\u05e0\u05d5 \u05de\u05d0\u05de\u05e8 \u05d1\u05e1\u05d9\u05e1. ",
    "This article is currently locked for editing.": "\u05de\u05d0\u05de\u05e8 \u05d6\u05d4 \u05e0\u05e2\u05d5\u05dc \u05dc\u05e2\u05e8\u05d9\u05db\u05d4 \u05e0\u05db\u05d5\u05df \u05dc\u05e2\u05db\u05e9\u05d9\u05d5.",
    "This article is no longer related to the file %s.": "\u05de\u05d0\u05de\u05e8 \u05d6\u05d4 \u05d0\u05d9\u05e0\u05d5 \u05e7\u05e9\u05d5\u05e8 \u05d9\u05d5\u05ea\u05e8 \u05dc\u05e7\u05d5\u05d1\u05e5 %s.",
    "This article together with all its contents are now completely gone! Thanks!": "\u05de\u05d0\u05de\u05e8 \u05d6\u05d4 \u05d9\u05d7\u05d3 \u05e2\u05dd \u05db\u05dc \u05ea\u05d5\u05db\u05e0\u05d5 \u05d4\u05de\u05e7\u05d5\u05e9\u05e8 \u05e0\u05de\u05d7\u05e7 \u05dc\u05d7\u05dc\u05d5\u05d8\u05d9\u05df! \u05ea\u05d5\u05d3\u05d4!",
    "This article was last modified:": "\u05de\u05d0\u05de\u05e8 \u05d6\u05d4 \u05e9\u05d5\u05e0\u05d4 \u05dc\u05d0\u05d7\u05e8\u05d5\u05e0\u05d4:",
    "This assessment could not be submitted.": "\u05dc\u05d0 \u05e0\u05d9\u05ea\u05df \u05d4\u05d9\u05d4 \u05dc\u05d4\u05d2\u05d9\u05e9 \u05d0\u05ea \u05e4\u05e8\u05d9\u05d8 \u05d4\u05d4\u05e2\u05e8\u05db\u05d4 \u05d4\u05d6\u05d4.",
    "This assignment has not yet been graded.": "\u05d8\u05e8\u05dd \u05d4\u05ea\u05e7\u05d1\u05dc \u05e6\u05d9\u05d5\u05df \u05dc\u05d4\u05d2\u05e9\u05d4 \u05d6\u05d5",
    "This block contains multiple components.": "\u05d1\u05dc\u05d5\u05e7 \u05d6\u05d4 \u05de\u05db\u05d9\u05dc \u05e8\u05db\u05d9\u05d1\u05d9\u05dd \u05e8\u05d1\u05d9\u05dd",
    "This browser cannot play .mp4, .ogg, or .webm files.": "\u05d3\u05e4\u05d3\u05e4\u05df \u05d6\u05d4 \u05d0\u05d9\u05e0\u05d5 \u05d9\u05db\u05d5\u05dc \u05dc\u05e0\u05d2\u05df \u05e7\u05d1\u05e6\u05d9  ogg  .webm ,.mp4.",
    "This cannot be changed.": "\u05dc\u05d0 \u05e0\u05d9\u05ea\u05df \u05dc\u05e9\u05e0\u05d5\u05ea \u05d6\u05d0\u05ea.",
    "This cannot be left blank and will be recorded and presented in Enrollment Reports.": "\u05dc\u05d0 \u05e0\u05d9\u05ea\u05df \u05dc\u05d4\u05e9\u05d0\u05d9\u05e8 \u05e9\u05d3\u05d4 \u05d6\u05d4 \u05e8\u05d9\u05e7 \u05d5\u05d4\u05d3\u05d1\u05e8 \u05d9\u05d5\u05e7\u05dc\u05d8 \u05d5\u05d9\u05d5\u05e6\u05d2 \u05d1\u05d3\u05d5\u05d7\u05d5\u05ea \u05d4\u05d4\u05e8\u05e9\u05de\u05d4.",
    "This catalog's courses:": "\u05d4\u05e7\u05d5\u05e8\u05e1\u05d9\u05dd \u05d1\u05e7\u05d8\u05dc\u05d5\u05d2 \u05d6\u05d4:",
    "This certificate has already been activated and is live. Are you sure you want to continue editing?": "\u05ea\u05e2\u05d5\u05d3\u05d4 \u05d6\u05d5  \u05d4\u05d5\u05e4\u05e2\u05dc\u05d4 \u05db\u05d1\u05e8 \u05d5\u05d4\u05d9\u05d0 \u05d1\u05de\u05e6\u05d1 \u05e4\u05e2\u05d9\u05dc. \u05d4\u05d0\u05dd \u05d0\u05ea\u05d4 \u05d1\u05d8\u05d5\u05d7 \u05e9\u05d1\u05e8\u05e6\u05d5\u05e0\u05da \u05dc\u05d4\u05de\u05e9\u05d9\u05da \u05d1\u05e2\u05e8\u05d9\u05db\u05d4?",
    "This comment could not be deleted. Refresh the page and try again.": "\u05dc\u05d0 \u05e0\u05d9\u05ea\u05df \u05dc\u05de\u05d7\u05d5\u05e7 \u05d0\u05ea \u05d4\u05d4\u05e2\u05e8\u05d4. \u05e8\u05e2\u05e0\u05df \u05d0\u05ea \u05d4\u05e2\u05de\u05d5\u05d3 \u05d5\u05e0\u05e1\u05d4 \u05e9\u05e0\u05d9\u05ea.",
    "This component cannot be rescored.": "\u05dc\u05de\u05e8\u05db\u05d9\u05d1 \u05d6\u05d4 \u05dc\u05d0 \u05e0\u05d9\u05ea\u05df \u05dc\u05ea\u05ea \u05e6\u05d9\u05d5\u05df \u05de\u05d7\u05d3\u05e9.",
    "This component does not support score override.": "\u05d4\u05e8\u05db\u05d9\u05d1 \u05dc\u05d0 \u05ea\u05d5\u05de\u05da \u05d1\u05de\u05d7\u05d9\u05e7\u05d4 \u05d5\u05e8\u05d9\u05e9\u05d5\u05dd \u05de\u05d7\u05d3\u05e9 \u05e9\u05dc \u05e6\u05d9\u05d5\u05df.",
    "This component has no source components configured yet.": "\u05dc\u05e8\u05db\u05d9\u05d1 \u05d6\u05d4 \u05d0\u05d9\u05df \u05e2\u05d3\u05d9\u05d9\u05df \u05e8\u05db\u05d9\u05d1\u05d9 \u05de\u05e7\u05d5\u05e8 \u05de\u05d5\u05d2\u05d3\u05e8\u05d9\u05dd.",
    "This component has validation issues.": "\u05dc\u05e8\u05db\u05d9\u05d1 \u05d6\u05d4 \u05d1\u05e2\u05d9\u05d5\u05ea \u05d0\u05d9\u05de\u05d5\u05ea.",
    "This component is out of date. The library has new content.": "\u05de\u05e8\u05db\u05d9\u05d1 \u05d6\u05d4 \u05de\u05d9\u05d5\u05e9\u05df. \u05d9\u05e9\u05e0\u05d5 \u05ea\u05d5\u05db\u05df \u05d7\u05d3\u05e9 \u05d1\u05e1\u05e4\u05e8\u05d9\u05d4.",
    "This component's access settings contradict its parent's access settings.": "\u05d4\u05d2\u05d3\u05e8\u05d5\u05ea \u05d2\u05d9\u05e9\u05d4 \u05e9\u05dc \u05e8\u05db\u05d9\u05d1 \u05d6\u05d4 \u05e1\u05d5\u05ea\u05e8\u05d5\u05ea \u05d0\u05ea \u05d4\u05d2\u05d3\u05e8\u05d5\u05ea \u05d4\u05d2\u05d9\u05e9\u05d4 \u05e9\u05dc \u05d4\u05d4\u05d5\u05e8\u05d4 \u05e9\u05dc \u05e8\u05db\u05d9\u05d1 \u05d6\u05d4.",
    "This component's access settings refer to deleted or invalid group configurations.": "\u05d4\u05d2\u05d3\u05e8\u05d5\u05ea \u05d2\u05d9\u05e9\u05ea \u05d1\u05e8\u05db\u05d9\u05d1 \u05d6\u05d4 \u05de\u05ea\u05d9\u05d9\u05d7\u05e1\u05d5\u05ea \u05dc\u05e7\u05d1\u05d5\u05e6\u05ea \u05d4\u05d2\u05d3\u05e8\u05d5\u05ea \u05de\u05d7\u05d5\u05e7\u05d4 \u05d0\u05d5 \u05dc\u05d0 \u05ea\u05e7\u05d9\u05e0\u05d4.",
    "This component's access settings refer to deleted or invalid groups.": "\u05d4\u05d2\u05d3\u05e8\u05d5\u05ea \u05d2\u05d9\u05e9\u05d4 \u05d1\u05e8\u05db\u05d9\u05d1 \u05d6\u05d4 \u05de\u05ea\u05d9\u05d7\u05e1\u05d5\u05ea \u05dc\u05e7\u05d1\u05d5\u05e6\u05d4 \u05de\u05d7\u05d5\u05e7\u05d4 \u05d0\u05d5 \u05dc\u05d0 \u05ea\u05e7\u05d9\u05e0\u05d4.",
    "This configuration is currently used in content experiments. If you make changes to the groups, you may need to edit those experiments.": "\u05d4\u05d2\u05d3\u05e8\u05d4 \u05d6\u05d5 \u05e0\u05de\u05e6\u05d0\u05ea \u05db\u05e2\u05ea \u05d1\u05e9\u05d9\u05de\u05d5\u05e9 \u05e0\u05d9\u05e1\u05d5\u05d9 \u05ea\u05d5\u05db\u05df. \u05d0\u05dd \u05ea\u05e9\u05e0\u05d4 \u05d0\u05ea \u05d4\u05e7\u05d1\u05d5\u05e6\u05d5\u05ea, \u05d9\u05ea\u05db\u05df \u05e9\u05ea\u05e6\u05d8\u05e8\u05da \u05dc\u05d1\u05e6\u05e2 \u05e2\u05e8\u05d9\u05db\u05d4 \u05d1\u05e0\u05d9\u05e1\u05d5\u05d9\u05d9\u05dd \u05d0\u05dc\u05d5.",
    "This content experiment has issues that affect content visibility.": "\u05e7\u05d9\u05d9\u05de\u05d5\u05ea \u05d1\u05e2\u05d9\u05d5\u05ea \u05d1\u05e0\u05d9\u05e1\u05d5\u05d9 \u05ea\u05d5\u05db\u05df \u05d6\u05d4 \u05d4\u05de\u05e9\u05e4\u05d9\u05e2\u05d5\u05ea \u05e2\u05dc \u05d4\u05e6\u05d2\u05ea \u05d4\u05ea\u05d5\u05db\u05df.",
    "This content experiment uses group configuration '{group_configuration_name}'.": "\u05e0\u05d9\u05e1\u05d5\u05d9 \u05ea\u05d5\u05db\u05df \u05d6\u05d4 \u05e2\u05d5\u05e9\u05d4 \u05e9\u05d9\u05de\u05d5\u05e9 \u05d1\u05ea\u05e6\u05d5\u05e8\u05ea \u05e7\u05d1\u05d5\u05e6\u05ea '{group_configuration_name}'.",
    "This content group is in use and cannot be deleted.": "\u05e7\u05d1\u05d5\u05e6\u05ea \u05ea\u05d5\u05db\u05df \u05d6\u05d5 \u05e0\u05de\u05e6\u05d0\u05ea \u05d1\u05e9\u05d9\u05de\u05d5\u05e9 \u05d5\u05dc\u05d0 \u05e0\u05d9\u05ea\u05e0\u05ea \u05dc\u05de\u05d7\u05d9\u05e7\u05d4.",
    "This content group is used in one or more units.": "\u05e0\u05e2\u05e9\u05d4 \u05e9\u05d9\u05de\u05d5\u05e9 \u05d1\u05e7\u05d1\u05d5\u05e6\u05ea \u05ea\u05d5\u05db\u05df \u05d6\u05d5 \u05d1\u05d9\u05d7\u05d9\u05d3\u05d4 \u05d0\u05d7\u05ea \u05d0\u05d5 \u05d9\u05d5\u05ea\u05e8. ",
    "This content is graded": "\u05ea\u05d5\u05db\u05df \u05d6\u05d4 \u05de\u05e7\u05d1\u05dc \u05d3\u05d9\u05e8\u05d5\u05d2",
    "This content is only accessible to enrolled learners. ": "\u05ea\u05d5\u05db\u05df \u05d6\u05d4 \u05d6\u05de\u05d9\u05df \u05e8\u05e7 \u05dc\u05dc\u05d5\u05de\u05d3\u05d9\u05dd \u05e8\u05e9\u05d5\u05de\u05d9\u05dd.",
    "This content is only accessible to registered learners. Sign in or register to view it.": "\u05ea\u05d5\u05db\u05df \u05d6\u05d4 \u05d6\u05de\u05d9\u05df \u05e8\u05e7 \u05dc\u05dc\u05d5\u05de\u05d3\u05d9\u05dd \u05e8\u05e9\u05d5\u05de\u05d9\u05dd. \u05d4\u05d9\u05db\u05e0\u05e1\u05d5 \u05d0\u05d5 \u05d4\u05d9\u05e8\u05e9\u05de\u05d5 \u05db\u05d3\u05d9 \u05dc\u05e6\u05e4\u05d5\u05ea \u05d1\u05d5.",
    "This course does not have any updates.": "\u05dc\u05e7\u05d5\u05e8\u05e1 \u05d6\u05d4 \u05d0\u05d9\u05df \u05e2\u05d3\u05db\u05d5\u05e0\u05d9\u05dd.",
    "This course does not support content libraries. Contact your system administrator for more information.": "\u05e7\u05d5\u05e8\u05e1 \u05d6\u05d4 \u05d0\u05d9\u05e0\u05d5 \u05ea\u05d5\u05de\u05da \u05d1\u05e1\u05e4\u05e8\u05d9\u05d5\u05ea \u05ea\u05d5\u05db\u05df. \u05dc\u05de\u05d9\u05d3\u05e2 \u05e0\u05d5\u05e1\u05e3, \u05e6\u05d5\u05e8 \u05e7\u05e9\u05e8 \u05e2\u05dd \u05de\u05e0\u05d4\u05dc \u05d4\u05de\u05e2\u05e8\u05db\u05ea. ",
    "This course does not use a mode that offers certificates.": "\u05e7\u05d5\u05e8\u05e1 \u05d6\u05d4 \u05d0\u05d9\u05e0\u05d5 \u05de\u05e9\u05ea\u05de\u05e9 \u05d1\u05de\u05e6\u05d1 \u05d4\u05de\u05d0\u05e4\u05e9\u05e8 \u05ea\u05e2\u05d5\u05d3\u05d5\u05ea.",
    "This course doesn't support paid certificates": "\u05e7\u05d5\u05e8\u05e1 \u05d6\u05d4 \u05d0\u05d9\u05e0\u05d5 \u05ea\u05d5\u05de\u05da \u05d1\u05ea\u05e2\u05d5\u05d3\u05d5\u05ea \u05d1\u05ea\u05e9\u05dc\u05d5\u05dd.",
    "This course has automatic cohorting enabled for verified track learners, but cohorts are disabled. You must enable cohorts for the feature to work.": "\u05dc\u05e7\u05d5\u05e8\u05e1 \u05d6\u05d4 \u05d9\u05e9 \u05de\u05d7\u05d6\u05d5\u05e8 \u05dc\u05de\u05d9\u05d3\u05d4 \u05d0\u05d5\u05d8\u05d5\u05de\u05d8\u05d9 \u05e9\u05de\u05d5\u05e4\u05e2\u05dc \u05e2\u05d1\u05d5\u05e8 \u05dc\u05d5\u05de\u05d3\u05d9\u05dd \u05d1\u05de\u05e1\u05dc\u05d5\u05dc \u05de\u05d0\u05d5\u05de\u05ea, \u05d0\u05da \u05de\u05d7\u05d6\u05d5\u05e8\u05d9 \u05d4\u05dc\u05de\u05d9\u05d3\u05d4 \u05de\u05d5\u05e9\u05d1\u05ea\u05d9\u05dd. \u05e2\u05dc\u05d9\u05da \u05dc\u05d4\u05e4\u05e2\u05d9\u05dc \u05de\u05d7\u05d6\u05d5\u05e8\u05d9 \u05dc\u05de\u05d9\u05d3\u05d4 \u05db\u05d3\u05d9 \u05e9\u05d4\u05ea\u05db\u05d5\u05e0\u05d4 \u05ea\u05e2\u05d1\u05d5\u05d3.",
    "This course has automatic cohorting enabled for verified track learners, but the required cohort does not exist. You must create a manually-assigned cohort named '{verifiedCohortName}' for the feature to work.": "\u05dc\u05e7\u05d5\u05e8\u05e1 \u05d6\u05d4 \u05d9\u05e9 \u05de\u05d7\u05d6\u05d5\u05e8 \u05dc\u05de\u05d9\u05d3\u05d4 \u05d0\u05d5\u05d8\u05d5\u05de\u05d8\u05d9 \u05e9\u05de\u05d5\u05e4\u05e2\u05dc \u05e2\u05d1\u05d5\u05e8 \u05dc\u05d5\u05de\u05d3\u05d9\u05dd \u05d1\u05de\u05e1\u05dc\u05d5\u05dc \u05de\u05d0\u05d5\u05de\u05ea, \u05d0\u05da \u05de\u05d7\u05d6\u05d5\u05e8 \u05d4\u05dc\u05de\u05d9\u05d3\u05d4 \u05d4\u05d3\u05e8\u05d5\u05e9 \u05d0\u05d9\u05e0\u05d5 \u05e7\u05d9\u05d9\u05dd. \u05e2\u05dc\u05d9\u05da \u05dc\u05d9\u05e6\u05d5\u05e8 \u05de\u05d7\u05d6\u05d5\u05e8 \u05dc\u05de\u05d9\u05d3\u05d4 \u05e9\u05de\u05d5\u05e7\u05e6\u05d4 \u05d1\u05d0\u05d5\u05e4\u05df \u05d9\u05d3\u05e0\u05d9 \u05d4\u05de\u05db\u05d5\u05e0\u05d4 '{verifiedCohortName}' \u05db\u05d3\u05d9 \u05e9\u05d4\u05ea\u05db\u05d5\u05e0\u05d4 \u05ea\u05e2\u05d1\u05d5\u05d3.",
    "This course has proctored exam settings that are incomplete or invalid.": "\u05dc\u05e7\u05d5\u05e8\u05e1 \u05d6\u05d4 \u05d9\u05e9 \u05d4\u05d2\u05d3\u05e8\u05d5\u05ea \u05d1\u05d7\u05d9\u05e0\u05d5\u05ea \u05d1\u05d4\u05e9\u05d2\u05d7\u05d4 \u05e9\u05d0\u05d9\u05e0\u05df \u05e9\u05dc\u05de\u05d5\u05ea \u05d0\u05d5 \u05dc\u05d0 \u05d7\u05d5\u05e7\u05d9\u05d5\u05ea.",
    "This course is archived, which means you can review course content but it is no longer active.": "\u05e7\u05d5\u05e8\u05e1 \u05d6\u05d4 \u05d0\u05d5\u05d7\u05e1\u05df \u05d1\u05d0\u05e8\u05db\u05d9\u05d5\u05df, \u05db\u05dc\u05d5\u05de\u05e8 \u05d1\u05d0\u05e4\u05e9\u05e8\u05d5\u05ea\u05da \u05dc\u05e1\u05e7\u05d5\u05e8 \u05d0\u05ea \u05ea\u05d5\u05db\u05df \u05d4\u05e7\u05d5\u05e8\u05e1 \u05d0\u05da \u05d4\u05d5\u05d0 \u05d0\u05d9\u05e0\u05d5 \u05e4\u05e2\u05d9\u05dc \u05d9\u05d5\u05ea\u05e8.",
    "This course is configured to generate PDF certificates and this certificate type is no longer supported. Example certificates cannot be generated.": "\u05e7\u05d5\u05e8\u05e1 \u05d6\u05d4 \u05de\u05d5\u05d2\u05d3\u05e8 \u05dc\u05d4\u05e4\u05e7\u05ea \u05ea\u05e2\u05d5\u05d3\u05d5\u05ea PDF \u05d5\u05e1\u05d5\u05d2 \u05ea\u05e2\u05d5\u05d3\u05d4 \u05d6\u05d4 \u05d0\u05d9\u05e0\u05d5 \u05e0\u05ea\u05de\u05da \u05e2\u05d5\u05d3. \u05dc\u05d0 \u05e0\u05d9\u05ea\u05df \u05dc\u05d4\u05e4\u05d9\u05e7 \u05d0\u05d9\u05e9\u05d5\u05e8\u05d9\u05dd \u05dc\u05d3\u05d5\u05d2\u05de\u05d4.",
    "This course is ending in {time_remaining_string} at {course_end_time}.": "\u05d4\u05e7\u05d5\u05e8\u05e1 \u05de\u05e1\u05ea\u05d9\u05d9\u05dd \u05d1-{time_remaining_string} \u05d1-{course_end_time}.",
    "This course is ending in {time_remaining_string} on {course_end_date}.": "\u05d4\u05e7\u05d5\u05e8\u05e1 \u05de\u05e1\u05ea\u05d9\u05d9\u05dd \u05d1-{time_remaining_string} \u05d1-{course_end_date}.",
    "This course run is currently being created.": "\u05de\u05d7\u05d6\u05d5\u05e8 \u05dc\u05d9\u05de\u05d5\u05d3\u05d9\u05dd \u05d6\u05d4 \u05e0\u05d5\u05e6\u05e8 \u05db\u05e2\u05ea.",
    "This course uses a legacy storage format.": "\u05e7\u05d5\u05e8\u05e1 \u05d6\u05d4 \u05de\u05e9\u05ea\u05de\u05e9 \u05d1\u05e4\u05d5\u05e8\u05de\u05d8 \u05d0\u05d7\u05e1\u05d5\u05df \u05de\u05d3\u05d5\u05e8 \u05e7\u05d5\u05d3\u05dd.",
    "This course uses automatic cohorting for verified track learners. You cannot disable cohorts, and you cannot rename the manual cohort named '{verifiedCohortName}'. To change the configuration for verified track cohorts, contact your edX partner manager.": "\u05e7\u05d5\u05e8\u05e1 \u05d6\u05d4 \u05de\u05e9\u05ea\u05de\u05e9 \u05d1\u05de\u05d7\u05d6\u05d5\u05e8\u05d9 \u05dc\u05de\u05d9\u05d3\u05d4 \u05d0\u05d5\u05d8\u05d5\u05de\u05d8\u05d9\u05d9\u05dd \u05e2\u05d1\u05d5\u05e8 \u05dc\u05d5\u05de\u05d3\u05d9\u05dd \u05d1\u05de\u05e1\u05dc\u05d5\u05dc \u05de\u05d0\u05d5\u05de\u05ea. \u05d0\u05d9\u05e0\u05da \u05d9\u05db\u05d5\u05dc \u05dc\u05d4\u05e9\u05d1\u05d9\u05ea \u05de\u05d7\u05d6\u05d5\u05e8\u05d9 \u05dc\u05de\u05d9\u05d3\u05d4 \u05d5\u05d0\u05d9\u05e0\u05da \u05d9\u05db\u05d5\u05dc \u05dc\u05e9\u05e0\u05d5\u05ea \u05d0\u05ea \u05d4\u05e9\u05dd \u05e9\u05dc \u05de\u05d7\u05d6\u05d5\u05e8 \u05dc\u05de\u05d9\u05d3\u05d4 \u05d9\u05d3\u05e0\u05d9 \u05d4\u05de\u05db\u05d5\u05e0\u05d4 '{verifiedCohortName}'. \u05db\u05d3\u05d9 \u05dc\u05e9\u05e0\u05d5\u05ea \u05d0\u05ea \u05d4\u05d4\u05d2\u05d3\u05e8\u05d4 \u05dc\u05de\u05d7\u05d6\u05d5\u05e8\u05d9 \u05dc\u05de\u05d9\u05d3\u05d4 \u05e2\u05dd \u05de\u05e2\u05e7\u05d1 \u05de\u05d0\u05d5\u05de\u05ea, \u05e6\u05d5\u05e8 \u05e7\u05e9\u05e8 \u05e2\u05dd \u05d4\u05de\u05e0\u05d4\u05dc \u05d4\u05e9\u05d5\u05ea\u05e3 \u05e9\u05dc\u05da \u05d1-edX.",
    "This course uses features that are no longer supported.": "\u05e7\u05d5\u05e8\u05e1 \u05d6\u05d4 \u05de\u05e9\u05ea\u05de\u05e9 \u05d1\u05ea\u05db\u05d5\u05e0\u05d5\u05ea \u05e9\u05d0\u05d9\u05e0\u05df \u05e0\u05ea\u05de\u05db\u05d5\u05ea \u05d9\u05d5\u05ea\u05e8.",
    "This course was created as a re-run. Some manual configuration is needed.": "\u05e7\u05d5\u05e8\u05e1 \u05d6\u05d4 \u05e0\u05d5\u05e6\u05e8 \u05db\u05de\u05d7\u05d6\u05d5\u05e8 \u05dc\u05d9\u05de\u05d5\u05d3\u05d9\u05dd \u05d7\u05d3\u05e9. \u05d3\u05e8\u05d5\u05e9\u05d5\u05ea \u05ea\u05e6\u05d5\u05e8\u05d4 \u05d9\u05d3\u05e0\u05d9\u05ea \u05de\u05e1\u05d5\u05d9\u05de\u05ea.",
    "This course will remain on your dashboard, but you will no longer be part of the beta testing group.": "\u05d4\u05e7\u05d5\u05e8\u05e1 \u05d9\u05d9\u05e9\u05d0\u05e8 \u05d1\u05dc\u05d5\u05d7 \u05d4\u05d1\u05e7\u05e8\u05d4 \u05e9\u05dc\u05da \u05d0\u05da \u05dc\u05d0 \u05ea\u05d4\u05d9\u05d4 \u05d9\u05d5\u05ea\u05e8 \u05d7\u05dc\u05e7 \u05de\u05e7\u05d1\u05d5\u05e6\u05ea \u05d4\u05d1\u05d7\u05d9\u05e0\u05d4.  ",
    "This discussion could not be loaded. Refresh the page and try again.": "\u05dc\u05d0 \u05e0\u05d9\u05ea\u05df \u05dc\u05d4\u05e2\u05dc\u05d5\u05ea \u05d0\u05ea \u05d4\u05d3\u05d9\u05d5\u05df. \u05e8\u05e2\u05e0\u05df \u05d0\u05ea \u05d4\u05e2\u05de\u05d5\u05d3 \u05d5\u05e0\u05e1\u05d4 \u05e9\u05e0\u05d9\u05ea.",
    "This e-mail key is not valid. Please check:": "\u05d4\u05d5\u05d3\u05e2\u05ea \u05d3\u05d5\u05d0\u05e8 \u05d0\u05dc\u05e7\u05d8\u05e8\u05d5\u05e0\u05d9 \u05d6\u05d5 \u05d0\u05d9\u05e0\u05d4 \u05ea\u05e7\u05d9\u05e0\u05d4. \u05d0\u05e0\u05d0 \u05d1\u05d3\u05d5\u05e7:",
    "This email is already associated with an existing or previous {settings.PLATFORM_NAME} account": ":\u05db\u05ea\u05d5\u05d1\u05ea \u05d4\u05de\u05d9\u05d9\u05dc \u05e9\u05e0\u05d1\u05d7\u05e8\u05d4 \u05db\u05d1\u05e8 \u05e0\u05de\u05e6\u05d0\u05ea \u05d1\u05e9\u05d9\u05de\u05d5\u05e9 \u05d1 {settings.PLATFORM_NAME} . \u05d0\u05e0\u05d0 \u05d1\u05d7\u05e8 \u05db\u05ea\u05d5\u05d1\u05ea \u05de\u05d9\u05d9\u05dc \u05d0\u05d7\u05e8\u05ea.",
    "This email message was automatically sent by {lms_url} because someone attempted to create an account on {platform_name_tag} using this email address.": "\u05d4\u05d5\u05d3\u05e2\u05d4 \u05d6\u05d5 \u05e0\u05e9\u05dc\u05d7\u05d4 \u05d1\u05d0\u05d5\u05e4\u05df \u05d0\u05d5\u05d8\u05d5\u05de\u05d8\u05d9 \u05e2\u05dc \u05d9\u05d3\u05d9 {lms_url}, \u05dc\u05d0\u05d7\u05e8 \u05e9\u05e0\u05d5\u05e6\u05e8 \u05d7\u05e9\u05d1\u05d5\u05df \u05d1{platform_name_tag} \u05d1\u05d0\u05de\u05e6\u05e2\u05d5\u05ea \u05db\u05ea\u05d5\u05d1\u05ea \u05d3\u05d5\u05d0\"\u05dc \u05d6\u05d5.",
    "This email message was automatically sent by {site_name}, after a {platform_name_tag} account with this email address was created.": "\u05d4\u05d5\u05d3\u05e2\u05d4 \u05d6\u05d5 \u05e0\u05e9\u05dc\u05d7\u05d4 \u05d1\u05d0\u05d5\u05e4\u05df \u05d0\u05d5\u05d8\u05d5\u05de\u05d8\u05d9 \u05e2\u05dc \u05d9\u05d3\u05d9 {site_name}, \u05dc\u05d0\u05d7\u05e8 \u05e9\u05e0\u05d5\u05e6\u05e8 \u05d7\u05e9\u05d1\u05d5\u05df \u05d1 {platform_name_tag} \u05d1\u05d0\u05de\u05e6\u05e2\u05d5\u05ea \u05de\u05d9\u05d9\u05dc \u05d6\u05d4.",
    "This email was automatically sent from %(platform_name)s to %(full_name)s.": "\u05de\u05d9\u05d9\u05dc \u05d6\u05d4 \u05e0\u05e9\u05dc\u05d7 \u05d1\u05d0\u05d5\u05e4\u05df \u05d0\u05d5\u05d8\u05d5\u05de\u05d8\u05d9 \u05de- %(platform_name)s\u05d0\u05dc %(full_name)s.",
    "This email was automatically sent from %(site_name)s to %(email_address)s": "\u05d4\u05d5\u05d3\u05e2\u05ea \u05de\u05d9\u05d9\u05dc \u05d6\u05d5 \u05e0\u05e9\u05dc\u05d7\u05d4 \u05d1\u05d0\u05d5\u05e4\u05df \u05d0\u05d5\u05d8\u05d5\u05de\u05d8\u05d9 \u05de-%(site_name)s \u05dc-%(email_address)s",
    "This email was automatically sent from %(site_name)s to %(full_name)s": "\u05d4\u05de\u05d9\u05d9\u05dc \u05e0\u05e9\u05dc\u05d7 \u05d0\u05d5\u05d8\u05d5\u05de\u05d8\u05d9 \u05de\u05d4\u05d0\u05ea\u05e8 %(site_name)s \u05dc %(full_name)s.\n\u05dc\u05de\u05d9\u05d3\u05e2 \u05e0\u05d5\u05e1\u05e3 \u05e0\u05d9\u05ea\u05df \u05dc\u05e4\u05e0\u05d5\u05ea \u05dc\u05ea\u05de\u05d9\u05db\u05d4 \u05d1\u05de\u05d9\u05d9\u05dc: Campus@mail.gov.il",
    "This exam has a time limit associated with it.": "\u05dc\u05de\u05d1\u05d7\u05df \u05d6\u05d4 \u05d9\u05e9 \u05de\u05d2\u05d1\u05dc\u05ea \u05d6\u05de\u05df.",
    "This exam is hidden from the learner.": "\u05de\u05d1\u05d7\u05df \u05d6\u05d4 \u05d7\u05e1\u05d5\u05d9 \u05dc\u05dc\u05d5\u05de\u05d3.",
    "This feedback could not be submitted.": "\u05dc\u05d0 \u05e0\u05d9\u05ea\u05df \u05d4\u05d9\u05d4 \u05dc\u05d4\u05d2\u05d9\u05e9 \u05d0\u05ea \u05d4\u05de\u05e9\u05d5\u05d1.",
    "This field is disabled: this information cannot be changed.": "\u05e9\u05d3\u05d4 \u05d6\u05d4 \u05d0\u05d9\u05e0\u05d5 \u05e4\u05e2\u05d9\u05dc: \u05dc\u05d0 \u05e0\u05d9\u05ea\u05df \u05dc\u05e9\u05e0\u05d5\u05ea \u05d0\u05ea \u05d4\u05de\u05d9\u05d3\u05e2.",
    "This field is not editable": "\u05e9\u05d3\u05d4 \u05d6\u05d4 \u05d0\u05d9\u05e0\u05d5 \u05e0\u05d9\u05ea\u05df \u05dc\u05e2\u05e8\u05d9\u05db\u05d4",
    "This field, together with certificate_available_date will determine when a user can see their certificate for the course": "\u05e9\u05d3\u05d4 \u05d6\u05d4, \u05d1\u05d9\u05d7\u05d3 \u05e2\u05dd certificate_available_date \u05d9\u05d9\u05e7\u05d1\u05e2 \u05de\u05ea\u05d9 \u05de\u05e9\u05ea\u05de\u05e9\u05d9\u05dd \u05d9\u05db\u05d5\u05dc\u05d9\u05dd \u05dc\u05e8\u05d0\u05d5\u05ea \u05d0\u05ea \u05d4\u05ea\u05e2\u05d5\u05d3\u05d4 \u05e9\u05dc\u05d4\u05dd \u05e2\u05d1\u05d5\u05e8 \u05e7\u05d5\u05e8\u05e1 \u05d6\u05d4",
    "This file type is not supported. Supported file type is {supportedFileFormat}.": "\u05e1\u05d5\u05d2 \u05e7\u05d5\u05d1\u05e5 \u05d6\u05d4 \u05d0\u05d9\u05e0\u05d5 \u05e0\u05ea\u05de\u05da. \u05e1\u05d5\u05d2 \u05d4\u05e7\u05d5\u05d1\u05e5 \u05d4\u05e0\u05ea\u05de\u05da \u05d4\u05d5\u05d0 {supportedFileFormat}.",
    "This group configuration is in use and cannot be deleted.": "\u05d4\u05d2\u05d3\u05e8\u05ea \u05e7\u05d1\u05d5\u05e6\u05d4 \u05d6\u05d5 \u05e0\u05de\u05e6\u05d0\u05ea \u05d1\u05e9\u05d9\u05de\u05d5\u05e9 \u05d5\u05dc\u05d0 \u05e0\u05d9\u05ea\u05e0\u05ea \u05dc\u05de\u05d7\u05d9\u05e7\u05d4.",
    "This group controls access to:": "\u05e7\u05d1\u05d5\u05e6\u05d4 \u05d6\u05d5 \u05e9\u05d5\u05dc\u05d8\u05ea \u05d1\u05d2\u05d9\u05e9\u05d4 \u05dc:",
    "This group no longer exists.  Choose another group or remove the access restriction.": "\u05d4\u05e7\u05d1\u05d5\u05e6\u05d4 \u05d4\u05d6\u05d5 \u05db\u05d1\u05e8 \u05dc\u05d0 \u05e7\u05d9\u05d9\u05de\u05ea. \u05d1\u05d7\u05e8\u05d5 \u05e7\u05d1\u05d5\u05e6\u05d4 \u05d0\u05d7\u05e8\u05ea \u05d0\u05d5 \u05d4\u05e1\u05d9\u05e8\u05d5 \u05d0\u05ea \u05d4\u05d2\u05d1\u05dc\u05ea \u05d4\u05d2\u05d9\u05e9\u05d4.",
    "This group no longer exists. Choose another group or do not restrict access to this unit.": "\u05d4\u05e7\u05d1\u05d5\u05e6\u05d4 \u05d4\u05d6\u05d5 \u05dc\u05d0 \u05e7\u05d9\u05d9\u05de\u05ea \u05e2\u05d5\u05d3. \u05e0\u05d0 \u05dc\u05d1\u05d7\u05d5\u05e8 \u05d1\u05e7\u05d1\u05d5\u05e6\u05d4 \u05d0\u05d7\u05e8\u05ea \u05d0\u05d5 \u05dc\u05d1\u05d8\u05dc \u05d0\u05ea \u05d4\u05d2\u05d1\u05dc\u05ea \u05d4\u05d2\u05d9\u05e9\u05d4 \u05dc\u05d9\u05d7\u05d9\u05d3\u05d4 \u05d4\u05d6\u05d0\u05ea.",
    "This image file must be larger than {image_min_size}.": "\u05e7\u05d5\u05d1\u05e5 \u05ea\u05de\u05d5\u05e0\u05d4 \u05d6\u05d4 \u05d7\u05d9\u05d9\u05d1 \u05dc\u05d4\u05d9\u05d5\u05ea \u05d2\u05d3\u05d5\u05dc \u05de-{image_min_size}.",
    "This image file must be smaller than {image_max_size}.": "\u05e7\u05d5\u05d1\u05e5 \u05ea\u05de\u05d5\u05e0\u05d4 \u05d6\u05d4 \u05d7\u05d9\u05d9\u05d1 \u05dc\u05d4\u05d9\u05d5\u05ea \u05e7\u05d8\u05df \u05de-{image_max_size}.",
    "This image file must have an aspect ratio of {video_image_aspect_ratio_text}.": "\u05e7\u05d5\u05d1\u05e5 \u05ea\u05de\u05d5\u05e0\u05d4 \u05d6\u05d4 \u05d7\u05d9\u05d9\u05d1 \u05dc\u05d4\u05d9\u05d5\u05ea \u05d1\u05e2\u05dc \u05d9\u05d7\u05e1 \u05e8\u05d5\u05d7\u05d1-\u05d2\u05d5\u05d1\u05d4 \u05e9\u05dc {video_image_aspect_ratio_text}.",
    "This image file type is not supported. Supported file types are {supportedFileFormats}.": "\u05e1\u05d5\u05d2 \u05e7\u05d5\u05d1\u05e5 \u05ea\u05de\u05d5\u05e0\u05d4 \u05d6\u05d4 \u05d0\u05d9\u05e0\u05d5 \u05e0\u05ea\u05de\u05da. \u05e1\u05d5\u05d2\u05d9 \u05d4\u05e7\u05d1\u05e6\u05d9\u05dd \u05d4\u05e0\u05ea\u05de\u05db\u05d9\u05dd \u05d4\u05dd {supportedFileFormats}.",
    "This image file type is not supported. Supported file types are {supported_file_formats}.": "\u05e1\u05d5\u05d2 \u05e7\u05d5\u05d1\u05e5 \u05ea\u05de\u05d5\u05e0\u05d4 \u05d6\u05d4 \u05d0\u05d9\u05e0\u05d5 \u05e0\u05ea\u05de\u05da. \u05e1\u05d5\u05d2\u05d9 \u05d4\u05e7\u05d1\u05e6\u05d9\u05dd \u05d4\u05e0\u05ea\u05de\u05db\u05d9\u05dd \u05d4\u05dd {supported_file_formats}.",
    "This image is for decorative purposes only and does not require a description.": "\u05ea\u05de\u05d5\u05e0\u05d4 \u05d6\u05d5 \u05e0\u05d5\u05e2\u05d3\u05d4 \u05dc\u05de\u05d8\u05e8\u05d5\u05ea \u05d3\u05e7\u05d5\u05e8\u05d8\u05d9\u05d1\u05d9\u05d5\u05ea \u05d1\u05dc\u05d1\u05d3 \u05d5\u05d0\u05d9\u05df \u05e6\u05d5\u05e8\u05da \u05d1\u05ea\u05d9\u05d0\u05d5\u05e8\u05d4.",
    "This includes access to {siteName} from your employer\u2019s or university\u2019s system{additionalSiteSpecificDeletionText}.": "\u05d4\u05d3\u05d1\u05e8 \u05db\u05d5\u05dc\u05dc \u05d2\u05dd \u05db\u05e0\u05d9\u05e1\u05d4 \u05dc\u05d0\u05ea\u05e8 {siteName} \u05d3\u05e8\u05da \u05d4\u05de\u05e2\u05e8\u05db\u05ea \u05e9\u05dc \u05d4\u05de\u05e2\u05e1\u05d9\u05e7 \u05e9\u05dc\u05db\u05dd \u05d0\u05d5 \u05e9\u05dc \u05d4\u05d0\u05d5\u05e0\u05d9\u05d1\u05e8\u05e1\u05d9\u05d8\u05d4 \u05e9\u05dc\u05db\u05dd  \u05d5\u05db\u05df \u05db\u05e0\u05d9\u05e1\u05d4 \u05dc\u05d0\u05ea\u05e8\u05d9\u05dd \u05e4\u05e8\u05d8\u05d9\u05d9\u05dd \u05d4\u05de\u05d5\u05e6\u05e2\u05d9\u05dd \u05de\u05d8\u05e2\u05dd{additionalSiteSpecificDeletionText}.",
    "This is a private discussion. You do not have permissions to view this discussion": "\u05d6\u05d4\u05d5 \u05d3\u05d9\u05d5\u05df \u05e4\u05e8\u05d8\u05d9. \u05d0\u05d9\u05df \u05dc\u05db\u05dd \u05d4\u05e8\u05e9\u05d0\u05d5\u05ea \u05dc\u05e6\u05e4\u05d5\u05ea \u05d1\u05d3\u05d9\u05d5\u05df \u05d4\u05d6\u05d4",
    "This is a routed Account Activation email for %(routed_user)s (%(routed_user_email)s): %(routed_profile_name)s": "\u05d6\u05d4\u05d5 \u05de\u05d9\u05d9\u05dc \u05dc\u05d4\u05e4\u05e2\u05dc\u05ea \u05d4\u05d7\u05e9\u05d1\u05d5\u05df \u05e2\u05d1\u05d5\u05e8 %(routed_user)s (%(routed_user_email)s): %(routed_profile_name)s",
    "This is a screen reader-friendly problem.": "\u05d6\u05d5 \u05d1\u05e2\u05d9\u05d4 \u05d9\u05d3\u05d9\u05d3\u05d5\u05ea\u05d9\u05ea \u05dc\u05e7\u05d5\u05e8\u05d0 \u05de\u05e1\u05da.",
    "This is a success message": "\u05d6\u05d5 \u05d4\u05d5\u05d3\u05e2\u05ea \u05d4\u05e6\u05dc\u05d7\u05d4",
    "This is a test error": "\u05d6\u05d5 \u05e9\u05d2\u05d9\u05d0\u05d4 \u05dc\u05d1\u05d3\u05d9\u05e7\u05d4",
    "This is a test message": "\u05d6\u05d5 \u05d4\u05d5\u05d3\u05e2\u05ea \u05d1\u05d3\u05d9\u05e7\u05d4",
    "This is a test warning": "\u05d6\u05d5 \u05d0\u05d6\u05d4\u05e8\u05d4 \u05dc\u05d1\u05d3\u05d9\u05e7\u05d4",
    "This is a valid {platform_name} certificate for {user_name}, who participated in {partner_short_name} {course_number}": "\u05d6\u05d5 \u05ea\u05e2\u05d5\u05d3\u05d4 \u05d7\u05d5\u05e7\u05d9\u05ea \u05e9\u05dc {platform_name} \u05e2\u05d1\u05d5\u05e8 {user_name}, \u05e9\u05d4\u05e9\u05ea\u05ea\u05e3 \u05d1-{partner_short_name} {course_number}",
    "This is an informational email only. If you did not initiate this request, please contact %(contact_email)s.": "\u05d6\u05d4\u05d5 \u05de\u05d9\u05d9\u05dc \u05dc\u05d9\u05d9\u05d3\u05d5\u05e2 \u05d1\u05dc\u05d1\u05d3. \u05d0\u05dd \u05dc\u05d0 \u05d9\u05d6\u05de\u05ea\u05dd \u05d1\u05e7\u05e9\u05d4 \u05d6\u05d5, \u05d0\u05e0\u05d0 \u05e6\u05e8\u05d5 \u05e7\u05e9\u05e8 \u05e2\u05dd %(contact_email)s.",
    "This is just the initial contents of your article. After creating it, you can use more complex features like adding plugins, meta data, related articles etc...": "\u05d6\u05d4\u05d5 \u05e8\u05e7 \u05ea\u05d5\u05db\u05df \u05d4\u05ea\u05d7\u05dc\u05ea\u05d9 \u05dc\u05de\u05d0\u05de\u05e8. \u05dc\u05d0\u05d7\u05e8 \u05d9\u05e6\u05d9\u05e8\u05ea\u05d5, \u05ea\u05d5\u05db\u05dc \u05dc\u05e2\u05e9\u05d5\u05ea \u05e9\u05d9\u05de\u05d5\u05e9 \u05d1\u05d0\u05e4\u05e9\u05e8\u05d5\u05d9\u05d5\u05ea \u05de\u05d5\u05e8\u05db\u05d1\u05d5\u05ea \u05d9\u05d5\u05ea\u05e8 \u05db\u05d3\u05d5\u05d2\u05de\u05ea \u05d4\u05d5\u05e1\u05e4\u05ea \u05ea\u05d5\u05e1\u05e4\u05d9\u05dd, \u05de\u05d8\u05d0-\u05d3\u05d0\u05d8\u05d4, \u05de\u05d0\u05de\u05e8\u05d9\u05dd \u05e7\u05e9\u05d5\u05e8\u05d9\u05dd \u05d5\u05e2\u05d5\u05d3...",
    "This is the Description of the Group Configuration": "\u05d6\u05d4\u05d5 \u05ea\u05d9\u05d0\u05d5\u05e8 \u05d4\u05d2\u05d3\u05e8\u05ea \u05d4\u05e7\u05d1\u05d5\u05e6\u05d4",
    "This is the Name of the Group Configuration": "\u05d6\u05d4\u05d5 \u05e9\u05dd \u05d4\u05d2\u05d3\u05e8\u05ea \u05d4\u05e7\u05d1\u05d5\u05e6\u05d4",
    "This is the bulk SKU (stock keeping unit) of this mode in the external ecommerce service.": "\u05d6\u05d5\u05d4\u05d9 \u05d4-SKU (\u05d9\u05d7\u05d9\u05d3\u05ea \u05d0\u05d7\u05d6\u05e7\u05ea \u05de\u05dc\u05d0\u05d9) \u05e9\u05dc \u05de\u05e6\u05d1 \u05d6\u05d4 \u05d1\u05e9\u05d9\u05e8\u05d5\u05ea \u05d4\u05de\u05e1\u05d7\u05e8 \u05d4\u05d0\u05dc\u05e7\u05d8\u05e8\u05d5\u05e0\u05d9 \u05d4\u05d7\u05d9\u05e6\u05d5\u05e0\u05d9.",
    "This is the e-mail address you used to register with {platform}": "\u05d6\u05d5 \u05db\u05ea\u05d5\u05d1\u05ea \u05d4\u05d3\u05d5\u05d0\u05e8 \u05d4\u05d0\u05dc\u05e7\u05d8\u05e8\u05d5\u05e0\u05d9 \u05d0\u05d9\u05ea\u05d4 \u05e0\u05e8\u05e9\u05de\u05ea \u05dc{platform}",
    "This is the list of available %s. You may choose some by selecting them in the box below and then clicking the \"Choose\" arrow between the two boxes.": "\u05d6\u05d5 \u05e8\u05e9\u05d9\u05de\u05ea %s \u05d4\u05d6\u05de\u05d9\u05e0\u05d9\u05dd \u05dc\u05d1\u05d7\u05d9\u05e8\u05d4. \u05e0\u05d9\u05ea\u05df \u05dc\u05d1\u05d7\u05d5\u05e8 \u05d7\u05dc\u05e7 \u05e2\"\u05d9 \u05e1\u05d9\u05de\u05d5\u05df \u05d1\u05ea\u05d9\u05d1\u05d4 \u05de\u05ea\u05d7\u05ea \u05d5\u05dc\u05d7\u05d9\u05e6\u05d4 \u05e2\u05dc \u05d7\u05e5  \"\u05d1\u05d7\u05e8\" \u05d1\u05d9\u05df \u05e9\u05ea\u05d9 \u05d4\u05ea\u05d9\u05d1\u05d5\u05ea.",
    "This is the list of chosen %s. You may remove some by selecting them in the box below and then clicking the \"Remove\" arrow between the two boxes.": "\u05d6\u05d5 \u05e8\u05e9\u05d9\u05de\u05ea %s \u05d0\u05e9\u05e8 \u05e0\u05d1\u05d7\u05e8\u05d5. \u05e0\u05d9\u05ea\u05df \u05dc\u05d4\u05e1\u05d9\u05e8 \u05d7\u05dc\u05e7 \u05e2\"\u05d9 \u05d1\u05d7\u05d9\u05e8\u05d4 \u05d1\u05ea\u05d9\u05d1\u05d4 \u05de\u05ea\u05d7\u05ea \u05d5\u05dc\u05d7\u05d9\u05e6\u05d4 \u05e2\u05dc \u05d7\u05e5 \"\u05d4\u05e1\u05e8\u05d4\" \u05d1\u05d9\u05df \u05e9\u05ea\u05d9 \u05d4\u05ea\u05d9\u05d1\u05d5\u05ea.",
    "This is the name of the group": "\u05d6\u05d4\u05d5 \u05e9\u05dd \u05d4\u05e7\u05d1\u05d5\u05e6\u05d4",
    "This is the wiki for **{organization}**'s _{course_name}_.": "\u05d6\u05d4\u05d5 wiki \u05e2\u05d1\u05d5\u05e8 **{organization}** \u05dc\u05e7\u05d5\u05e8\u05e1 _{course_name}_.",
    "This is to confirm that you changed the e-mail associated with %(platform_name_tag)s from %(old_email)s to %(new_email)s. If you did not make this request, please contact us immediately. Contact information is listed at:": "\u05d6\u05d5\u05d4\u05d9 \u05d4\u05d5\u05d3\u05e2\u05d4 \u05dc\u05d0\u05e9\u05e8 \u05db\u05d9 \u05d4\u05d7\u05dc\u05e4\u05ea \u05d0\u05ea \u05db\u05ea\u05d5\u05d1\u05ea \u05d4\u05d3\u05d5\u05d0\u05e8 \u05d4\u05d0\u05dc\u05e7\u05d8\u05e8\u05d5\u05e0\u05d9 \u05d4\u05de\u05e7\u05d5\u05e9\u05e8\u05ea \u05dc\u05d7\u05e9\u05d1\u05d5\u05df %(platform_name_tag)s \u05de-%(old_email)s \u05dc-%(new_email)s. \u05d0\u05dd \u05dc\u05d0 \u05d1\u05d9\u05e7\u05e9\u05ea \u05d0\u05ea \u05d4\u05e9\u05d9\u05e0\u05d5\u05d9 \u05d4\u05e0\"\u05dc, \u05e0\u05d0 \u05e6\u05d5\u05e8 \u05e2\u05de\u05e0\u05d5 \u05e7\u05e9\u05e8 \u05d1\u05d0\u05d5\u05e4\u05df \u05de\u05d9\u05d9\u05d3\u05d9. \u05d3\u05e8\u05db\u05d9 \u05e7\u05e9\u05e8 \u05e8\u05e9\u05d5\u05de\u05d5\u05ea \u05d1:",
    "This is to confirm that you changed the e-mail associated with {platform_name_tag} from {old_email} to {new_email}. If you did not make this request, please contact us at": "\u05d6\u05d5\u05d4\u05d9 \u05d4\u05d5\u05d3\u05e2\u05d4 \u05dc\u05d0\u05e9\u05e8 \u05db\u05d9 \u05d4\u05d7\u05dc\u05e4\u05ea \u05d0\u05ea \u05db\u05ea\u05d5\u05d1\u05ea \u05d4\u05d3\u05d5\u05d0\u05e8 \u05d4\u05d0\u05dc\u05e7\u05d8\u05e8\u05d5\u05e0\u05d9 \u05d4\u05de\u05e7\u05d5\u05e9\u05e8\u05ea \u05dc\u05d7\u05e9\u05d1\u05d5\u05df {platform_name} \u05de-{old_email} \u05dc-{new_email}. \u05d0\u05dd \u05dc\u05d0 \u05d1\u05d9\u05e7\u05e9\u05ea \u05d0\u05ea \u05d4\u05e9\u05d9\u05e0\u05d5\u05d9 \u05d4\u05e0\"\u05dc \u05d0\u05e0\u05d0 \u05e6\u05d5\u05e8 \u05e2\u05de\u05e0\u05d5 \u05e7\u05e9\u05e8 \u05d1-",
    "This is to confirm that you have successfully changed your password associated with %(platform_name)s account. Please sign-in to your account.": "\u05de\u05d8\u05e8\u05ea \u05d4\u05d4\u05d5\u05d3\u05e2\u05d4 \u05d4\u05d6\u05d0\u05ea \u05d4\u05d9\u05d0 \u05dc\u05d0\u05e9\u05e8 \u05e9\u05e9\u05d9\u05e0\u05d9\u05ea \u05d1\u05d4\u05e6\u05dc\u05d7\u05d4 \u05d0\u05ea \u05d4\u05e1\u05d9\u05e1\u05de\u05d4 \u05e9\u05dc\u05da \u05e9\u05de\u05e9\u05d5\u05d9\u05db\u05ea \u05dc\u05d7\u05e9\u05d1\u05d5\u05df \u05d1\u05d0\u05ea\u05e8 %(platform_name)s. \u05e0\u05d0 \u05dc\u05d4\u05d9\u05db\u05e0\u05e1 \u05dc\u05d7\u05e9\u05d1\u05d5\u05df \u05e9\u05dc\u05da.",
    "This is to confirm that you have successfully changed your password associated with %(platform_name_tag)s account. Please sign-in to your account.": "\u05de\u05d8\u05e8\u05ea \u05d4\u05d4\u05d5\u05d3\u05e2\u05d4 \u05d4\u05d6\u05d0\u05ea \u05d4\u05d9\u05d0 \u05dc\u05d0\u05e9\u05e8 \u05e9\u05e9\u05d9\u05e0\u05d9\u05ea \u05d1\u05d4\u05e6\u05dc\u05d7\u05d4 \u05d0\u05ea \u05d4\u05e1\u05d9\u05e1\u05de\u05d4 \u05e9\u05dc\u05da \u05e9\u05de\u05e9\u05d5\u05d9\u05db\u05ea \u05dc\u05d7\u05e9\u05d1\u05d5\u05df \u05d1\u05d0\u05ea\u05e8 %(platform_name_tag)s. \u05e0\u05d0 \u05dc\u05d4\u05d9\u05db\u05e0\u05e1 \u05dc\u05d7\u05e9\u05d1\u05d5\u05df \u05e9\u05dc\u05da.",
    "This is what you will use to login.": "\u05d6\u05d4 \u05de\u05d4 \u05e9\u05ea\u05e9\u05ea\u05de\u05e9 \u05db\u05d3\u05d9 \u05dc\u05d4\u05ea\u05d7\u05d1\u05e8.",
    "This learner does not have access to this course. Their access expired on {expiration_date}.": "\u05dc\u05dc\u05d5\u05de\u05d3 \u05d6\u05d4 \u05d0\u05d9\u05df \u05d2\u05d9\u05e9\u05d4 \u05dc\u05e7\u05d5\u05e8\u05e1 \u05d6\u05d4. \u05d4\u05d2\u05d9\u05e9\u05d4 \u05e9\u05dc\u05d5 \u05e4\u05d2\u05d4 \u05d1\u05ea\u05d0\u05e8\u05d9\u05da {expiration_date}.",
    "This learner is currently sharing a limited profile.": "\u05dc\u05d5\u05de\u05d3 \u05d6\u05d4 \u05de\u05e9\u05ea\u05e3 \u05db\u05e8\u05d2\u05e2 \u05e4\u05e8\u05d5\u05e4\u05d9\u05dc \u05d7\u05dc\u05e7\u05d9.",
    "This learner will be removed from the team,allowing another learner to take the available spot.": "\u05dc\u05d5\u05de\u05d3 \u05d6\u05d4 \u05d9\u05d5\u05e1\u05e8 \u05de\u05d4\u05e6\u05d5\u05d5\u05ea, \u05de\u05d4 \u05e9\u05d9\u05d0\u05e4\u05e9\u05e8 \u05dc\u05dc\u05d5\u05de\u05d3 \u05d0\u05d7\u05e8 \u05dc\u05ea\u05e4\u05d5\u05e1 \u05d0\u05ea \u05d4\u05de\u05e7\u05d5\u05dd \u05d4\u05e4\u05e0\u05d5\u05d9.",
    "This link is no longer valid. But don\u2019t worry\u2014this Verified Certificate is still valid and available to share. If this is your certificate, please visit your dashboard to get a new shareable link. If you're viewing someone else's certificate, please contact them to get an updated link.": "\u05e7\u05d9\u05e9\u05d5\u05e8 \u05d6\u05d4 \u05d0\u05d9\u05e0\u05d5 \u05ea\u05e7\u05e3 \u05d9\u05d5\u05ea\u05e8. \u05d0\u05d1\u05dc \u05d0\u05dc \u05d3\u05d0\u05d2\u05d4 - \u05d4\u05ea\u05e2\u05d5\u05d3\u05d4 \u05d4\u05de\u05d0\u05d5\u05de\u05ea\u05ea \u05d4\u05d6\u05d5 \u05e2\u05d3\u05d9\u05d9\u05df \u05ea\u05e7\u05e4\u05d4 \u05d5\u05d6\u05de\u05d9\u05e0\u05d4 \u05dc\u05e9\u05d9\u05ea\u05d5\u05e3. \u05d0\u05dd \u05d6\u05d5 \u05d4\u05ea\u05e2\u05d5\u05d3\u05d4 \u05e9\u05dc\u05db\u05dd, \u05d1\u05e7\u05e8\u05d5 \u05d1\u05d3\u05e9\u05d1\u05d5\u05e8\u05d3 \u05e9\u05dc\u05db\u05dd \u05db\u05d3\u05d9 \u05dc\u05e7\u05d1\u05dc \u05e7\u05d9\u05e9\u05d5\u05e8 \u05d7\u05d3\u05e9 \u05e9\u05e0\u05d9\u05ea\u05df \u05dc\u05e9\u05d9\u05ea\u05d5\u05e3. \u05d0\u05dd \u05d0\u05ea\u05dd \u05e6\u05d5\u05e4\u05d9\u05dd \u05d1\u05ea\u05e2\u05d5\u05d3\u05d4 \u05e9\u05dc \u05de\u05d9\u05e9\u05d4\u05d5 \u05d0\u05d7\u05e8, \u05d0\u05e0\u05d0 \u05e4\u05e0\u05d5 \u05d0\u05dc\u05d9\u05d5 \u05db\u05d3\u05d9 \u05dc\u05e7\u05d1\u05dc \u05e7\u05d9\u05e9\u05d5\u05e8 \u05de\u05e2\u05d5\u05d3\u05db\u05df.",
