    "Invalid `role` specified.": "\u05e6\u05d5\u05d9\u05d9\u05df '\u05ea\u05e4\u05e7\u05d9\u05d3' \u05dc\u05d0 \u05d7\u05d5\u05e7\u05d9",
    "Invalid amount selected.": "\u05e0\u05d1\u05d7\u05e8\u05d4 \u05db\u05de\u05d5\u05ea \u05e9\u05d2\u05d5\u05d9\u05d4.",
    "Invalid course id": "\u05de\u05d6\u05d4\u05d4 \u05d4\u05e7\u05d5\u05e8\u05e1 \u05d0\u05d9\u05e0\u05d5 \u05ea\u05e7\u05d9\u05df",
    "Invalid course key": "\u05de\u05e4\u05ea\u05d7 \u05e7\u05d5\u05e8\u05e1 \u05d0\u05d9\u05e0\u05d5 \u05d7\u05d5\u05e7\u05d9",
    "Invalid course key.": "\u05de\u05e4\u05ea\u05d7 \u05d4\u05e7\u05d5\u05e8\u05e1 \u05d0\u05d9\u05e0\u05d5 \u05d7\u05d5\u05e7\u05d9.",
    "Invalid course update id.": "\u05d6\u05d4\u05d5\u05ea \u05e2\u05d3\u05db\u05d5\u05df \u05e7\u05d5\u05e8\u05e1 \u05d0\u05d9\u05e0\u05d4 \u05ea\u05e7\u05e4\u05d4",
    "Invalid data": "\u05e0\u05ea\u05d5\u05e0\u05d9\u05dd \u05dc\u05d0 \u05d7\u05d5\u05e7\u05d9\u05d9\u05dd",
    "Invalid data ({details})": "\u05e0\u05ea\u05d5\u05e0\u05d9\u05dd \u05dc\u05d0 \u05d7\u05d5\u05e7\u05d9\u05d9\u05dd ({details})",
    "Invalid data, generate_for must be \"new\" or \"all\".": "\u05de\u05d9\u05d3\u05e2 \u05dc\u05d0 \u05d7\u05d5\u05e7\u05d9, generate_for \u05d7\u05d9\u05d9\u05d1 \u05dc\u05d4\u05d9\u05d5\u05ea \"new\" \u05d0\u05d5 \"all\".",
    "Invalid email address: {email}": "\u05db\u05ea\u05d5\u05d1\u05ea \u05d4\u05de\u05d9\u05d9\u05dc: {email} \u05dc\u05d0 \u05d7\u05d5\u05e7\u05d9\u05ea",
    "Invalid email change key": "\u05de\u05e4\u05ea\u05d7 \u05dc\u05e9\u05d9\u05e0\u05d5\u05d9 \u05db\u05ea\u05d5\u05d1\u05ea \u05d3\u05d5\u05d0\u05e8 \u05d0\u05dc\u05e7\u05d8\u05e8\u05d5\u05e0\u05d9 \u05dc\u05d0 \u05ea\u05e7\u05d9\u05df",
    "Invalid email {email_address}.": "\u05db\u05ea\u05d5\u05d1\u05ea \u05d3\u05d5\u05d0\u05e8 \u05d0\u05dc\u05e7\u05d8\u05e8\u05d5\u05e0\u05d9 {email_address} \u05d0\u05d9\u05e0\u05d4 \u05ea\u05e7\u05d9\u05e0\u05d4.",
    "Invalid grader reply. Please contact the course staff.": "\u05ea\u05e9\u05d5\u05d1\u05ea \u05d1\u05d5\u05d3\u05e7 \u05d0\u05d9\u05e0\u05d4 \u05d7\u05d5\u05e7\u05d9\u05ea. \u05e0\u05d0 \u05e6\u05d5\u05e8 \u05e7\u05e9\u05e8 \u05e2\u05dd \u05e6\u05d5\u05d5\u05ea \u05d4\u05e7\u05d5\u05e8\u05e1. ",
    "Invalid group name: \"{group_name}\". {messages}": "\u05e9\u05dd \u05e7\u05d1\u05d5\u05e6\u05d4 \u05d0\u05d9\u05e0\u05d5 \u05d7\u05d5\u05e7\u05d9: {group_name}\". {messages}\"",
    "Invalid input: Could not parse '{bad_input}' as a formula": "\u05d4\u05d6\u05e0\u05ea \u05e0\u05ea\u05d5\u05e0\u05d9\u05dd \u05dc\u05d0 \u05d7\u05d5\u05e7\u05d9\u05d9\u05dd: \u05dc\u05d0 \u05e0\u05d9\u05ea\u05df \u05dc\u05e0\u05ea\u05d7  '{bad_input}' \u05db\u05e0\u05d5\u05e1\u05d7\u05d4. ",
    "Invalid input: Could not parse '{bad_input}' as a formula.": "\u05d4\u05d6\u05e0\u05ea \u05e0\u05ea\u05d5\u05e0\u05d9\u05dd \u05dc\u05d0 \u05d7\u05d5\u05e7\u05d9\u05dd: \u05dc\u05d0 \u05e0\u05d9\u05ea\u05df \u05dc\u05e0\u05ea\u05d7 '{bad_input}' \u05db\u05e0\u05d5\u05e1\u05d7\u05d4.",
    "Invalid location.": "\u05de\u05d9\u05e7\u05d5\u05dd \u05dc\u05d0 \u05d7\u05d5\u05e7\u05d9.",
    "Invalid math syntax: '{student_answer}'": "\u05ea\u05d7\u05d1\u05d9\u05e8 \u05de\u05ea\u05de\u05d8\u05d9 \u05dc\u05d0 \u05ea\u05e7\u05d9\u05df: '{student_answer}'",
    "Invalid password.": "\u05e1\u05d9\u05e1\u05de\u05d4 \u05dc\u05d0 \u05d7\u05d5\u05e7\u05d9\u05ea.",
    "Invalid permission codename: \"{codename}\".  No such permission exists for the model {module}.{model_name}.": "\u05e9\u05dd \u05e7\u05d5\u05d3 \u05dc\u05d4\u05e8\u05e9\u05d0\u05d4 \u05d0\u05d9\u05e0\u05d5 \u05d7\u05d5\u05e7\u05d9: \"{codename}\". \u05dc\u05d0 \u05e7\u05d9\u05d9\u05de\u05ea \u05d4\u05e8\u05e9\u05d0\u05d4 \u05db\u05d6\u05d0\u05ea \u05e2\u05d1\u05d5\u05e8 \u05d4\u05d3\u05d2\u05dd {module}.{model_name}.",
    "Invalid permission option: \"{}\". Please specify permissions using the format: app_label:model_name:permission_codename.": "\u05d0\u05e4\u05e9\u05e8\u05d5\u05ea \u05d4\u05e8\u05e9\u05d0\u05d4 \u05d0\u05d9\u05e0\u05d4 \u05d7\u05d5\u05e7\u05d9\u05ea: \"{}\". \u05e0\u05d0 \u05e6\u05d9\u05d9\u05df \u05d4\u05e8\u05e9\u05d0\u05d5\u05ea \u05d1\u05d0\u05de\u05e6\u05e2\u05d5\u05ea \u05d4\u05ea\u05d1\u05e0\u05d9\u05ea: app_label:model_name:permission_codename.",
    "Invalid prerequisite course key": "\u05de\u05e4\u05ea\u05d7 \u05d3\u05e8\u05d9\u05e9\u05d5\u05ea \u05e7\u05d3\u05dd \u05dc\u05d0 \u05d7\u05d5\u05e7\u05d9",
    "Invalid task_output information found for instructor_task {0}: {1}": "\u05e0\u05de\u05e6\u05d0 \u05de\u05d9\u05d3\u05e2 task_output \u05dc\u05d0 \u05d7\u05d5\u05e7\u05d9 \u05e2\u05d1\u05d5\u05e8 instructor_task {0}: {1}",
    "Invalid usage_id: {usage_id}.": "usage_id \u05dc\u05d0 \u05d7\u05d5\u05e7\u05d9: {usage_id}.",
    "Invalid user preference key '{preference_key}'.": "\u05de\u05e4\u05ea\u05d7 \u05d4\u05e2\u05d3\u05e4\u05d5\u05ea \u05de\u05e9\u05ea\u05de\u05e9 \u05d0\u05d9\u05e0\u05d5 \u05d7\u05d5\u05e7\u05d9 '{preference_key}'.",
    "Invalidate Certificate": "\u05e4\u05e1\u05d9\u05dc\u05ea \u05ea\u05e2\u05d5\u05d3\u05d4",
    "Invalidate Certificates": "\u05e4\u05e1\u05d9\u05dc\u05ea \u05ea\u05e2\u05d5\u05d3\u05d5\u05ea",
    "Invalidated": "\u05e0\u05e4\u05e1\u05dc\u05d4",
    "Invalidated By": "\u05e0\u05e4\u05e1\u05dc\u05d4 \u05e2\u05dc \u05d9\u05d3\u05d9",
    "Invitation Only": "\u05d1\u05d4\u05d6\u05de\u05e0\u05d4 \u05d1\u05dc\u05d1\u05d3",
    "Invite your students": "\u05d4\u05d6\u05de\u05df \u05d0\u05ea \u05d4\u05e1\u05d8\u05d5\u05d3\u05e0\u05d8\u05d9\u05dd \u05e9\u05dc\u05da",
    "Invoice Recipient": "\u05e0\u05de\u05e2\u05df \u05d4\u05d7\u05e9\u05d1\u05d5\u05e0\u05d9\u05ea",
    "Is Enabled": "\u05de\u05d5\u05e4\u05e2\u05dc",
    "Is Entrance Exam": "\u05d4\u05d9\u05d0 \u05d1\u05d7\u05d9\u05e0\u05ea \u05db\u05e0\u05d9\u05e1\u05d4",
    "Is Onboarding Exam": "\u05de\u05d1\u05d7\u05df \u05d4\u05e6\u05d8\u05e8\u05e4\u05d5\u05ea",
    "Is Practice Exam": "\u05d6\u05d4\u05d5 \u05de\u05d1\u05d7\u05df \u05ea\u05e8\u05d2\u05d5\u05dc",
    "Is Proctoring Enabled": "\u05d4\u05e4\u05d9\u05e7\u05d5\u05d7 \u05de\u05d5\u05e4\u05e2\u05dc",
    "Is Sample Attempt": "\u05d4\u05d5\u05d0 \u05d3\u05d5\u05d2\u05de\u05ea \u05e0\u05d9\u05e1\u05d9\u05d5\u05df",
    "Is Time Limited": "\u05de\u05d5\u05d2\u05d1\u05dc \u05d1\u05d6\u05de\u05df",
    "Is Visible To:": "\u05d2\u05dc\u05d5\u05d9 \u05e2\u05d1\u05d5\u05e8:",
    "Is this OK?": "\u05d4\u05d0\u05dd \u05d6\u05d4 \u05d1\u05e1\u05d3\u05e8?",
    "Is your name on your ID readable?": "\u05d4\u05d0\u05dd \u05d4\u05e9\u05dd \u05e2\u05dc \u05d4\u05ea\u05e2\u05d5\u05d3\u05d4 \u05d4\u05de\u05d6\u05d4\u05d4 \u05e9\u05dc\u05da \u05e7\u05e8\u05d9\u05d0?",
    "Issue Open Badges": "\u05ea\u05d2\u05d9\u05dd \u05e4\u05ea\u05d5\u05d7\u05d9\u05dd \u05dc\u05d1\u05e2\u05d9\u05d4",
    "Issue Open Badges badges for this course. Badges are generated when certificates are created.": "\u05ea\u05d2\u05d9\u05dd \u05e4\u05ea\u05d5\u05d7\u05d9\u05dd \u05dc\u05d1\u05e2\u05d9\u05d4 \u05e2\u05d1\u05d5\u05e8 \u05e7\u05d5\u05e8\u05e1 \u05d6\u05d4. \u05d4\u05ea\u05d2\u05d9\u05dd \u05e0\u05d5\u05e6\u05e8\u05d9\u05dd \u05d1\u05e2\u05ea \u05d9\u05e6\u05d9\u05e8\u05ea \u05d4\u05ea\u05e2\u05d5\u05d3\u05d5\u05ea.",
    "Issued On:": "\u05d4\u05d5\u05e0\u05e4\u05e7 \u05d1\u05ea\u05d0\u05e8\u05d9\u05da:",
    "Issuing Certificates to Learners": "\u05d4\u05e0\u05e4\u05e7\u05ea \u05ea\u05e2\u05d5\u05d3\u05d5\u05ea \u05dc\u05dc\u05d5\u05de\u05d3\u05d9\u05dd",
    "It expect that the data will be provided in a csv file format with                     first row being the header and columns will be as follows:                     course_id, username, mode": "\u05d4\u05d3\u05e8\u05d9\u05e9\u05d4 \u05d4\u05d9\u05d0 \u05db\u05d9 \u05d4\u05de\u05d9\u05d3\u05e2 \u05d9\u05e1\u05d5\u05e4\u05e7 \u05d1\u05e7\u05d5\u05d1\u05e5 \u05d1\u05e4\u05d5\u05e8\u05de\u05d8 csv \u05db\u05d0\u05e9\u05e8 \u05d4\u05e9\u05d5\u05e8\u05d4 \u05d4\u05e8\u05d0\u05e9\u05d5\u05e0\u05d4 \u05d4\u05d9\u05d0 \u05d4\u05db\u05d5\u05ea\u05e8\u05ea \u05d5\u05d4\u05e2\u05de\u05d5\u05d3\u05d5\u05ea \u05d9\u05d4\u05d9\u05d5 \u05db\u05d3\u05dc\u05e7\u05de\u05df: course_id, username, mode",
    "It expect that the data will be provided in a csv file format with                     first row being the header and columns will be as follows:                     user_id, username, email, course_id, is_verified, verification_date": "\u05d4\u05d3\u05e8\u05d9\u05e9\u05d4 \u05d4\u05d9\u05d0 \u05db\u05d9 \u05d4\u05de\u05d9\u05d3\u05e2 \u05d9\u05e1\u05d5\u05e4\u05e7 \u05d1\u05e7\u05d5\u05d1\u05e5 \u05d1\u05e4\u05d5\u05e8\u05de\u05d8 csv \u05db\u05d0\u05e9\u05e8 \u05d4\u05e9\u05d5\u05e8\u05d4 \u05d4\u05e8\u05d0\u05e9\u05d5\u05e0\u05d4 \u05d4\u05d9\u05d0 \u05d4\u05db\u05d5\u05ea\u05e8\u05ea \u05d5\u05d4\u05e2\u05de\u05d5\u05d3\u05d5\u05ea \u05d9\u05d4\u05d9\u05d5 \u05db\u05d3\u05dc\u05e7\u05de\u05df: user_id, username, email, course_id, is_verified, verification_date",
    "It expect that the data will be provided in a csv file format with                     first row being the header and columns will be as follows:                     username, current_email, desired_email": "\u05d4\u05d3\u05e8\u05d9\u05e9\u05d4 \u05d4\u05d9\u05d0 \u05db\u05d9 \u05d4\u05de\u05d9\u05d3\u05e2 \u05d9\u05e1\u05d5\u05e4\u05e7 \u05d1\u05e7\u05d5\u05d1\u05e5 \u05d1\u05e4\u05d5\u05e8\u05de\u05d8 csv \u05db\u05d0\u05e9\u05e8 \u05d4\u05e9\u05d5\u05e8\u05d4 \u05d4\u05e8\u05d0\u05e9\u05d5\u05e0\u05d4 \u05d4\u05d9\u05d0 \u05d4\u05db\u05d5\u05ea\u05e8\u05ea \u05d5\u05d4\u05e2\u05de\u05d5\u05d3\u05d5\u05ea \u05d9\u05d4\u05d9\u05d5 \u05db\u05d3\u05dc\u05e7\u05de\u05df: username, current_email, desired_email",
    "It is recommended that you change your password.": "\u05de\u05d5\u05de\u05dc\u05e5 \u05db\u05d9 \u05ea\u05e9\u05e0\u05d4 \u05d0\u05ea \u05e1\u05d9\u05e1\u05de\u05ea\u05da.",
    "It is strongly recommended that you include four or fewer signatories. If you include additional signatories, preview the certificate in Print View to ensure the certificate will print correctly on one page.": "\u05de\u05d5\u05de\u05dc\u05e5 \u05d1\u05d7\u05d5\u05dd \u05e9\u05ea\u05db\u05dc\u05d5\u05dc \u05d0\u05e8\u05d1\u05e2 \u05d7\u05ea\u05d9\u05de\u05d5\u05ea \u05d0\u05d5 \u05e4\u05d7\u05d5\u05ea. \u05d0\u05dd \u05ea\u05db\u05dc\u05d5\u05dc \u05d7\u05ea\u05d9\u05de\u05d5\u05ea \u05e0\u05d5\u05e1\u05e4\u05d5\u05ea, \u05d4\u05e6\u05d2 \u05d1\u05ea\u05e6\u05d5\u05d2\u05d4 \u05de\u05d5\u05e7\u05d3\u05de\u05ea \u05d0\u05ea \u05d4\u05ea\u05e2\u05d5\u05d3\u05d4 \u05d1\u05de\u05e6\u05d1 '\u05ea\u05e6\u05d5\u05d2\u05ea \u05d4\u05d3\u05e4\u05e1\u05d4' \u05db\u05d3\u05d9 \u05dc\u05d4\u05d1\u05d8\u05d9\u05d7 \u05e9\u05d4\u05ea\u05e2\u05d5\u05d3\u05d4 \u05ea\u05d5\u05d3\u05e4\u05e1 \u05db\u05d4\u05dc\u05db\u05d4 \u05e2\u05dc \u05d3\u05e3 \u05d0\u05d7\u05d3.",
    "It looks like this email address is already registered": "\u05e0\u05e8\u05d0\u05d4 \u05e9\u05db\u05ea\u05d5\u05d1\u05ea \u05d3\u05d5\u05d0\"\u05dc \u05d6\u05d5 \u05db\u05d1\u05e8 \u05e8\u05e9\u05d5\u05de\u05d4",
    "It looks like this username is already taken": "\u05e0\u05e8\u05d0\u05d4 \u05e9\u05e9\u05dd \u05d4\u05de\u05e9\u05ea\u05de\u05e9 \u05d4\u05d6\u05d4 \u05db\u05d1\u05e8 \u05ea\u05e4\u05d5\u05e1",
    "It looks like you missed some important deadlines based on our suggested schedule.": "\u05e0\u05e8\u05d0\u05d4 \u05e9\u05d4\u05d7\u05de\u05e6\u05ea\u05dd \u05de\u05e1\u05e4\u05e8 \u05de\u05d5\u05e2\u05d3\u05d9\u05dd \u05d7\u05e9\u05d5\u05d1\u05d9\u05dd \u05d1\u05d4\u05ea\u05d1\u05e1\u05e1 \u05e2\u05dc \u05dc\u05d5\u05d7 \u05d4\u05d6\u05de\u05e0\u05d9\u05dd \u05d4\u05de\u05d5\u05e6\u05e2 \u05e9\u05dc\u05e0\u05d5.",
    "It looks like {email_address} belongs to an existing account. Try again with a different email address.": "\u05e0\u05e8\u05d0\u05d4 \u05db\u05d9 {email_address} \u05e9\u05d9\u05d9\u05da \u05dc\u05d7\u05e9\u05d1\u05d5\u05df \u05e7\u05d9\u05d9\u05dd. \u05e0\u05e1\u05d4 \u05e9\u05d5\u05d1 \u05e2\u05dd \u05db\u05ea\u05d5\u05d1\u05ea \u05d3\u05d5\u05d0\u05e8 \u05d0\u05dc\u05e7\u05d8\u05e8\u05d5\u05e0\u05d9 \u05d0\u05d7\u05e8\u05ea.",
