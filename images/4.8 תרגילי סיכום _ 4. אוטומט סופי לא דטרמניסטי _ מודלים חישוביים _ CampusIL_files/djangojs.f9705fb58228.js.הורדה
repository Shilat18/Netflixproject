    "Your password must contain no more than %(max_length)d character.": [
      "\u05e2\u05dc \u05d4\u05e1\u05d9\u05e1\u05de\u05d4 \u05dc\u05d4\u05db\u05d9\u05dc \u05dc\u05d0 \u05d9\u05d5\u05ea\u05e8 \u05de-%(max_length)d \u05ea\u05d5\u05d5\u05d9\u05dd.",
      "\u05e2\u05dc \u05d4\u05e1\u05d9\u05e1\u05de\u05d4 \u05dc\u05d4\u05db\u05d9\u05dc \u05dc\u05d0 \u05d9\u05d5\u05ea\u05e8 \u05de-%(max_length)d \u05ea\u05d5\u05d5\u05d9\u05dd.",
      "\u05e2\u05dc \u05d4\u05e1\u05d9\u05e1\u05de\u05d4 \u05dc\u05d4\u05db\u05d9\u05dc \u05dc\u05d0 \u05d9\u05d5\u05ea\u05e8 \u05de-%(max_length)d \u05ea\u05d5\u05d5\u05d9\u05dd.",
      "\u05e2\u05dc \u05d4\u05e1\u05d9\u05e1\u05de\u05d4 \u05dc\u05d4\u05db\u05d9\u05dc \u05dc\u05d0 \u05d9\u05d5\u05ea\u05e8 \u05de-%(max_length)d \u05ea\u05d5\u05d5\u05d9\u05dd."
    ],
    "Your password must contain {length_instruction}, including {complexity_instructions}.": "\u05e2\u05dc \u05d4\u05e1\u05d9\u05e1\u05de\u05d4 \u05e9\u05dc\u05db\u05dd \u05dc\u05db\u05dc\u05d5\u05dc {length_instruction}, \u05db\u05d5\u05dc\u05dc {complexity_instructions}.",
    "Your password must contain {length_instruction}.": "\u05d4\u05e1\u05d9\u05e1\u05de\u05d4 \u05e9\u05dc\u05da \u05d7\u05d9\u05d9\u05d1\u05ea \u05dc\u05d4\u05db\u05d9\u05dc {length_instruction}.",
    "Your payment was successful.": "\u05d4\u05ea\u05e9\u05dc\u05d5\u05dd \u05e2\u05d1\u05e8 \u05d1\u05d4\u05e6\u05dc\u05d7\u05d4",
    "Your payment was successful. You will see the charge below on your next credit or debit card statement under the company name {merchant_name}.": "\u05d4\u05ea\u05e9\u05dc\u05d5\u05dd \u05e2\u05d1\u05e8 \u05d1\u05d4\u05e6\u05dc\u05d7\u05d4. \u05ea\u05d5\u05db\u05dc \u05dc\u05e8\u05d0\u05d5\u05ea \u05d0\u05ea \u05d4\u05d7\u05d9\u05d5\u05d1 \u05de\u05d8\u05d4 \u05d1\u05db\u05e8\u05d8\u05d9\u05e1 \u05d4\u05d0\u05e9\u05e8\u05d0\u05d9/\u05d7\u05d9\u05d5\u05d1 \u05e9\u05dc\u05da \u05ea\u05d7\u05ea \u05d4\u05e9\u05dd {merchant_name}. ",
    "Your permission settings were unchanged, so nothing saved.": "\u05dc\u05d0 \u05d4\u05d9\u05d5 \u05e9\u05d9\u05e0\u05d5\u05d9\u05d9\u05dd \u05d1\u05d4\u05e8\u05e9\u05d0\u05d5\u05ea, \u05dc\u05db\u05df \u05d3\u05d1\u05e8 \u05dc\u05d0 \u05e0\u05e9\u05de\u05e8.",
    "Your photo ID verification expires on {verification_expiry}. Please be aware photo verification can take up to three days once initiated and you will not be able to earn a certificate or take a proctored exam until approved.": "\u05ea\u05d5\u05e7\u05e3 \u05d0\u05d9\u05de\u05d5\u05ea \u05d4\u05ea\u05e2\u05d5\u05d3\u05d4 \u05d4\u05de\u05d6\u05d4\u05d4 \u05e9\u05dc\u05db\u05dd \u05d9\u05e4\u05d5\u05d2 \u05d1-{verification_expiry}. \u05dc\u05d9\u05d3\u05d9\u05e2\u05ea\u05db\u05dd, \u05d0\u05d9\u05de\u05d5\u05ea \u05ea\u05de\u05d5\u05e0\u05d4 \u05d9\u05db\u05d5\u05dc \u05dc\u05d4\u05ea\u05e8\u05d7\u05e9 \u05e2\u05d3 \u05e9\u05dc\u05d5\u05e9\u05d4 \u05d9\u05de\u05d9\u05dd \u05de\u05e8\u05d2\u05e2 \u05d4\u05ea\u05d7\u05dc\u05ea\u05d5, \u05d5\u05dc\u05d0 \u05ea\u05d5\u05db\u05dc\u05d5 \u05dc\u05e7\u05d1\u05dc \u05ea\u05e2\u05d5\u05d3\u05d4 \u05d0\u05d5 \u05dc\u05d2\u05e9\u05ea \u05dc\u05d1\u05d7\u05d9\u05e0\u05ea \u05d1\u05d4\u05e9\u05d2\u05d7\u05d4 \u05e2\u05d3 \u05dc\u05d0\u05d9\u05e9\u05d5\u05e8.",
    "Your policy changes have been saved.": "\u05e9\u05d9\u05e0\u05d5\u05d9\u05d9 \u05de\u05d3\u05d9\u05e0\u05d9\u05d5\u05ea\u05da \u05e0\u05e9\u05de\u05e8\u05d5.",
    "Your post will be discarded.": "\u05d4\u05e4\u05d5\u05e1\u05d8 \u05e9\u05dc\u05da \u05d9\u05d1\u05d5\u05d8\u05dc",
    "Your previous request is in progress, please try again in a few moments.": "\u05d1\u05e7\u05e9\u05ea\u05da \u05dc\u05d0\u05d9\u05e4\u05d5\u05e1 \u05e1\u05d9\u05e1\u05de\u05d4 \u05e0\u05e7\u05dc\u05d8\u05d4 \u05d1\u05de\u05e2\u05e8\u05db\u05ea, \u05d9\u05e9 \u05dc\u05e0\u05e1\u05d5\u05ea \u05dc\u05d4\u05ea\u05d7\u05d1\u05e8 \u05e9\u05d5\u05d1 \u05d1\u05e2\u05d5\u05d3 \u05de\u05e1\u05e4\u05e8 \u05d3\u05e7\u05d5\u05ea.",
    "Your profile has missing fields!": "\u05d7\u05e1\u05e8 \u05db\u05de\u05d4 \u05e9\u05d3\u05d5\u05ea \u05d1\u05e4\u05e8\u05d5\u05e4\u05d9\u05dc \u05e9\u05dc\u05da!",
    "Your profile settings are managed by {enterprise_name}. Contact your administrator or {link_start}edX Support{link_end} for help.": "\u05d4\u05d2\u05d3\u05e8\u05d5\u05ea \u05d4\u05e4\u05e8\u05d5\u05e4\u05d9\u05dc \u05e9\u05dc\u05db\u05dd \u05de\u05e0\u05d5\u05d4\u05dc\u05d5\u05ea \u05e2\u05dc \u05d9\u05d3\u05d9 {enterprise_name}. \u05e4\u05e0\u05d5 \u05dc\u05de\u05e0\u05d4\u05dc \u05d4\u05de\u05e2\u05e8\u05db\u05ea \u05e9\u05dc\u05db\u05dd \u05d0\u05d5 \u05dc{link_start}\u05ea\u05de\u05d9\u05db\u05d4 \u05e9\u05dc edX{link_end} \u05dc\u05e7\u05d1\u05dc\u05ea \u05e2\u05d6\u05e8\u05d4.",
    "Your question or idea (required)": "\u05e9\u05d0\u05dc\u05ea\u05da \u05d0\u05d5 \u05e8\u05e2\u05d9\u05d5\u05e0\u05da (\u05d7\u05d5\u05d1\u05d4)",
    "Your redeem url is: [[Enter Redeem URL here from the attached CSV]]": "\u05db\u05ea\u05d5\u05d1\u05ea \u05d4-URL \u05e9\u05dc\u05da \u05d4\u05d9\u05d0: [[Enter Redeem URL here from the attached CSV]]",
    "Your report has been successfully generated.": "\u05d4\u05d3\u05d5\u05d7 \u05e9\u05dc\u05da \u05e0\u05d5\u05e6\u05e8 \u05d1\u05d4\u05e6\u05dc\u05d7\u05d4.",
    "Your report is being generated...": "\u05d4\u05d3\u05d5\u05d7 \u05e9\u05dc\u05da \u05e0\u05d5\u05e6\u05e8\u2026",
    "Your request could not be completed due to a server problem. Reload the page and try again. If the issue persists, click the Help tab to report the problem.": "\u05dc\u05d0 \u05e0\u05d9\u05ea\u05df \u05dc\u05d4\u05e9\u05dc\u05d9\u05dd \u05d0\u05ea \u05d1\u05e7\u05e9\u05ea\u05da \u05d1\u05d2\u05dc\u05dc \u05d1\u05e2\u05d9\u05d4 \u05d1\u05e9\u05e8\u05ea. \u05d8\u05e2\u05df \u05de\u05d7\u05d3\u05e9 \u05d0\u05ea \u05d4\u05d3\u05e3 \u05d5\u05e0\u05e1\u05d4 \u05e9\u05d5\u05d1. \u05d0\u05dd \u05d4\u05d1\u05e2\u05d9\u05d4 \u05e0\u05de\u05e9\u05db\u05ea, \u05dc\u05d7\u05e5 \u05e2\u05dc \u05d4\u05dc\u05e9\u05d5\u05e0\u05d9\u05ea '\u05e2\u05d6\u05e8\u05d4' \u05db\u05d3\u05d9 \u05dc\u05d3\u05d5\u05d5\u05d7 \u05e2\u05dc \u05d4\u05d1\u05e2\u05d9\u05d4.",
    "Your request could not be completed. Reload the page and try again.": "\u05dc\u05d0 \u05e0\u05d9\u05ea\u05df \u05dc\u05d4\u05e9\u05dc\u05d9\u05dd \u05d0\u05ea \u05d1\u05e7\u05e9\u05ea\u05da. \u05d8\u05e2\u05df \u05de\u05d7\u05d3\u05e9 \u05d0\u05ea \u05d4\u05d3\u05e3 \u05d5\u05e0\u05e1\u05d4 \u05e9\u05d5\u05d1.",
    "Your request could not be completed. Reload the page and try again. If the issue persists, click the Help tab to report the problem.": "\u05dc\u05d0 \u05e0\u05d9\u05ea\u05df \u05dc\u05d4\u05e9\u05dc\u05d9\u05dd \u05d0\u05ea \u05d1\u05e7\u05e9\u05ea\u05da. \u05d8\u05e2\u05df \u05de\u05d7\u05d3\u05e9 \u05d0\u05ea \u05d4\u05d3\u05e3 \u05d5\u05e0\u05e1\u05d4 \u05e9\u05d5\u05d1. \u05d0\u05dd \u05d4\u05d1\u05e2\u05d9\u05d4 \u05e0\u05de\u05e9\u05db\u05ea, \u05dc\u05d7\u05e5 \u05e2\u05dc \u05d4\u05dc\u05e9\u05d5\u05e0\u05d9\u05ea '\u05e2\u05d6\u05e8\u05d4' \u05db\u05d3\u05d9 \u05dc\u05d3\u05d5\u05d5\u05d7 \u05e2\u05dc \u05d4\u05d1\u05e2\u05d9\u05d4.",
    "Your request could not be processed. Refresh the page and try again.": "\u05dc\u05d0 \u05e0\u05d9\u05ea\u05df \u05dc\u05e2\u05d1\u05d3 \u05d0\u05ea \u05d1\u05e7\u05e9\u05ea\u05da. \u05e8\u05e2\u05e0\u05df \u05d0\u05ea \u05d4\u05e2\u05de\u05d5\u05d3 \u05d5\u05e0\u05e1\u05d4 \u05e9\u05e0\u05d9\u05ea.",
    "Your request did not meet the criteria/guidelines specified by {platform_name} Staff.": "\u05d4\u05d1\u05e7\u05e9\u05d4 \u05e9\u05dc\u05da \u05dc\u05d0 \u05e2\u05de\u05d3\u05d4 \u05d1\u05e7\u05e8\u05d9\u05d8\u05e8\u05d9\u05d5\u05e0\u05d9\u05dd/\u05d4\u05e0\u05d7\u05d9\u05d5\u05ea \u05e9\u05dc \u05e6\u05d5\u05d5\u05ea {platform_name}. ",
    "Your request for course creation rights to {studio_name} have been denied. If you believe this was in error, please contact {email}": "\u05d1\u05e7\u05e9\u05ea\u05da \u05dc\u05d2\u05e9\u05ea \u05dc\u05e7\u05d1\u05dc\u05ea \u05d6\u05db\u05d5\u05d9\u05d5\u05ea \u05d9\u05e6\u05d9\u05e8\u05ea \u05e7\u05d5\u05e8\u05e1 \u05d1-{studio_name} \u05e0\u05d3\u05d7\u05ea\u05d4. \u05d0\u05dd \u05dc\u05d3\u05e2\u05ea\u05da \u05d1\u05e7\u05e9\u05ea\u05da \u05e0\u05d3\u05d7\u05ea\u05d4 \u05d1\u05e9\u05d5\u05d2\u05d2, \u05e6\u05d5\u05e8 \u05e7\u05e9\u05e8 \u05e2\u05dd {email}",
    "Your request for course creation rights to {studio_name} have been granted. To create your first course, visit\n\n{url}": "\u05d1\u05e7\u05e9\u05ea\u05da \u05dc\u05d2\u05e9\u05ea \u05dc\u05e7\u05d1\u05dc\u05ea \u05d6\u05db\u05d5\u05d9\u05d5\u05ea \u05d9\u05e6\u05d9\u05e8\u05ea \u05e7\u05d5\u05e8\u05e1 \u05d1-{studio_name} \u05d4\u05ea\u05e7\u05d1\u05dc\u05d4. \u05e6\u05d5\u05e8 \u05d0\u05ea \u05d4\u05e7\u05d5\u05e8\u05e1 \u05d4\u05e8\u05d0\u05e9\u05d5\u05df \u05e9\u05dc\u05da\n\n{url}",
    "Your request has been rate-limited. Please try again later.": "\u05d1\u05e7\u05e9\u05ea\u05db\u05dd \u05e0\u05ea\u05e7\u05dc\u05d4 \u05d1\u05de\u05d2\u05d1\u05dc\u05ea \u05e7\u05e6\u05d1. \u05d0\u05e0\u05d0 \u05e0\u05e1\u05d5 \u05e9\u05d5\u05d1 \u05de\u05d0\u05d5\u05d7\u05e8 \u05d9\u05d5\u05ea\u05e8.",
    "Your request is currently being reviewed by {platform_name} staff and should be updated shortly.": "\u05d1\u05e7\u05e9\u05ea\u05da \u05e0\u05d1\u05d7\u05e0\u05ea \u05db\u05e8\u05d2\u05e2 \u05e2\u05dc-\u05d9\u05d3\u05d9 \u05e6\u05d5\u05d5\u05ea {platform_name} \u05d5\u05ea\u05e2\u05d5\u05d3\u05db\u05df \u05d1\u05e7\u05e8\u05d5\u05d1.",
    "Your request to access the {platform_name} Course Catalog API has been approved.": "\u05d1\u05e7\u05e9\u05ea\u05da \u05dc\u05d2\u05e9\u05ea \u05dc-{platform_name} \u05de\u05de\u05e9\u05e7 \u05d4-API \u05e9\u05dc \u05e7\u05d8\u05dc\u05d5\u05d2 \u05d4\u05e7\u05d5\u05e8\u05e1 \u05d0\u05d5\u05e9\u05e8\u05d4.",
    "Your request to access the {platform_name} Course Catalog API has been denied. If you think this is an error, or for other questions about using this API, contact {api_support_email_link}.": "\u05d1\u05e7\u05e9\u05ea\u05da \u05dc\u05d2\u05e9\u05ea \u05dc{platform_name} \u05de\u05de\u05e9\u05e7 \u05d4-API \u05e9\u05dc \u05e7\u05d8\u05dc\u05d5\u05d2 \u05d4\u05e7\u05d5\u05e8\u05e1 \u05e0\u05d3\u05d7\u05ea\u05d4. \u05d0\u05dd \u05dc\u05d3\u05e2\u05ea\u05da \u05d6\u05d5 \u05e9\u05d2\u05d9\u05d0\u05d4, \u05d0\u05d5 \u05d9\u05e9 \u05dc\u05da \u05e9\u05d0\u05dc\u05d5\u05ea \u05e0\u05d5\u05e1\u05e4\u05d5\u05ea \u05d0\u05d5\u05d3\u05d5\u05ea \u05de\u05de\u05e9\u05e7 API \u05d6\u05d4, \u05e6\u05d5\u05e8 \u05e7\u05e9\u05e8 \u05e2\u05dd {api_support_email_link}.",
    "Your request to access the {platform_name} Course Catalog API is being processed. You will receive a message at the email address in your profile when processing is complete. You can also return to this page to see the status of your API access request.": "\u05d1\u05e7\u05e9\u05ea\u05da \u05dc\u05e7\u05d1\u05dc \u05d2\u05d9\u05e9\u05d4 \u05dc{platform_name} \u05de\u05de\u05e9\u05e7 \u05d4-API \u05e9\u05dc \u05e7\u05d8\u05dc\u05d5\u05d2 \u05d4\u05e7\u05d5\u05e8\u05e1 \u05e0\u05de\u05e6\u05d0\u05ea \u05d1\u05e2\u05d9\u05d1\u05d5\u05d3. \u05ea\u05e7\u05d1\u05dc \u05d4\u05d5\u05d3\u05e2\u05d4 \u05d1\u05d3\u05d5\u05d0\u05e8 \u05d0\u05dc\u05e7\u05d8\u05e8\u05d5\u05e0\u05d9 \u05d4\u05de\u05d5\u05e4\u05d9\u05e2 \u05d1\u05e4\u05e8\u05d5\u05e4\u05d9\u05dc \u05e9\u05dc\u05da, \u05db\u05e9\u05d9\u05d5\u05e9\u05dc\u05dd \u05d4\u05e2\u05d9\u05d1\u05d5\u05d3. \u05d1\u05e0\u05d5\u05e1\u05e3, \u05ea\u05d5\u05db\u05dc \u05dc\u05d7\u05d6\u05d5\u05e8 \u05dc\u05e2\u05de\u05d5\u05d3 \u05d6\u05d4 \u05e2\u05dc \u05de\u05e0\u05ea \u05dc\u05e8\u05d0\u05d5\u05ea \u05d0\u05ea \u05e1\u05d8\u05d8\u05d5\u05e1 \u05d1\u05e7\u05e9\u05ea \u05d4\u05d2\u05d9\u05e9\u05d4 \u05dc\u05de\u05de\u05e9\u05e7 \u05d4-API.",
    "Your request to author courses in {studio_name} has been denied. Please {link_start}contact {platform_name} Staff with further questions{link_end}.": "\u05d1\u05e7\u05e9\u05ea\u05da \u05dc\u05db\u05ea\u05d5\u05d1 \u05e7\u05d5\u05e8\u05e1\u05d9\u05dd \u05d1-{studio_name} \u05e0\u05d3\u05d7\u05ea\u05d4. \u05dc\u05e9\u05d0\u05dc\u05d5\u05ea \u05e0\u05d5\u05e1\u05e4\u05d5\u05ea, {link_start}\u05e6\u05d5\u05e8 \u05e7\u05e9\u05e8 {platform_name} \u05e2\u05dd \u05d4\u05e6\u05d5\u05d5\u05ea{link_end}.",
    "Your score is": "\u05d4\u05e6\u05d9\u05d5\u05df \u05e9\u05dc\u05da \u05d4\u05d5\u05d0",
    "Your score is %(graded_score)s / %(max_score)s": "\u05d4\u05e6\u05d9\u05d5\u05df \u05e9\u05dc\u05da %(graded_score)s / %(max_score)s",
    "Your score is {current_score}%. You have passed the entrance exam.": "\u05e6\u05d9\u05d5\u05e0\u05da \u05d4\u05d5\u05d0 {current_score}%. \u05e2\u05d1\u05e8\u05ea \u05d0\u05ea \u05de\u05d1\u05d7\u05df \u05d4\u05db\u05e0\u05d9\u05e1\u05d4.",
    "Your search did not return any results": "\u05d4\u05d7\u05d9\u05e4\u05d5\u05e9 \u05e9\u05dc\u05db\u05dd \u05dc\u05d0 \u05d4\u05d7\u05d6\u05d9\u05e8 \u05ea\u05d5\u05e6\u05d0\u05d5\u05ea \u05db\u05dc\u05e9\u05d4\u05df",
    "Your secondary email has been activated. Please visit {link_start}dashboard{link_end} for courses.": "\u05d4\u05d3\u05d5\u05d0\"\u05dc \u05d4\u05de\u05e9\u05e0\u05d9 \u05e9\u05dc\u05db\u05dd \u05d4\u05d5\u05e4\u05e2\u05dc. \u05d1\u05e7\u05e8\u05d5 \u05d1-{link_start}\u05d3\u05e9\u05d1\u05d5\u05e8\u05d3{link_end} \u05dc\u05e7\u05d5\u05e8\u05e1\u05d9\u05dd.",
    "Your team could not be created.": "\u05dc\u05d0 \u05e0\u05d9\u05ea\u05df \u05dc\u05d9\u05e6\u05d5\u05e8 \u05d0\u05ea \u05d4\u05e6\u05d5\u05d5\u05ea \u05e9\u05dc\u05da.",
    "Your team could not be updated.": "\u05dc\u05d0 \u05e0\u05d9\u05ea\u05df \u05dc\u05e2\u05d3\u05db\u05df \u05d0\u05ea \u05d4\u05e6\u05d5\u05d5\u05ea \u05e9\u05dc\u05da.",
    "Your unenrollment request could not be processed. Please try again later.": "\u05dc\u05d0 \u05e0\u05d9\u05ea\u05df \u05d4\u05d9\u05d4 \u05dc\u05e2\u05d1\u05d3 \u05d0\u05ea \u05d1\u05e7\u05e9\u05ea \u05d4\u05d1\u05d9\u05d8\u05d5\u05dc \u05e9\u05dc\u05db\u05dd. \u05d1\u05d1\u05e7\u05e9\u05d4 \u05e0\u05e1\u05d5 \u05e9\u05d5\u05d1 \u05de\u05d0\u05d5\u05d7\u05e8 \u05d9\u05d5\u05ea\u05e8.",
    "Your upload of '{file}' failed.": "\u05d4\u05e2\u05dc\u05ea \u05e7\u05d5\u05d1\u05e5 '{file}' \u05e0\u05db\u05e9\u05dc\u05d4.",
    "Your upload of '{file}' succeeded.": "\u05d4\u05e7\u05d5\u05d1\u05e5 '{file}' \u05e0\u05d8\u05e2\u05df \u05d1\u05d4\u05e6\u05dc\u05d7\u05d4.",
    "Your username, email, and full name will be sent to {destination}, where the collection and use of this information will be governed by their terms of service and privacy policy.": "\u05e9\u05dd \u05d4\u05de\u05e9\u05ea\u05de\u05e9, \u05db\u05ea\u05d5\u05d1\u05ea \u05d4\u05d3\u05d5\u05d0\u05e8 \u05d4\u05d0\u05dc\u05e7\u05d8\u05e8\u05d5\u05e0\u05d9 \u05d5\u05e9\u05de\u05da \u05d4\u05de\u05dc\u05d0 \u05d9\u05e9\u05dc\u05d7\u05d5 \u05dc-{destination} \u05d4\u05d9\u05db\u05df \u05e9\u05d4\u05d0\u05d9\u05e1\u05d5\u05e3 \u05d5\u05d4\u05e9\u05d9\u05de\u05d5\u05e9 \u05d1\u05de\u05d9\u05d3\u05e2 \u05d9\u05e0\u05d5\u05d4\u05dc\u05d5 \u05e2\u05dc \u05e4\u05d9 \u05ea\u05e0\u05d0\u05d9 \u05d4\u05e9\u05d9\u05de\u05d5\u05e9 \u05d5\u05de\u05d3\u05d9\u05e0\u05d9\u05d5\u05ea \u05d4\u05e4\u05e8\u05d8\u05d9\u05d5\u05ea \u05e9\u05dc \u05d9\u05e2\u05d3 \u05d4\u05de\u05e9\u05dc\u05d5\u05d7. ",
    "Your verification is pending": "\u05d0\u05d9\u05de\u05d5\u05ea\u05da \u05e0\u05de\u05e6\u05d0 \u05d1\u05d4\u05de\u05ea\u05e0\u05d4",
    "Your verification status is good until {verificationGoodUntil}.": "\u05e1\u05d8\u05d8\u05d5\u05e1 \u05d4\u05d0\u05d9\u05de\u05d5\u05ea \u05e9\u05dc\u05da \u05ea\u05e7\u05e3 \u05e2\u05d3 {verificationGoodUntil}.",
    "Your verified {cert_name_long} is being held pending confirmation that the issuance of your {cert_name_short} is in compliance with strict U.S. embargoes on Iran, Cuba, Syria and Sudan. If you think our system has mistakenly identified you as being connected with one of those countries, please let us know by contacting {email}. If you would like a refund on your {cert_name_long}, please contact our billing address {billing_email}": "\u05ea\u05e2\u05d5\u05d3\u05ea\u05da \u05d4\u05de\u05d0\u05d5\u05de\u05ea\u05ea {cert_name_long} \u05de\u05d5\u05d7\u05d6\u05e7\u05ea \u05d1\u05db\u05e4\u05d5\u05e3 \u05dc\u05d1\u05d9\u05d8\u05d7\u05d5\u05e0\u05d5\u05ea \u05e9-{cert_name_short} \u05e2\u05d5\u05de\u05d3\u05ea \u05d1\u05db\u05dc\u05dc\u05d9 \u05d4\u05d0\u05de\u05d1\u05e8\u05d2\u05d5 \u05d4\u05de\u05d7\u05de\u05d9\u05e8\u05d9\u05dd \u05e9\u05dc \u05d0\u05e8\u05d4\"\u05d1 \u05e2\u05dc \u05d0\u05d9\u05e8\u05d0\u05df, \u05e7\u05d5\u05d1\u05d4, \u05e1\u05d5\u05e8\u05d9\u05d4 \u05d5\u05e1\u05d5\u05d3\u05df. \u05d0\u05dd \u05dc\u05d3\u05e2\u05ea\u05da \u05d4\u05de\u05e2\u05e8\u05db\u05ea \u05e9\u05dc\u05e0\u05d5 \u05d8\u05e2\u05ea\u05d4 \u05d1\u05d6\u05d9\u05d4\u05d5\u05d9\u05d9\u05da \u05db\u05e7\u05e9\u05d5\u05e8 \u05dc\u05de\u05d3\u05d9\u05e0\u05d5\u05ea \u05d0\u05dc\u05d5, \u05e0\u05d0 \u05d4\u05d5\u05d3\u05e2 \u05dc\u05e0\u05d5 \u05d1\u05d0\u05de\u05e6\u05e2\u05d5\u05ea \u05d4\u05d5\u05d3\u05e2\u05ea \u05d3\u05d5\u05d0\u05e8 \u05d0\u05dc\u05e7\u05d8\u05e8\u05d5\u05e0\u05d9 {email}. \u05d0\u05dd \u05d4\u05d9\u05e0\u05da \u05de\u05e2\u05d5\u05e0\u05d9\u05d9\u05df \u05d1\u05d4\u05d7\u05d6\u05e8 \u05e2\u05d1\u05d5\u05e8 {cert_name_long},  \u05d0 \u05e6\u05d5\u05e8 \u05e2\u05de\u05e0\u05d5 \u05e7\u05e9\u05e8 \u05d1\u05db\u05ea\u05d5\u05d1\u05ea \u05d4\u05d1\u05d0\u05d4 {billing_email}.  ",
    "Your video thumbnail image URL": "\u05db\u05ea\u05d5\u05d1\u05ea \u05d4-URL \u05e9\u05dc \u05ea\u05de\u05d5\u05e0\u05ea \u05d4\u05d5\u05d5\u05d9\u05d3\u05d0\u05d5 \u05d4\u05de\u05de\u05d5\u05d6\u05e2\u05e8\u05ea",
    "Your video uploads are not complete.": "\u05d4\u05e2\u05dc\u05d0\u05d5\u05ea \u05e1\u05e8\u05d8\u05d5\u05e0\u05d9 \u05d4\u05d5\u05d5\u05d9\u05d3\u05d0\u05d5 \u05dc\u05d0 \u05d4\u05d5\u05e9\u05dc\u05de\u05d5.",
    "Your words were:": "\u05d4\u05de\u05d9\u05dc\u05d9\u05dd \u05e9\u05dc\u05da \u05d4\u05d9\u05d5:",
    "Your year of birth is required": "\u05e9\u05e0\u05ea \u05dc\u05d9\u05d3\u05d4 \u05d4\u05d5\u05d0 \u05e9\u05d3\u05d4 \u05d7\u05d5\u05d1\u05d4",
    "Your {cert_name_long} is being held pending confirmation that the issuance of your {cert_name_short} is in compliance with strict U.S. embargoes on Iran, Cuba, Syria and Sudan. If you think our system has mistakenly identified you as being connected with one of those countries, please let us know by contacting {email}.": "\u05ea\u05e2\u05d5\u05d3\u05ea\u05da {cert_name_long} \u05de\u05d5\u05d7\u05d6\u05e7\u05ea \u05d1\u05db\u05e4\u05d5\u05e3 \u05dc\u05d1\u05d9\u05d8\u05d7\u05d5\u05e0\u05d5\u05ea \u05e9-{cert_name_short} \u05e2\u05d5\u05de\u05d3\u05ea \u05d1\u05db\u05dc\u05dc\u05d9 \u05d4\u05d0\u05de\u05d1\u05e8\u05d2\u05d5 \u05d4\u05de\u05d7\u05de\u05d9\u05e8\u05d9\u05dd \u05e9\u05dc \u05d0\u05e8\u05d4\"\u05d1 \u05e2\u05dc \u05d0\u05d9\u05e8\u05d0\u05df, \u05e7\u05d5\u05d1\u05d4, \u05e1\u05d5\u05e8\u05d9\u05d4 \u05d5\u05e1\u05d5\u05d3\u05df. \u05d0\u05dd \u05dc\u05d3\u05e2\u05ea\u05da \u05d4\u05de\u05e2\u05e8\u05db\u05ea \u05e9\u05dc\u05e0\u05d5 \u05d8\u05e2\u05ea\u05d4 \u05d1\u05d6\u05d9\u05d4\u05d5\u05d9\u05d9\u05da \u05db\u05e7\u05e9\u05d5\u05e8 \u05dc\u05de\u05d3\u05d9\u05e0\u05d5\u05ea \u05d0\u05dc\u05d5, \u05e0\u05d0 \u05e6\u05d5\u05e8 \u05e2\u05de\u05e0\u05d5 \u05e7\u05e9\u05e8 \u05d1\u05d0\u05de\u05e6\u05e2\u05d5\u05ea {email}. ",
    "Your {cert_name_short} is Generating": "\u05ea\u05e2\u05d5\u05d3\u05ea\u05da {cert_name_short} \u05d1\u05ea\u05d4\u05dc\u05d9\u05db\u05d9 \u05d4\u05e4\u05e7\u05d4",
    "Your {platform_name} ID verification photos have been approved.": "\u05ea\u05de\u05d5\u05e0\u05d5\u05ea \u05d0\u05d9\u05de\u05d5\u05ea \u05d4\u05d6\u05d9\u05d4\u05d5\u05d9 {platform_name} \u05e9\u05dc\u05db\u05dd \u05d0\u05d5\u05e9\u05e8\u05d5.",
    "Your {platform_name} ID verification was approved!": "\u05d0\u05d9\u05de\u05d5\u05ea \u05d4\u05d6\u05d9\u05d4\u05d5\u05d9 \u05e9\u05dc\u05db\u05dd \u05d1-{platform_name} \u05d0\u05d5\u05e9\u05e8!",
    "Your {platform_name} Verification Has Been Denied": "\u05d0\u05d9\u05de\u05d5\u05ea {platform_name} \u05e9\u05dc\u05db\u05dd \u05e0\u05d3\u05d7\u05d4",
    "Your {platform_name} account email has been updated": "\u05db\u05ea\u05d5\u05d1\u05ea \u05d4\u05d3\u05d5\u05d0\"\u05dc \u05e9\u05dc \u05d7\u05e9\u05d1\u05d5\u05df {platform_name} \u05e9\u05dc\u05db\u05dd \u05e2\u05d5\u05d3\u05db\u05e0\u05d4",
    "Your {platform_name} verification has expired.": "\u05d0\u05d9\u05de\u05d5\u05ea \u05dc {platform_name} \u05e4\u05d2 \u05ea\u05d5\u05e7\u05e3.",
    "Your {program} Certificate": "\u05ea\u05e2\u05d5\u05d3\u05ea {program} \u05e9\u05dc\u05db\u05dd",
    "Your {task_name} task has completed with the status '{task_status}'. Sign in to view the details of your task or download any files created.": "\u05d4\u05de\u05e9\u05d9\u05de\u05d4 {task_name} \u05d4\u05d5\u05e9\u05dc\u05de\u05d4 \u05d5\u05d4\u05d9\u05d0 \u05d1\u05e1\u05d8\u05d8\u05d5\u05e1 '{task_status}'. \u05d4\u05d9\u05db\u05e0\u05e1 \u05db\u05d3\u05d9 \u05dc\u05e8\u05d0\u05d5\u05ea \u05d0\u05ea \u05e4\u05e8\u05d8\u05d9 \u05d4\u05de\u05e9\u05d9\u05de\u05d4 \u05d0\u05d5 \u05dc\u05d4\u05d5\u05e8\u05d9\u05d3 \u05e7\u05d1\u05e6\u05d9\u05dd \u05e9\u05e0\u05d5\u05e6\u05e8\u05d5.",
    "Your {task_name} task has completed with the status '{task_status}'. Use this URL to view task details or download any files created: {detail_url}": "\u05d4\u05de\u05e9\u05d9\u05de\u05d4 {task_name} \u05d4\u05d5\u05e9\u05dc\u05de\u05d4 \u05d5\u05d4\u05d9\u05d0 \u05d1\u05e1\u05d8\u05d8\u05d5\u05e1  '{task_status}'. \u05d4\u05e9\u05ea\u05de\u05e9 \u05d1\u05db\u05ea\u05d5\u05d1\u05ea URL \u05d6\u05d5 \u05db\u05d3\u05d9 \u05dc\u05e8\u05d0\u05d5\u05ea \u05d0\u05ea \u05e4\u05e8\u05d8\u05d9 \u05d4\u05de\u05e9\u05d9\u05de\u05d4 \u05d0\u05d5 \u05dc\u05d4\u05d5\u05e8\u05d9\u05d3 \u05e7\u05d1\u05e6\u05d9\u05dd \u05e9\u05e0\u05d5\u05e6\u05e8\u05d5: {detail_url}",
    "Yourself": "\u05d0\u05ea\u05d4",
