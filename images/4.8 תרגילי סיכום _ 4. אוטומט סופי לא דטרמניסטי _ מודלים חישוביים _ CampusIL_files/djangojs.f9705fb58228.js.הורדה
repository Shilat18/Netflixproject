    "Add to Mozilla Backpack": "\u05d4\u05d5\u05e1\u05e3 \u05dc-Mozilla Backpack",
    "Add to article": "\u05d4\u05d5\u05e1\u05e4\u05d4 \u05dc\u05e2\u05e8\u05da",
    "Add transcripts in different languages. Click below to specify a language and upload an .srt transcript file for that language.": "\u05d4\u05d5\u05e1\u05e4\u05ea \u05ea\u05de\u05dc\u05d9\u05dc\u05d9\u05dd \u05d1\u05e9\u05e4\u05d5\u05ea \u05e9\u05d5\u05e0\u05d5\u05ea. \u05dc\u05d7\u05e5 \u05dc\u05de\u05d8\u05d4 \u05db\u05d3\u05d9 \u05dc\u05e6\u05d9\u05d9\u05df \u05e9\u05e4\u05d4 \u05d5\u05dc\u05d4\u05e2\u05dc\u05d5\u05ea \u05e7\u05d5\u05d1\u05e5 \u05ea\u05de\u05dc\u05d9\u05dc srt. \u05e2\u05d1\u05d5\u05e8 \u05e9\u05e4\u05d4 \u05d6\u05d5.",
    "Add your first content group": "\u05d4\u05d5\u05e1\u05e3 \u05d0\u05ea \u05e7\u05d1\u05d5\u05e6\u05ea \u05d4\u05ea\u05d5\u05db\u05df \u05d4\u05e8\u05d0\u05e9\u05d5\u05e0\u05d4 \u05e9\u05dc\u05da",
    "Add your first group configuration": "\u05d4\u05d5\u05e1\u05e3 \u05d0\u05ea \u05d4\u05d2\u05d3\u05e8\u05ea \u05ea\u05e6\u05d5\u05e8\u05ea \u05e7\u05d1\u05d5\u05e6\u05ea\u05da \u05d4\u05e8\u05d0\u05e9\u05d5\u05e0\u05d4 ",
    "Add your first textbook": "\u05d4\u05d5\u05e1\u05e3 \u05d0\u05ea \u05e1\u05e4\u05e8 \u05d4\u05dc\u05d9\u05de\u05d5\u05d3 \u05d4\u05e8\u05d0\u05e9\u05d5\u05df \u05e9\u05dc\u05da",
    "Add your post to a relevant topic to help others find it. (Required)": "\u05d4\u05d5\u05e1\u05e3 \u05d0\u05ea \u05d4\u05e4\u05d5\u05e1\u05d8 \u05e9\u05dc\u05da \u05dc\u05e0\u05d5\u05e9\u05d0 \u05d4\u05e8\u05dc\u05d5\u05d5\u05e0\u05d8\u05d9 \u05e2\u05dc \u05de\u05e0\u05ea \u05dc\u05d4\u05e7\u05dc \u05e2\u05dc \u05d0\u05d7\u05e8\u05d9\u05dd \u05dc\u05de\u05e6\u05d5\u05d0 \u05d0\u05d5\u05ea\u05d5. (\u05d7\u05d5\u05d1\u05d4)",
    "Add {role} Access": "\u05d4\u05d5\u05e1\u05e3 \u05d2\u05d9\u05e9\u05ea {role}",
    "Added Course": "\u05e0\u05d5\u05e1\u05e3 \u05e7\u05d5\u05e8\u05e1",
    "Added a reference to \"%(att)s\" from \"%(art)s\".": "\u05e0\u05d5\u05e1\u05e4\u05d4 \u05d4\u05e4\u05e0\u05d9\u05d9\u05d4 \"%(att)s\" \u05de\u05ea\u05d5\u05da \"%(art)s\".",
    "Adding": "\u05de\u05d5\u05e1\u05d9\u05e3",
    "Adding components": "\u05d4\u05d5\u05e1\u05e4\u05ea \u05e8\u05db\u05d9\u05d1\u05d9\u05dd",
    "Adding content to your library": "\u05d4\u05d5\u05e1\u05e4\u05ea \u05ea\u05d5\u05db\u05df \u05dc\u05e1\u05e4\u05e8\u05d9\u05d4 \u05e9\u05dc\u05da",
    "Adding new articles": "\u05d4\u05d5\u05e1\u05e4\u05ea \u05e2\u05e8\u05db\u05d9\u05dd \u05d7\u05d3\u05e9\u05d9\u05dd",
    "Adding team members makes course authoring collaborative. Users must be signed up for {studio_name} and have an active account.": "\u05d4\u05d5\u05e1\u05e4\u05ea \u05d7\u05d1\u05e8\u05d9 \u05e6\u05d5\u05d5\u05ea \u05d4\u05d5\u05e4\u05db\u05ea \u05d0\u05ea \u05de\u05dc\u05d0\u05db\u05ea \u05d9\u05e6\u05d9\u05e8\u05ea \u05d4\u05e7\u05d5\u05e8\u05e1 \u05dc\u05e9\u05d9\u05ea\u05d5\u05e4\u05d9\u05ea. \u05de\u05e9\u05ea\u05de\u05e9\u05d9\u05dd \u05d7\u05d9\u05d9\u05d1\u05d9\u05dd \u05dc\u05d4\u05d9\u05d5\u05ea \u05e8\u05e9\u05d5\u05de\u05d9\u05dd \u05dc{studio_name} \u05d5\u05dc\u05d4\u05d7\u05d6\u05d9\u05e7 \u05d7\u05e9\u05d1\u05d5\u05df \u05e4\u05e2\u05d9\u05dc. ",
    "Adding the selected course to your cart": "\u05d4\u05d5\u05e1\u05e4\u05ea \u05d4\u05e7\u05d5\u05e8\u05e1 \u05e9\u05e0\u05d1\u05d7\u05e8 \u05dc\u05e2\u05d2\u05dc\u05ea \u05d4\u05e7\u05e0\u05d9\u05d5\u05ea \u05e9\u05dc\u05da",
    "Adding user \"{username}\" to groups {group_names}": "\u05d4\u05d5\u05e1\u05e4\u05ea \u05d4\u05de\u05e9\u05ea\u05de\u05e9 \"{username}\" \u05dc\u05e7\u05d1\u05d5\u05e6\u05d5\u05ea {group_names}",
    "Adding {codenames} permissions to group \"{group}\"": "\u05d4\u05d5\u05e1\u05e4\u05ea \u05d4\u05e8\u05e9\u05d0\u05d5\u05ea {codenames} \u05dc\u05e7\u05d1\u05d5\u05e6\u05d4 \"{group}\"",
    "Additional Credit Opportunities": "\u05d4\u05d6\u05d3\u05de\u05e0\u05d5\u05d9\u05d5\u05ea \u05e7\u05e8\u05d3\u05d9\u05d8 \u05e0\u05d5\u05e1\u05e4\u05d5\u05ea",
    "Additional Info:": "\u05de\u05d9\u05d3\u05e2 \u05e0\u05d5\u05e1\u05e3:",
    "Additional Information": "\u05de\u05d9\u05d3\u05e2 \u05e0\u05d5\u05e1\u05e3",
    "Additional Personal Information": "\u05de\u05d9\u05d3\u05e2 \u05d0\u05d9\u05e9\u05d9 \u05e0\u05d5\u05e1\u05e3",
    "Additional Professional Opportunities": "\u05d4\u05d6\u05d3\u05de\u05e0\u05d5\u05d9\u05d5\u05ea \u05de\u05e7\u05e6\u05d5\u05e2\u05d9\u05d5\u05ea \u05e0\u05d5\u05e1\u05e4\u05d5\u05ea",
    "Additional Resources": "\u05de\u05e9\u05d0\u05d1\u05d9\u05dd \u05e0\u05d5\u05e1\u05e4\u05d9\u05dd",
    "Additional Time (minutes)": "\u05ea\u05d5\u05e1\u05e4\u05ea \u05d6\u05de\u05df (\u05d3\u05e7\u05d5\u05ea)",
    "Additional posts could not be loaded. Refresh the page and try again.": "\u05dc\u05d0 \u05e0\u05d9\u05ea\u05df \u05dc\u05d4\u05e2\u05dc\u05d5\u05ea \u05e4\u05d5\u05e1\u05d8\u05d9\u05dd \u05e0\u05d5\u05e1\u05e4\u05d9\u05dd. \u05e8\u05e2\u05e0\u05df \u05d0\u05ea \u05d4\u05e2\u05de\u05d5\u05d3 \u05d5\u05e0\u05e1\u05d4 \u05e9\u05e0\u05d9\u05ea.",
    "Additional responses could not be loaded. Refresh the page and try again.": "\u05dc\u05d0 \u05e0\u05d9\u05ea\u05df \u05dc\u05d4\u05e2\u05dc\u05d5\u05ea \u05ea\u05d2\u05d5\u05d1\u05d5\u05ea \u05e0\u05d5\u05e1\u05e4\u05d5\u05ea. \u05e8\u05e2\u05e0\u05df \u05d0\u05ea \u05d4\u05e2\u05de\u05d5\u05d3 \u05d5\u05e0\u05e1\u05d4 \u05e9\u05e0\u05d9\u05ea.",
    "Address Line 1": "\u05e9\u05d5\u05e8\u05ea \u05db\u05ea\u05d5\u05d1\u05ea 1",
    "Address Line 2": "\u05e9\u05d5\u05e8\u05ea \u05db\u05ea\u05d5\u05d1\u05ea 2",
    "Address Line 3": "\u05e9\u05d5\u05e8\u05ea \u05db\u05ea\u05d5\u05d1\u05ea 3",
    "Adjust a learner's entrance exam results": "\u05d4\u05ea\u05d0\u05dd \u05d0\u05ea \u05ea\u05d5\u05e6\u05d0\u05d5\u05ea \u05de\u05d1\u05d7\u05df \u05d4\u05db\u05e0\u05d9\u05e1\u05d4 \u05e9\u05dc \u05d4\u05dc\u05d5\u05de\u05d3",
    "Adjust a learner's grade for a specific problem": "\u05d4\u05ea\u05d0\u05dd \u05e6\u05d9\u05d5\u05df \u05e9\u05dc \u05ea\u05dc\u05de\u05d9\u05d3 \u05dc\u05d1\u05e2\u05d9\u05d4 \u05e1\u05e4\u05e6\u05d9\u05e4\u05d9\u05ea",
    "Adjust all enrolled learners' grades for a specific problem": "\u05d4\u05ea\u05d0\u05dd \u05d0\u05ea \u05db\u05dc \u05e6\u05d9\u05d5\u05e0\u05d9 \u05d4\u05dc\u05d5\u05de\u05d3 \u05e9\u05e0\u05e8\u05e9\u05dd \u05dc\u05d1\u05e2\u05d9\u05d4 \u05de\u05e1\u05d5\u05d9\u05de\u05ea",
    "Adjust video speed": "\u05d4\u05ea\u05d0\u05dd \u05d0\u05ea \u05de\u05d4\u05d9\u05e8\u05d5\u05ea \u05e1\u05e8\u05d8\u05d5\u05df \u05d4\u05d5\u05d5\u05d9\u05d3\u05d0\u05d5",
    "Adjust video volume": "\u05d4\u05ea\u05d0\u05dd \u05d0\u05ea \u05e2\u05d5\u05e6\u05de\u05ea \u05d4\u05e7\u05d5\u05dc \u05e9\u05dc \u05e1\u05e8\u05d8\u05d5\u05df \u05d4\u05d5\u05d5\u05d9\u05d3\u05d0\u05d5",
    "Admin": "\u05de\u05d9\u05e0\u05d4\u05dc",
    "Administer Courses": "\u05e0\u05d4\u05dc \u05e7\u05d5\u05e8\u05e1\u05d9\u05dd",
    "Administer users and author content": "\u05ea\u05d5\u05db\u05df \u05de\u05e0\u05d4\u05dc\u05d9\u05dd \u05d5\u05db\u05d5\u05ea\u05d1\u05d9\u05dd",
    "Administrator": "\u05de\u05e0\u05d4\u05dc",
    "Admins are course team members who can add and remove other course team members.": "\u05de\u05e0\u05d4\u05dc\u05d9\u05dd \u05d4\u05dd \u05d7\u05d1\u05e8\u05d9\u05dd \u05d1\u05e6\u05d5\u05d5\u05ea \u05d4\u05e7\u05d5\u05e8\u05e1 \u05d4\u05d9\u05db\u05d5\u05dc\u05d9\u05dd \u05dc\u05d4\u05d5\u05e1\u05d9\u05e3 \u05d0\u05d5 \u05dc\u05d4\u05e1\u05d9\u05e8 \u05d7\u05d1\u05e8\u05d9\u05dd \u05d0\u05d7\u05e8\u05d9\u05dd \u05d1\u05e6\u05d5\u05d5\u05ea \u05d4\u05e7\u05d5\u05e8\u05e1.",
    "Advanced": "\u05de\u05ea\u05e7\u05d3\u05dd",
    "Advanced Editor": "\u05e2\u05d5\u05e8\u05da \u05de\u05ea\u05e7\u05d3\u05dd",
    "Advanced Module List": "\u05e8\u05e9\u05d9\u05de\u05ea \u05de\u05d5\u05d3\u05d5\u05dc\u05d9\u05dd \u05de\u05ea\u05e7\u05d3\u05de\u05ea",
    "Advanced Settings": "\u05d4\u05d2\u05d3\u05e8\u05d5\u05ea \u05de\u05ea\u05e7\u05d3\u05de\u05d5\u05ea",
    "Advanced settings control specific course functionality. On this page, you can edit manual policies, which are JSON-based key and value pairs that control specific course settings.": "\u05d4\u05d2\u05d3\u05e8\u05d5\u05ea \u05de\u05ea\u05e7\u05d3\u05de\u05d5\u05ea \u05e9\u05d5\u05dc\u05d8\u05d5\u05ea \u05d1\u05ea\u05e4\u05e7\u05d5\u05d3\u05d9\u05dd \u05de\u05e1\u05d5\u05d9\u05de\u05d9\u05dd \u05e9\u05dc \u05d4\u05e7\u05d5\u05e8\u05e1. \u05d1\u05e2\u05de\u05d5\u05d3 \u05d6\u05d4, \u05e0\u05d9\u05ea\u05df \u05dc\u05e2\u05e8\u05d5\u05da \u05d9\u05d3\u05e0\u05d9\u05ea \u05d0\u05ea \u05de\u05d3\u05d9\u05e0\u05d9\u05d5\u05ea \u05d4\u05e7\u05d5\u05e8\u05e1 \u05e9\u05d4\u05d9\u05e0\u05d4 \u05de\u05e4\u05ea\u05d7\u05d5\u05ea \u05d0\u05d5 \u05e6\u05de\u05d3 \u05e2\u05e8\u05db\u05d9\u05dd \u05de\u05d1\u05d5\u05e1\u05e1\u05d9 JSON, \u05d4\u05e9\u05d5\u05dc\u05d8\u05d9\u05dd \u05d1\u05d4\u05d2\u05d3\u05e8\u05d5\u05ea \u05e7\u05d5\u05e8\u05e1 \u05de\u05e1\u05d5\u05d9\u05de\u05d5\u05ea.",
    "Advanced users only.": "\u05dc\u05de\u05e9\u05ea\u05de\u05e9\u05d9\u05dd \u05de\u05ea\u05e7\u05d3\u05de\u05d9\u05dd \u05d1\u05dc\u05d1\u05d3",
    "Affiliates": "\u05d2\u05d5\u05e8\u05de\u05d9\u05dd \u05de\u05e9\u05d5\u05d9\u05db\u05d9\u05dd",
    "Affixes": "\u05ea\u05d5\u05d5\u05d9\u05dd \u05de\u05d9\u05d5\u05d7\u05d3\u05d9\u05dd",
    "After All Attempts": "\u05dc\u05d0\u05d7\u05e8 \u05db\u05dc \u05d4\u05e0\u05d9\u05e1\u05d9\u05d5\u05e0\u05d5\u05ea",
    "After All Attempts or Correct": "\u05dc\u05d0\u05d7\u05e8 \u05db\u05dc \u05d4\u05e0\u05d9\u05e1\u05d9\u05d5\u05e0\u05d5\u05ea \u05d0\u05d5 \u05e0\u05db\u05d5\u05df",
    "After Some Number of Attempts": "\u05dc\u05d0\u05d7\u05e8 \u05de\u05e1\u05e4\u05e8 \u05e0\u05d9\u05e1\u05d9\u05d5\u05e0\u05d5\u05ea",
    "After the course ends, the course content will be archived and no longer active.": "\u05dc\u05d0\u05d7\u05e8 \u05e1\u05d9\u05d5\u05dd \u05d4\u05e7\u05d5\u05e8\u05e1, \u05ea\u05d5\u05db\u05df \u05d4\u05e7\u05d5\u05e8\u05e1 \u05d9\u05d9\u05e9\u05dc\u05d7 \u05dc\u05d0\u05e8\u05db\u05d9\u05d5\u05df \u05d5\u05dc\u05d0 \u05d9\u05d4\u05d9\u05d4 \u05e4\u05e2\u05d9\u05dc \u05d9\u05d5\u05ea\u05e8.",
    "After the course's end date has passed, learners can no longer access subsection content. The subsection remains included in grade calculations.": "\u05dc\u05d0\u05d7\u05e8 \u05e9\u05ea\u05d0\u05e8\u05d9\u05da \u05d4\u05d9\u05e2\u05d3 \u05e9\u05dc \u05ea\u05ea \u05d4\u05e4\u05e8\u05e7 \u05e2\u05d1\u05e8, \u05d4\u05dc\u05d5\u05de\u05d3\u05d9\u05dd \u05d0\u05d9\u05e0\u05dd \u05d9\u05db\u05d5\u05dc\u05d9\u05dd \u05d9\u05d5\u05ea\u05e8 \u05dc\u05d2\u05e9\u05ea \u05dc\u05ea\u05d5\u05db\u05df \u05ea\u05ea \u05d4\u05e4\u05e8\u05e7. \u05ea\u05ea \u05d4\u05e4\u05e8\u05e7 \u05d0\u05d9\u05e0\u05d5 \u05db\u05dc\u05d5\u05dc \u05d1\u05d7\u05d9\u05e9\u05d5\u05d1\u05d9 \u05d4\u05e6\u05d9\u05d5\u05df.",
    "After the subsection's due date has passed, learners can no longer access its content. The subsection remains included in grade calculations.": "\u05dc\u05d0\u05d7\u05e8 \u05e9\u05ea\u05d0\u05e8\u05d9\u05da \u05d4\u05d9\u05e2\u05d3 \u05e9\u05dc \u05ea\u05ea \u05d4\u05e4\u05e8\u05e7 \u05e2\u05d1\u05e8, \u05d4\u05dc\u05d5\u05de\u05d3\u05d9\u05dd \u05d0\u05d9\u05e0\u05dd \u05d9\u05db\u05d5\u05dc\u05d9\u05dd \u05d9\u05d5\u05ea\u05e8 \u05dc\u05d2\u05e9\u05ea \u05dc\u05ea\u05d5\u05db\u05e0\u05d5. \u05ea\u05ea \u05d4\u05e4\u05e8\u05e7 \u05e0\u05e9\u05d0\u05e8 \u05db\u05dc\u05d5\u05dc \u05d1\u05d7\u05d9\u05e9\u05d5\u05d1\u05d9 \u05d4\u05d3\u05d9\u05e8\u05d5\u05d2.",
    "After this course officially ends, you will receive an email notification with your certificate.": "\u05dc\u05d0\u05d7\u05e8 \u05de\u05d5\u05e2\u05d3 \u05d4\u05e1\u05d9\u05d5\u05dd \u05d4\u05e8\u05e9\u05de\u05d9 \u05e9\u05dc \u05d4\u05e7\u05d5\u05e8\u05e1, \u05d4\u05ea\u05e2\u05d5\u05d3\u05d4 \u05e9\u05dc\u05da \u05ea\u05e9\u05dc\u05d7 \u05dc\u05db\u05ea\u05d5\u05d1\u05ea \u05d4\u05de\u05d9\u05d9\u05dc \u05d0\u05d9\u05ea\u05d4 \u05e0\u05e8\u05e9\u05de\u05ea \u05dc\u05d0\u05ea\u05e8.",
    "After this date, course content will be archived.": "\u05dc\u05d0\u05d7\u05e8 \u05ea\u05d0\u05e8\u05d9\u05da \u05d6\u05d4, \u05ea\u05d5\u05db\u05df \u05d4\u05e7\u05d5\u05e8\u05e1 \u05d9\u05d0\u05d5\u05d7\u05e1\u05df \u05d1\u05d0\u05e8\u05db\u05d9\u05d5\u05df.",
    "After this date, the course will be archived, which means you can review the course content but can no longer participate in graded assignments or work towards earning a certificate.": "\u05dc\u05d0\u05d7\u05e8 \u05ea\u05d0\u05e8\u05d9\u05da \u05d6\u05d4, \u05d4\u05e7\u05d5\u05e8\u05e1 \u05d9\u05d9\u05e9\u05dc\u05d7 \u05dc\u05d0\u05e8\u05db\u05d9\u05d5\u05df, \u05de\u05d4 \u05e9\u05d0\u05d5\u05de\u05e8 \u05e9\u05e0\u05d9\u05ea\u05df \u05dc\u05e2\u05d1\u05d5\u05e8 \u05e2\u05dc \u05ea\u05d5\u05db\u05df \u05d4\u05e7\u05d5\u05e8\u05e1 \u05d0\u05d1\u05dc \u05d0\u05d9 \u05d0\u05e4\u05e9\u05e8 \u05dc\u05d4\u05e9\u05ea\u05ea\u05e3 \u05d9\u05d5\u05ea\u05e8 \u05d1\u05de\u05e9\u05d9\u05de\u05d5\u05ea \u05e2\u05dd \u05e6\u05d9\u05d5\u05e0\u05d9\u05dd \u05d0\u05d5 \u05dc\u05e2\u05d1\u05d5\u05d3 \u05db\u05d3\u05d9 \u05dc\u05e7\u05d1\u05dc \u05ea\u05e2\u05d5\u05d3\u05d4.",
    "After this, it's important to do a manual review.": "\u05dc\u05d0\u05d7\u05e8 \u05de\u05db\u05df, \u05d7\u05e9\u05d5\u05d1 \u05dc\u05d1\u05e6\u05e2 \u05e1\u05e7\u05d9\u05e8\u05d4 \u05d9\u05d3\u05e0\u05d9\u05ea.",
    "After uploading an image, it is attached to this particular artice and can be used only here. Other users may replace the image, but older versions are kept. You probably want to show the image with a nice caption. To achieve this, press the Insert button and fill in the caption fields and possibly choose to have you image floating right or left of the content. You can use Markdown in the caption. The markdown code syntax for images looks like this, possible values for align are left/center/right:": "\u05dc\u05d0\u05d7\u05e8 \u05d4\u05e2\u05dc\u05d0\u05ea \u05ea\u05de\u05d5\u05e0\u05d4, \u05d4\u05d9\u05d0 \u05de\u05e6\u05d5\u05e8\u05e4\u05ea \u05dc\u05de\u05d0\u05de\u05e8 \u05e1\u05e4\u05e6\u05d9\u05e4\u05d9 \u05d6\u05d4 \u05d5\u05e0\u05d9\u05ea\u05df \u05dc\u05d4\u05e9\u05ea\u05de\u05e9 \u05d1\u05d4 \u05e8\u05e7 \u05db\u05d0\u05df. \u05de\u05e9\u05ea\u05de\u05e9\u05d9\u05dd \u05d0\u05d7\u05e8\u05d9\u05dd \u05d9\u05db\u05d5\u05dc\u05d9\u05dd \u05dc\u05d4\u05d7\u05dc\u05d9\u05e3 \u05d0\u05ea \u05d4\u05ea\u05de\u05d5\u05e0\u05d4, \u05d0\u05da \u05d2\u05e8\u05e1\u05d0\u05d5\u05ea \u05d9\u05e9\u05e0\u05d5\u05ea \u05d9\u05d5\u05ea\u05e8 \u05e0\u05e9\u05de\u05e8\u05d5\u05ea. \u05db\u05db\u05dc \u05d4\u05e0\u05e8\u05d0\u05d4 \u05ea\u05e8\u05e6\u05d5 \u05dc\u05d4\u05e6\u05d9\u05d2 \u05d0\u05ea \u05d4\u05ea\u05de\u05d5\u05e0\u05d4 \u05e2\u05dd \u05db\u05d9\u05ea\u05d5\u05d1 \u05e0\u05d7\u05de\u05d3. \u05dc\u05e9\u05dd \u05db\u05da, \u05dc\u05d7\u05e6\u05d5 \u05e2\u05dc \u05db\u05e4\u05ea\u05d5\u05e8 \u05d4\u05d5\u05e1\u05e4\u05d4 \u05d5\u05de\u05dc\u05d0\u05d5 \u05d0\u05ea \u05e9\u05d3\u05d5\u05ea \u05d4\u05db\u05d9\u05ea\u05d5\u05d1 \u05d5\u05d0\u05d5\u05dc\u05d9 \u05d1\u05d7\u05e8\u05d5 \u05ea\u05de\u05d5\u05e0\u05d4 \u05e9\u05dc\u05db\u05dd \u05de\u05e8\u05d7\u05e4\u05ea \u05de\u05d9\u05de\u05d9\u05df \u05d0\u05d5 \u05de\u05e9\u05de\u05d0\u05dc \u05dc\u05ea\u05d5\u05db\u05df. \u05ea\u05d5\u05db\u05dc\u05d5 \u05dc\u05d4\u05e9\u05ea\u05de\u05e9 \u05d1-Markdown \u05d1\u