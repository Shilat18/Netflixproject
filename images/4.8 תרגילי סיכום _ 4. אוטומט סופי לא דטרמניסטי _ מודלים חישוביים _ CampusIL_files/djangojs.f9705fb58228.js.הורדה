    "Certificate generation started for students on the allowlist.": "\u05d4\u05e4\u05e7\u05ea \u05ea\u05e2\u05d5\u05d3\u05d4 \u05d4\u05d5\u05ea\u05d7\u05dc\u05d4 \u05e2\u05d1\u05d5\u05e8 \u05e1\u05d8\u05d5\u05d3\u05e0\u05d8\u05d9\u05dd \u05d1\u05e8\u05e9\u05d9\u05de\u05ea \u05d4\u05d4\u05d9\u05ea\u05e8\u05d9\u05dd.",
    "Certificate generation started for white listed students.": "\u05d9\u05e6\u05d9\u05e8\u05ea \u05d4\u05ea\u05e2\u05d5\u05d3\u05d4 \u05d4\u05d7\u05dc\u05d4 \u05dc\u05e1\u05d8\u05d5\u05d3\u05e0\u05d8\u05d9\u05dd \u05e9\u05d1\u05e8\u05e9\u05d9\u05de\u05d4 \u05d4\u05dc\u05d1\u05e0\u05d4.",
    "Certificate generation task for all students of this course has been started. You can view the status of the generation task in the \"Pending Tasks\" section.": "\u05de\u05e9\u05d9\u05de\u05ea \u05d9\u05e6\u05d9\u05e8\u05ea \u05d4\u05ea\u05e2\u05d5\u05d3\u05d4 \u05dc\u05db\u05dc \u05d4\u05e1\u05d8\u05d5\u05d3\u05e0\u05d8\u05d9\u05dd \u05d1\u05e7\u05d5\u05e8\u05e1 \u05d6\u05d4 \u05d4\u05d7\u05dc\u05d4. \u05d1\u05d0\u05e4\u05e9\u05e8\u05d5\u05ea\u05da \u05dc\u05d1\u05d3\u05d5\u05e7 \u05d0\u05ea \u05e1\u05d8\u05d8\u05d5\u05e1 \u05de\u05e9\u05d9\u05de\u05ea \u05d4\u05d9\u05e6\u05d9\u05e8\u05d4 \u05d1\u05e1\u05e2\u05d9\u05e3 \"\u05de\u05e9\u05d9\u05de\u05d5\u05ea \u05d1\u05d4\u05de\u05ea\u05e0\u05d4\".",
    "Certificate has already been created.": "\u05ea\u05e2\u05d5\u05d3\u05d4 \u05e0\u05d5\u05e6\u05e8\u05d4.",
    "Certificate has been successfully invalidated for <%= user %>.": "\u05d4\u05ea\u05e2\u05d5\u05d3\u05d4 \u05e9\u05dc <%= user %> \u05e0\u05e4\u05e1\u05dc\u05d4 \u05d1\u05d4\u05e6\u05dc\u05d7\u05d4.",
    "Certificate is being created.": "\u05d4\u05ea\u05e2\u05d5\u05d3\u05d4 \u05e0\u05d5\u05e6\u05e8\u05ea.",
    "Certificate name is required.": "\u05e9\u05dd \u05d4\u05ea\u05e2\u05d5\u05d3\u05d4 \u05d4\u05d5\u05d0 \u05e9\u05d3\u05d4 \u05d7\u05d5\u05d1\u05d4.",
    "Certificate of <%= user %> has already been invalidated. Please check your spelling and retry.": "\u05d4\u05ea\u05e2\u05d5\u05d3\u05d4 \u05e9\u05dc <%= user %> \u05db\u05d1\u05e8 \u05e0\u05e4\u05e1\u05dc\u05d4. \u05d1\u05d3\u05d5\u05e7 \u05d0\u05ea \u05d4\u05d0\u05d9\u05d5\u05ea \u05d5\u05e0\u05e1\u05d4 \u05e9\u05d5\u05d1.",
    "Certificate of {user} has already been invalidated. Please check your spelling and retry.": "\u05d4\u05ea\u05e2\u05d5\u05d3\u05d4 \u05e9\u05dc {user} \u05e0\u05e4\u05e1\u05dc\u05d4 \u05db\u05d1\u05e8. \u05d1\u05d3\u05d5\u05e7 \u05d0\u05ea \u05d4\u05d0\u05d9\u05d5\u05ea \u05d5\u05e0\u05e1\u05d4 \u05e9\u05d5\u05d1.",
    "Certificate purchases help {platform_name} continue to offer free courses": "\u05e8\u05db\u05d9\u05e9\u05d5\u05ea \u05e9\u05dc \u05ea\u05e2\u05d5\u05d3\u05d5\u05ea \u05e2\u05d5\u05d6\u05e8\u05d5\u05ea \u05dc-{platform_name} \u05dc\u05d4\u05de\u05e9\u05d9\u05da \u05dc\u05d4\u05e6\u05d9\u05e2 \u05e7\u05d5\u05e8\u05e1\u05d9\u05dd \u05d1\u05d7\u05d9\u05e0\u05dd",
    "Certificate regeneration task has been started. You can view the status of the generation task in the \"Pending Tasks\" section.": "\u05de\u05e9\u05d9\u05de\u05ea \u05d4\u05d9\u05e6\u05d9\u05e8\u05d4 \u05de\u05d7\u05d3\u05e9 \u05e9\u05dc \u05ea\u05e2\u05d5\u05d3\u05d4 \u05d4\u05d7\u05dc\u05d4. \u05d1\u05d0\u05e4\u05e9\u05e8\u05d5\u05ea\u05da \u05dc\u05d1\u05d3\u05d5\u05e7 \u05d0\u05ea \u05e1\u05d8\u05d8\u05d5\u05e1 \u05de\u05e9\u05d9\u05de\u05ea \u05d4\u05d9\u05e6\u05d9\u05e8\u05d4 \u05d1\u05e1\u05e2\u05d9\u05e3 \"\u05de\u05e9\u05d9\u05de\u05d5\u05ea \u05d1\u05d4\u05de\u05ea\u05e0\u05d4\".",
    "Certificate unavailable": "\u05d4\u05ea\u05e2\u05d5\u05d3\u05d4 \u05d0\u05d9\u05e0\u05d4 \u05d6\u05de\u05d9\u05e0\u05d4",
    "Certificates": "\u05ea\u05e2\u05d5\u05d3\u05d5\u05ea",
    "Certificates Available Date": "\u05ea\u05d0\u05e8\u05d9\u05da \u05d6\u05de\u05d9\u05e0\u05d5\u05ea \u05ea\u05e2\u05d5\u05d3\u05d5\u05ea",
    "Certificates Display Behavior": "\u05ea\u05e2\u05d5\u05d3\u05d5\u05ea \u05d4\u05de\u05e6\u05d9\u05d2\u05d5\u05ea \u05d4\u05ea\u05e0\u05d4\u05d2\u05d5\u05ea",
    "Certificates Downloadable Before End": "\u05e0\u05d9\u05ea\u05df \u05dc\u05d4\u05d5\u05e8\u05d9\u05d3 \u05ea\u05e2\u05d5\u05d3\u05d5\u05ea \u05e1\u05d9\u05d5\u05dd \u05dc\u05e4\u05e0\u05d9 \u05de\u05d5\u05e2\u05d3 \u05d4\u05e1\u05d9\u05d5\u05dd",
    "Certificates are awarded at the end of a course run": "\u05ea\u05e2\u05d5\u05d3\u05d5\u05ea \u05de\u05d5\u05e2\u05e0\u05e7\u05d5\u05ea \u05d1\u05ea\u05d5\u05dd \u05d4\u05e7\u05d5\u05e8\u05e1",
    "Certificates issued by {platform_name} are signed by a gpg key so that they can be validated independently by anyone with the {platform_name} public key. For independent verification, {platform_name} uses what is called a \"detached signature\"&quot;\".": "\u05ea\u05e2\u05d5\u05d3\u05d5\u05ea \u05e9\u05d4\u05d5\u05e0\u05e4\u05e7\u05d5 \u05d1\u05d9\u05d3\u05d9 {platform_name} \u05d7\u05ea\u05d5\u05de\u05d5\u05ea \u05e2\u05dc \u05d9\u05d3\u05d9 \u05de\u05e4\u05ea\u05d7 gpg \u05db\u05da \u05e9\u05db\u05dc \u05d0\u05d7\u05d3 \u05d1\u05e2\u05dc \u05de\u05e4\u05ea\u05d7 \u05e6\u05d9\u05d1\u05d5\u05e8\u05d9 \u05e9\u05dc {platform_name}, \u05d9\u05db\u05d5\u05dc \u05dc\u05d0\u05de\u05ea \u05d0\u05d5\u05ea\u05df \u05d1\u05d0\u05d5\u05e4\u05df \u05e2\u05e6\u05de\u05d0\u05d9. \u05dc\u05d0\u05d9\u05de\u05d5\u05ea \u05e2\u05e6\u05de\u05d0\u05d9, {platform_name} \u05de\u05e9\u05ea\u05de\u05e9\u05ea \u05d1\u05de\u05d4 \u05e9\u05de\u05db\u05d5\u05e0\u05d4 \"\u05d7\u05ea\u05d9\u05de\u05d4 \u05e0\u05e4\u05e8\u05d3\u05ea\"&quot;\".",
    "Change": "\u05e9\u05d9\u05e0\u05d5\u05d9",
