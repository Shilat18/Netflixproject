    ],
    "Your password must contain at least %(min_numeric)d number.": [
      "\u05e2\u05dc \u05d4\u05e1\u05d9\u05e1\u05de\u05d4 \u05e9\u05dc\u05db\u05dd \u05dc\u05d4\u05db\u05d9\u05dc \u05dc\u05e4\u05d7\u05d5\u05ea %(min_numeric)d \u05de\u05e1\u05e4\u05e8\u05d9\u05dd.",
      "\u05e2\u05dc \u05d4\u05e1\u05d9\u05e1\u05de\u05d4 \u05e9\u05dc\u05db\u05dd \u05dc\u05d4\u05db\u05d9\u05dc \u05dc\u05e4\u05d7\u05d5\u05ea %(min_numeric)d \u05de\u05e1\u05e4\u05e8\u05d9\u05dd.",
      "\u05e2\u05dc \u05d4\u05e1\u05d9\u05e1\u05de\u05d4 \u05e9\u05dc\u05db\u05dd \u05dc\u05d4\u05db\u05d9\u05dc \u05dc\u05e4\u05d7\u05d5\u05ea %(min_numeric)d \u05de\u05e1\u05e4\u05e8\u05d9\u05dd.",
