    "Thank you for enrolling in:": "\u05ea\u05d5\u05d3\u05d4 \u05e9\u05e0\u05e8\u05e9\u05de\u05ea\u05dd \u05dc:",
    "Thank you for joining {platform_name}. Just a couple steps before you start learning!": "\u05ea\u05d5\u05d3\u05d4 \u05e9\u05d4\u05e6\u05d8\u05e8\u05e4\u05ea\u05dd \u05dc-{platform_name}. \u05e8\u05e7 \u05e2\u05d5\u05d3 \u05db\u05de\u05d4 \u05e6\u05e2\u05d3\u05d9\u05dd \u05dc\u05e4\u05e0\u05d9 \u05e9\u05ea\u05ea\u05d7\u05d9\u05dc\u05d5 \u05dc\u05dc\u05de\u05d5\u05d3!",
    "Thank you for setting your course goal to {goal}!": "\u05ea\u05d5\u05d3\u05d4 \u05dc\u05da \u05e2\u05dc \u05d4\u05d2\u05d3\u05e8\u05ea \u05d9\u05e2\u05d3 \u05d4\u05e7\u05d5\u05e8\u05e1 \u05e9\u05dc\u05da \u05dc\u05db\u05d3\u05d9 {goal}!",
    "Thank you for sharing your reasons for unenrolling.": "\u05ea\u05d5\u05d3\u05d4 \u05e9\u05e9\u05d9\u05ea\u05e4\u05ea\u05dd \u05d0\u05ea \u05d4\u05e1\u05d9\u05d1\u05d5\u05ea \u05e9\u05dc\u05db\u05dd \u05dc\u05d1\u05d9\u05d8\u05d5\u05dc \u05d4\u05d4\u05e8\u05e9\u05de\u05d4.",
    "Thank you for signing up for {platform_name}.": "\u05ea\u05d5\u05d3\u05d4 \u05e8\u05d1\u05d4 \u05e2\u05dc \u05e9\u05e0\u05e8\u05e9\u05de\u05ea \u05dc{platform_name}.",
    "Thank you for submitting a request! We appreciate your patience while we work to review your request.": "\u05ea\u05d5\u05d3\u05d4 \u05e2\u05dc \u05d4\u05d2\u05e9\u05ea \u05d4\u05d1\u05e7\u05e9\u05d4! \u05d0\u05e0\u05d5 \u05de\u05e2\u05e8\u05d9\u05db\u05d9\u05dd \u05d0\u05ea \u05e1\u05d1\u05dc\u05e0\u05d5\u05ea\u05db\u05dd \u05d1\u05d6\u05de\u05df \u05e9\u05e0\u05e4\u05e2\u05dc \u05dc\u05d1\u05d3\u05d9\u05e7\u05ea \u05d1\u05e7\u05e9\u05ea\u05db\u05dd.",
    "Thank you for submitting your financial assistance application for {course_name}! You can expect a response in 2-4 business days.": "\u05ea\u05d5\u05d3\u05d4 \u05e9\u05e9\u05dc\u05d7\u05ea \u05d0\u05ea \u05d0\u05e4\u05dc\u05d9\u05e7\u05e6\u05d9\u05d9\u05ea \u05d4\u05e1\u05d9\u05d5\u05e2 \u05d4\u05db\u05e1\u05e4\u05d9 \u05e9\u05dc\u05da \u05dc-{course_name}! \u05ea\u05d5\u05db\u05dc \u05dc\u05e6\u05e4\u05d5\u05ea \u05dc\u05ea\u05e9\u05d5\u05d1\u05d4 \u05ea\u05d5\u05da 4-2 \u05d9\u05de\u05d9 \u05e2\u05e1\u05e7\u05d9\u05dd.",
    "Thank you for submitting your photos for identity verification with %(platform_name)s. ": "\u05ea\u05d5\u05d3\u05d4 \u05e2\u05dc \u05e9\u05dc\u05d9\u05d7\u05ea \u05d4\u05ea\u05de\u05d5\u05e0\u05d5\u05ea \u05e9\u05dc\u05db\u05dd \u05dc\u05d0\u05d9\u05de\u05d5\u05ea \u05d6\u05d9\u05d4\u05d5\u05d9 \u05e2\u05dd %(platform_name)s.",
    "Thank you for submitting your photos!": "\u05ea\u05d5\u05d3\u05d4 \u05e2\u05dc \u05e9\u05dc\u05d9\u05d7\u05ea \u05d4\u05ea\u05de\u05d5\u05e0\u05d5\u05ea \u05e9\u05dc\u05db\u05dd!",
    "Thank you for submitting your photos. We will review them shortly. You can now sign up for any %(platformName)s course that offers verified certificates. Verification is good for one year. After one year, you must submit photos for verification again.": "\u05ea\u05d5\u05d3\u05d4 \u05e2\u05dc \u05d4\u05d2\u05e9\u05ea \u05ea\u05de\u05d5\u05e0\u05d5\u05ea\u05d9\u05da. \u05d0\u05e0\u05d5 \u05e0\u05d1\u05d3\u05d5\u05e7 \u05d0\u05d5\u05ea\u05df \u05d1\u05e7\u05e8\u05d5\u05d1. \u05d9\u05e9 \u05d1\u05d0\u05e4\u05e9\u05e8\u05d5\u05ea\u05da \u05db\u05e2\u05ea \u05dc\u05d4\u05d9\u05e8\u05e9\u05dd \u05dc\u05db\u05dc \u05e7\u05d5\u05e8\u05e1\u05d9 %(platformName)s \u05e9\u05de\u05e6\u05d9\u05e2\u05d9\u05dd \u05ea\u05e2\u05d5\u05d3\u05d4 \u05e2\u05dd \u05d6\u05d4\u05d5\u05ea \u05de\u05d0\u05d5\u05de\u05ea\u05ea. \u05d0\u05d9\u05de\u05d5\u05ea \u05d6\u05d4\u05d5\u05ea\u05da \u05ea\u05e7\u05e3 \u05dc\u05e9\u05e0\u05d4 \u05d0\u05d7\u05ea. \u05dc\u05d0\u05d7\u05e8 \u05e9\u05e0\u05d4, \u05e2\u05dc\u05d9\u05da \u05dc\u05d4\u05d2\u05d9\u05e9 \u05ea\u05de\u05d5\u05e0\u05d5\u05ea \u05dc\u05d0\u05d9\u05de\u05d5\u05ea \u05d7\u05d5\u05d6\u05e8.",
