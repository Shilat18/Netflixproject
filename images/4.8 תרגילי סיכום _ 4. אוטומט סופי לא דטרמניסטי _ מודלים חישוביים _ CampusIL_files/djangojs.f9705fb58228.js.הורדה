      "\u05d4\u05e7\u05d5\u05d1\u05e5 \u05d7\u05d9\u05d9\u05d1 \u05dc\u05d4\u05e1\u05ea\u05d9\u05d9\u05dd \u05d1\u05e1\u05d5\u05d2 \u05e7\u05d5\u05d1\u05e5 '{file_types}'."
    ],
