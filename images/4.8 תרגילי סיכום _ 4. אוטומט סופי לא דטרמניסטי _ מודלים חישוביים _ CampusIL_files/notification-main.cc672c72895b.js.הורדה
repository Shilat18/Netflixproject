// showEachSec in milliseconds
function setWithExpiry(key, value, showEachSec) {
  const now = new Date()
  // `item` is an object which contains the original value
  // as well as the time when it's supposed to expire
  const item = {
    value: value,
    expiry: now.getTime() + showEachSec,
  }
  localStorage.setItem(key, JSON.stringify(item))
}

function getWithExpiry(key) {
  const itemStr = localStorage.getItem(key)
  // if the item doesn't exist, return null
  if (!itemStr) {
    return null
  }
  const item = JSON.parse(itemStr)
  const now = new Date()
  // compare the expiry time of the item with the current time
  if (now.getTime() > item.expiry) {
    // If the item is expired, delete the item from storage
    // and return null
    localStorage.removeItem(key)
    return undefined
  }
  return item.value
}

function toggleNotification(isShow, showEachSec) {
  // prepare element in case element is not provided
  var $el = $('#freeze-notification');
  if (showEachSec) _showEachSec = showEachSec

  // toggle in case status is not provided
  if (isShow == null || isShow == undefined)
    isShow = !$el.hasClass('is-shown');

  js_el = $el.get(0);
    if (js_el)
      js_el.style.display = null;
      
  // toggle the notification
  if (isShow)
    $el.addClass('is-shown');
  else {
    $el.removeClass('is-shown');

    // in case user don't want to see the message again --> set flag for message dissapear
    setWithExpiry(_showFreezeNotification, 1, _showEachSec); // add to localstorage
  }
}

function showFreezeNotification(showEachSec, text) {
  var _isExist = getWithExpiry(_showFreezeNotification);
  if (_isExist == null) {
    var _title = $('#freeze-notification .title-text');
    var _body = $('#freeze-notification .body-text');

    // set title text
    _title.html('<div>' + text.title + '</div><br/>');

    // set body text(s)
    text.body.forEach(function(bodyRow) {
      if (!bodyRow) _body.append('<br/>');
      else _body.append('<div>' + bodyRow + '</div>');
    });

    toggleNotification(true, showEachSec);         // hide show notification

    return true;
  }
};

function isShowFreezeNotification() {
  _notifications.forEach(function(element) {

    // create date objects
    element.startDate = new Date(element.startDateStr);
    element.stopDate = new Date(element.stopDateStr);

    // check the date objects
    if (element.startDate <= _today && element.stopDate > _today) {
      return !showFreezeNotification(element.showEachSec, element.text);    
    }
  });
}
window.addEventListener('DOMContentLoaded', (event) => {
  // show notification
  isShowFreezeNotification();
});
