
$(function() {
    //----- OPEN
    $('[open-popup]').on('click', function(e)  {
        var targeted_popup_class = jQuery(this).attr('open-popup');
        $('[data-popup="' + targeted_popup_class + '"]').fadeIn(350);
 
        e.preventDefault();
    });
 
    //----- CLOSE
    $('[close-popup]').on('click', function(e)  {
        var targeted_popup_class = jQuery(this).attr('close-popup');
        $('[data-popup="' + targeted_popup_class + '"]').fadeOut(350);
 
        e.preventDefault();
    });
});


