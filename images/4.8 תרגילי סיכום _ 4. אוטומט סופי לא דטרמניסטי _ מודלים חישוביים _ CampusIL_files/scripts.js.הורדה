window.addEventListener('message', (event) => {
  if (event.data.type === 'scroll') {
    let _scrollTop = event.data.scrollTop + 1800;

    reveal(_scrollTop);
    revealLong(_scrollTop);
    revealShort(_scrollTop);
    //console.log('Parent scroll position:', event.data.scrollTop);
  }
});
