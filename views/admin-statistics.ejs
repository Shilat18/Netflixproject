<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Statistics</title>

    <link rel="stylesheet" href="/style.css">

    <script src="https://d3js.org/d3.v7.min.js"></script>
</head>

<body class="admin-page">

    <main class="admin-panel admin-panel-wide">

        <div class="admin-header">
            <div>
                <p class="admin-eyebrow">Admin Area</p>
                <h1>Statistics</h1>
            </div>

            <div class="admin-actions">
                <a href="/admin/users">Users</a>
                <a href="/admin/content">Content</a>
                <a href="/homepage">Homepage</a>
                <a href="/logout">Logout</a>
            </div>
        </div>

        <section class="statistics-cards">

            <article class="statistics-card">
                <h2><%= totalUsers %></h2>
                <p>Users</p>
            </article>

            <article class="statistics-card">
                <h2><%= totalMovies %></h2>
                <p>Content items</p>
            </article>

            <article class="statistics-card">
                <h2><%= totalViews %></h2>
                <p>Total views</p>
            </article>

            <article class="statistics-card">
                <h2><%= averageRating %></h2>
                <p>Average rating</p>
            </article>

        </section>

        <section class="statistics-chart">
            <h2>Top 10 most viewed content</h2>
            <div id="viewsChart"></div>
        </section>

        <section class="statistics-chart">
            <h2>Content by category</h2>
            <div id="categoryChart"></div>
        </section>

    </main>

    <script>
        const topMovies = <%- JSON.stringify(topMovies) %>;
        const categoryStatistics =
            <%- JSON.stringify(categoryStatistics) %>;

        function createBarChart() {
            const width = 900;
            const height = 420;
            const margin = {
                top: 30,
                right: 30,
                bottom: 120,
                left: 70
            };

            const svg = d3.select('#viewsChart')
                .append('svg')
                .attr('viewBox', `0 0 ${width} ${height}`);

            const x = d3.scaleBand()
                .domain(topMovies.map(function (movie) {
                    return movie.title;
                }))
                .range([margin.left, width - margin.right])
                .padding(0.2);

            const y = d3.scaleLinear()
                .domain([
                    0,
                    d3.max(topMovies, function (movie) {
                        return movie.views;
                    }) || 1
                ])
                .nice()
                .range([height - margin.bottom, margin.top]);

            svg.append('g')
                .attr(
                    'transform',
                    `translate(0, ${height - margin.bottom})`
                )
                .call(d3.axisBottom(x))
                .selectAll('text')
                .attr('transform', 'rotate(-40)')
                .style('text-anchor', 'end');

            svg.append('g')
                .attr('transform', `translate(${margin.left}, 0)`)
                .call(d3.axisLeft(y));

            svg.selectAll('.views-bar')
                .data(topMovies)
                .enter()
                .append('rect')
                .attr('class', 'views-bar')
                .attr('x', function (movie) {
                    return x(movie.title);
                })
                .attr('y', function (movie) {
                    return y(movie.views);
                })
                .attr('width', x.bandwidth())
                .attr('height', function (movie) {
                    return height - margin.bottom - y(movie.views);
                });
        }

        function createCategoryChart() {
            const width = 900;
            const height = 400;
            const margin = {
                top: 30,
                right: 30,
                bottom: 70,
                left: 70
            };

            const svg = d3.select('#categoryChart')
                .append('svg')
                .attr('viewBox', `0 0 ${width} ${height}`);

            const x = d3.scaleBand()
                .domain(categoryStatistics.map(function (item) {
                    return item.category;
                }))
                .range([margin.left, width - margin.right])
                .padding(0.25);

            const y = d3.scaleLinear()
                .domain([
                    0,
                    d3.max(categoryStatistics, function (item) {
                        return item.amount;
                    }) || 1
                ])
                .nice()
                .range([height - margin.bottom, margin.top]);

            svg.append('g')
                .attr(
                    'transform',
                    `translate(0, ${height - margin.bottom})`
                )
                .call(d3.axisBottom(x));

            svg.append('g')
                .attr('transform', `translate(${margin.left}, 0)`)
                .call(d3.axisLeft(y).ticks(5));

            svg.selectAll('.category-bar')
                .data(categoryStatistics)
                .enter()
                .append('rect')
                .attr('class', 'category-bar')
                .attr('x', function (item) {
                    return x(item.category);
                })
                .attr('y', function (item) {
                    return y(item.amount);
                })
                .attr('width', x.bandwidth())
                .attr('height', function (item) {
                    return height - margin.bottom - y(item.amount);
                });
        }

        createBarChart();
        createCategoryChart();
    </script>

</body>
</html>