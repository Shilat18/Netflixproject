<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0">

    <title>Admin Users</title>

    <link
        rel="stylesheet"
        href="/style.css">
</head>

<body class="admin-page">

    <main class="admin-panel">

        <%
            const safeErrorMessage =
                typeof errorMessage !== 'undefined'
                    ? errorMessage
                    : null;

            const safeSuccessMessage =
                typeof successMessage !== 'undefined'
                    ? successMessage
                    : null;

            const safeFormData =
                typeof formData !== 'undefined' && formData
                    ? formData
                    : {};

            const safeUsers =
                typeof users !== 'undefined' && Array.isArray(users)
                    ? users
                    : [];
        %>

        <div class="admin-header">

            <div>
                <p class="admin-eyebrow">
                    Admin Area
                </p>

                <h1>Users</h1>
            </div>

            <div class="admin-actions">
                <a href="/admin/content">
                    Content
                </a>

                <a href="/admin/statistics">
                    Statistics
                </a>

                <a href="/profiles">
                    Profiles
                </a>

                <a href="/logout">
                    Logout
                </a>
            </div>

        </div>

        <% if (safeErrorMessage) { %>

            <p class="alert-error">
                <%= safeErrorMessage %>
            </p>

        <% } %>

        <% if (safeSuccessMessage) { %>

            <p class="alert-success">
                <%= safeSuccessMessage %>
            </p>

        <% } %>

        <section class="admin-form-section">

            <h2>Create New User</h2>

            <form
                class="admin-form"
                action="/admin/users/add"
                method="POST">

                <label>
                    Name

                    <input
                        type="text"
                        name="name"
                        required
                        value="<%= safeFormData.name || '' %>">
                </label>

                <label>
                    Email

                    <input
                        type="email"
                        name="email"
                        required
                        value="<%= safeFormData.email || '' %>">
                </label>

                <label>
                    Password

                    <input
                        type="password"
                        name="password"
                        minlength="6"
                        required>
                </label>

                <label>
                    Role

                    <select
                        name="role"
                        required>

                        <option
                            value="user"
                            <%= safeFormData.role !== 'admin'
                                ? 'selected'
                                : '' %>>

                            User
                        </option>

                        <option
                            value="admin"
                            <%= safeFormData.role === 'admin'
                                ? 'selected'
                                : '' %>>

                            Admin
                        </option>

                    </select>
                </label>

                <div class="admin-form-actions">

                    <button type="submit">
                        Create User
                    </button>

                </div>

            </form>

        </section>

        <section class="admin-users-section">

            <h2>Existing Users</h2>

            <table class="users-table">

                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Created</th>
                    </tr>
                </thead>

                <tbody>

                    <% if (safeUsers.length === 0) { %>

                        <tr>
                            <td colspan="4">
                                No users found.
                            </td>
                        </tr>

                    <% } %>

                    <% safeUsers.forEach(function (user) { %>

                        <tr>

                            <td>
                                <%= user.name || '-' %>
                            </td>

                            <td>
                                <%= user.email || '-' %>
                            </td>

                            <td>
                                <span class="role-badge">
                                    <%= user.role || 'user' %>
                                </span>
                            </td>

                            <td>
                                <%
                                    let createdDate = '-';

                                    if (user.createdAt) {
                                        createdDate =
                                            new Date(
                                                user.createdAt
                                            ).toLocaleDateString(
                                                'en-US'
                                            );
                                    }
                                %>

                                <%= createdDate %>
                            </td>

                        </tr>

                    <% }); %>

                </tbody>

            </table>

        </section>

    </main>

</body>

</html>