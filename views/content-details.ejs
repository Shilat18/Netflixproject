<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= movie.title %></title>
    <link rel="stylesheet" href="/homepage.css">
</head>

<body>
    <header class="navbar">
        <div class="right">
            <img src="https://upload.wikimedia.org/wikipedia/commons/0/08/Netflix_2015_logo.svg" class="logo" alt="Netflix">
        </div>

        <div class="left">
            <a href="/homepage" class="nav-link">Home</a>
            <a href="/my-list" class="nav-link">My List</a>
            <a href="/logout" class="nav-link">Logout</a>
        </div>
    </header>

    <main class="details-page">
        <img src="/images/<%= movie.image %>" alt="<%= movie.title %>" class="details-poster">

        <section class="details-copy">
            <p class="movie-meta"><%= movie.category %> | <%= movie.year %> | Rating <%= movie.rating %></p>
            <h1><%= movie.title %></h1>
            <p><%= movie.description %></p>

            <div class="quick-actions">
                <a href="/watch/<%= movie.id %>" class="play-btn">Play</a>
                <a href="#addReview" class="info-btn">Add Rating</a>
                <form class="inline-form" action="/my-list/<%= movie.id %>/toggle" method="POST">
                    <input type="hidden" name="redirectTo" value="/content/<%= movie.id %>">
                    <button type="submit" class="info-btn"><%= movie.isInMyList ? 'Remove from My List' : '+ My List' %></button>
                </form>
            </div>

            <h2 id="reviews">Reviews</h2>
            <% if (movie.reviews && movie.reviews.length) { %>
                <% movie.reviews.forEach(function(review) { %>
                    <article class="review-card">
                        <strong><%= review.user %> rated <%= review.rating %>/5</strong>
                        <p><%= review.text %></p>
                    </article>
                <% }); %>
            <% } else { %>
                <p class="empty-reviews">No reviews yet. Be the first to add one.</p>
            <% } %>

            <form id="addReview" class="review-form" action="/content/<%= movie.id %>/reviews" method="POST">
                <h2>Add your review</h2>

                <label for="rating">Rating</label>
                <select id="rating" name="rating" required>
                    <option value="5">5 - Excellent</option>
                    <option value="4">4 - Great</option>
                    <option value="3">3 - Good</option>
                    <option value="2">2 - Okay</option>
                    <option value="1">1 - Not for me</option>
                </select>

                <label for="reviewText">Review</label>
                <textarea id="reviewText" name="reviewText" rows="4" maxlength="300" required placeholder="Write a short review..."></textarea>

                <button type="submit" class="play-btn">Save Review</button>
            </form>
        </section>
    </main>
</body>

</html>
