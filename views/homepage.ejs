<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link rel="stylesheet" href="/homepage.css">
</head>

<body>
    <% const moodOptions = feed.moods || []; %>
    <% const moodMovies = feed.moodMovies || []; %>

    <header class="navbar">
        <div class="right">
            <img src="https://upload.wikimedia.org/wikipedia/commons/0/08/Netflix_2015_logo.svg" class="logo" alt="Netflix">
            <ul class="menu">
                <li>Home</li>
                <li>Series</li>
                <li>Movies</li>
                <li>New & Popular</li>
                <li><a href="/my-list">My List (<%= typeof myListCount !== 'undefined' ? myListCount : 0 %>)</a></li>
            </ul>
        </div>

        <div class="left">
            <i class="fa-solid fa-magnifying-glass icon"></i>
            <i class="fa-regular fa-bell icon bell"></i>
            <span class="user-chip"><%= currentUser.name %></span>
            <img src="/images/ester.jpg" class="profile" alt="Profile">
            <% if (currentUser && currentUser.role === 'admin') { %>
                <a href="/admin/users" class="nav-link">Admin</a>
            <% } %>
            <a href="/logout" class="nav-link">Logout</a>
        </div>
    </header>

    <section class="banner" style="background-image: linear-gradient(90deg, rgba(0,0,0,0.9), rgba(0,0,0,0.3)), url('/images/<%= feed.hero.image %>');">
        <div class="banner-content">
            <p class="movie-meta"><%= feed.hero.category %> | <%= feed.hero.year %> | Rating <%= feed.hero.rating %></p>
            <h1><%= feed.hero.title %></h1>
            <p><%= feed.hero.description %></p>
            <a href="/content/<%= feed.hero.id %>" class="play-btn">Play</a>
            <a href="/content/<%= feed.hero.id %>" class="info-btn">More Info</a>
            <form class="inline-form" action="/my-list/<%= feed.hero.id %>/toggle" method="POST">
                <input type="hidden" name="redirectTo" value="/homepage">
                <button type="submit" class="info-btn"><%= feed.hero.isInMyList ? 'Saved in My List' : 'Add to My List' %></button>
            </form>
        </div>
    </section>

    <main class="feed-page">
        <section class="feed-tools">
            <input id="searchInput" placeholder="Search in your feed..." aria-label="Search in your feed">
            <button type="button" onclick="sortAZ()">Sort A-Z</button>
        </section>

        <!-- Mood picker is the custom recommendation feature. -->
        <section class="mood-picker mood-feature" aria-labelledby="moodTitle">
            <div class="mood-feature-copy">
                <p>Special feature</p>
                <h2 id="moodTitle">What to watch by mood</h2>
                <span id="moodResultText">Choose your mood</span>
            </div>

            <div class="mood-buttons" role="list" aria-label="Mood choices">
                <% moodOptions.forEach(function(mood, index) { %>
                    <button
                        type="button"
                        class="mood-btn <%= index === 0 ? 'active' : '' %>"
                        data-mood="<%= mood.id %>"
                        aria-pressed="<%= index === 0 ? 'true' : 'false' %>">
                        <span><%= mood.emoji %></span>
                        <%= mood.label %>
                    </button>
                <% }); %>
            </div>

            <div class="movie-row mood-results" id="moodResults">
                <% moodMovies.forEach(function(movie) { %>
                    <%- include('partials/movie-card', { movie: movie, showProgress: false, returnTo: '/homepage' }) %>
                <% }); %>
            </div>

            <% if (!moodMovies.length) { %>
                <div class="empty-state mood-empty">
                    <h2>No mood matches yet</h2>
                    <p>Add moods to movies in the content model to show personalized mood recommendations.</p>
                </div>
            <% } %>
        </section>

        <section class="feed-row">
            <div class="row-title">
                <h2>Continue Watching</h2>
                <span><%= feed.continueWatching.length %> active titles</span>
            </div>

            <div class="movie-row">
                <% feed.continueWatching.forEach(function(movie) { %>
                    <%- include('partials/movie-card', { movie: movie, showProgress: true, returnTo: '/homepage' }) %>
                <% }); %>
            </div>
        </section>

        <section class="feed-row">
            <div class="row-title">
                <h2>Recommended For You</h2>
                <span>Based on your profile</span>
            </div>

            <div class="movie-row">
                <% feed.recommendations.forEach(function(movie) { %>
                    <%- include('partials/movie-card', { movie: movie, showProgress: false, returnTo: '/homepage' }) %>
                <% }); %>
            </div>
        </section>

        <section class="feed-row">
            <div class="row-title">
                <h2>Top 10 Popular</h2>
                <span>Most watched now</span>
            </div>

            <div class="movie-row">
                <% feed.popular.forEach(function(movie, index) { %>
                    <article class="ranked-card">
                        <span class="rank-number"><%= index + 1 %></span>
                        <%- include('partials/movie-card', { movie: movie, showProgress: false, returnTo: '/homepage' }) %>
                    </article>
                <% }); %>
            </div>
        </section>

        <% Object.keys(feed.byCategory).forEach(function(category) { %>
            <section class="feed-row">
                <div class="row-title">
                    <h2><%= category %></h2>
                    <span><%= feed.byCategory[category].length %> titles</span>
                </div>

                <div class="movie-row">
                    <% feed.byCategory[category].forEach(function(movie) { %>
                        <%- include('partials/movie-card', { movie: movie, showProgress: false, returnTo: '/homepage' }) %>
                    <% }); %>
                </div>
            </section>
        <% }); %>
    </main>

    <script src="/script.js"></script>
</body>

</html>
