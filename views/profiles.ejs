<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Select Profile</title>
    <link rel="stylesheet" href="/profiles.css">
</head>

<body>
    <main class="profiles-page">
        <section class="profiles-header">
            <img src="https://upload.wikimedia.org/wikipedia/commons/0/08/Netflix_2015_logo.svg" class="profiles-logo" alt="Netflix">
            <h1>Who's watching?</h1>
            <p>Choose a profile to continue to your Netflix homepage.</p>
        </section>

        <!-- Each profile card sends the user into the MVC homepage route. -->
        <section class="profiles-grid" aria-label="Profile selection">
            <% personasList.forEach(function(persona) { %>
                <a class="profile-card" href="/homepage" aria-label="Choose <%= persona.name %> profile">
                    <img src="<%= persona.image %>" alt="<%= persona.name %> avatar">
                    <strong><%= persona.name %></strong>
                    <span>Choose Profile</span>
                </a>
            <% }); %>
        </section>

        <!-- Profile management actions stay below the selection grid. -->
        <section class="profile-actions">
            <% if (currentUser && currentUser.role === 'admin') { %>
                <a href="/admin/users" class="secondary-action">Admin Users</a>
            <% } %>

            <form action="/profiles/add" method="POST" class="add-profile-form">
                <label for="personaName">Add a new profile</label>
                <div class="add-profile-row">
                    <input id="personaName" type="text" name="personaName" placeholder="Profile name" required>
                    <button type="submit">Add Profile</button>
                </div>
            </form>
        </section>
    </main>
</body>
</html>
