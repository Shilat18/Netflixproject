<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>Select Profile</title>
    <link rel="stylesheet" href="/profiles.css">
</head>

<body>
    <div class="container">
        <h1>מי צופה ב-NETFLIX?</h1>

        <div class="profiles">
            <% personasList.forEach(function(persona) { %>
                <a href="/homepage">
                    <div class="profile">
                        <img src="<%= persona.image %>" width="150" alt="<%= persona.name %>">
                        <p><%= persona.name %></p>
                    </div>
                </a>
            <% }); %>
        </div>

        <% if (currentUser && currentUser.role === 'admin') { %>
            <a href="/admin/users" class="manage" style="display: inline-block; text-decoration: none;">Admin Users</a>
        <% } %>

        <button class="manage">נהל פרופילים</button>

        <div class="add-persona-container" style="margin-top: 40px; text-align: center;">
            <form action="/profiles/add" method="POST" style="display: inline-block;">
                <input type="text" name="personaName" placeholder="שם פרופיל חדש" required style="padding: 10px; font-size: 16px; border-radius: 4px; border: 1px solid #666; background: #333; color: white; margin-left: 10px;">
                <button type="submit" class="manage" style="display: inline-block; width: auto; padding: 10px 20px; cursor: pointer;">הוסף פרופיל</button>
            </form>
        </div>

    </div>
</body>
</html>
