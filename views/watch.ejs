<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Watching <%= movie.title %></title>
    <link rel="stylesheet" href="/homepage.css">
</head>

<body class="watch-body">
    <header class="watch-header">
        <a href="/homepage" class="nav-link">Home</a>
        <a href="/content/<%= movie.id %>" class="nav-link">Details</a>
        <a href="/logout" class="nav-link">Logout</a>
    </header>

    <main class="watch-page">
        <section class="watch-copy">
            <p class="movie-meta"><%= movie.category %> | <%= movie.year %> | Rating <%= movie.rating %></p>
            <h1><%= movie.title %></h1>
            <p><%= movie.description %></p>
        </section>

        <div class="watch-actions">
            <button type="button" class="play-btn" id="startVideo">Start Watching</button>
        </div>

        <!-- Short local demo video that simulates playing the selected content. -->
        <video class="watch-player" id="watchPlayer" controls preload="auto" poster="/images/<%= movie.image %>">
            <source src="<%= movie.videoUrl %>" type="video/mp4">
            Your browser does not support the video tag.
        </video>
    </main>

    <script>
        // Start playback after a user click because browsers may block autoplay.
        const startButton = document.getElementById('startVideo');
        const watchPlayer = document.getElementById('watchPlayer');

        startButton.addEventListener('click', function () {
            watchPlayer.play();
        });
    </script>
</body>

</html>
